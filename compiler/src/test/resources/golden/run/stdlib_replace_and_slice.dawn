use std/str
use std/list.{slice}

pub fn main() -> Unit !io = {
  println(str.replace("a.b.c", ".", "/"))
  println(str.replace("no-hit", ",", "|"))
  println(str.replace("aaa", "aa", "b"))
  println(str.replace("ab", "", "-"))
  println("${slice([1, 2, 3, 4, 5], 1, 4)}")
  println("${slice([1, 2, 3], -2, 99)}")
  println("${slice([1, 2, 3], 2, 1)}")
}
