fn compose[A, B, C](f: fn(A) -> B !e1, g: fn(B) -> C !e2) -> fn(A) -> C !(e1 | e2) =
  fn(a) => g(f(a))

fn inc(x: Int) -> Int = x + 1
fn dbl(x: Int) -> Int = x * 2
fn tag(x: Int) -> String !io = {
  println("tag $x")
  "n$x"
}

pub fn main() -> Unit !io = {
  let p = compose(inc, tag)
  println(p(41))
}
