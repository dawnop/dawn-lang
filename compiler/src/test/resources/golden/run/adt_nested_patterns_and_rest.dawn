type Opt = | Got(v: Int) | Nothing
type Box = | Box(inner: Opt, label: String)

fn peek(b: Box) -> String =
  match b {
    Box(Got(0), ..) -> "zero"
    Box(Got(v), ..) -> "got $v"
    Box(Nothing, lab) -> "empty $lab"
  }

pub fn main() -> Unit !io = {
  println(peek(Box(Got(0), "a")))
  println(peek(Box(Got(7), "b")))
  println(peek(Box(Nothing, "c")))
}
