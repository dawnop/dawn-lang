fn parse_digit(s: String) -> Result[Int, String] =
  match s {
    "0" -> Ok(0)
    "1" -> Ok(1)
    "2" -> Ok(2)
    _ -> Err("not a digit: " ++ s)
  }

fn add_digits(a: String, b: String) -> Result[Int, String] = {
  let x = parse_digit(a)?
  let y = parse_digit(b)?
  Ok(x + y)
}

fn show(r: Result[Int, String]) -> String =
  match r {
    Ok(v) -> "ok $v"
    Err(m) -> "err: $m"
  }

pub fn main() -> Unit !io = {
  println(show(add_digits("1", "2")))
  println(show(add_digits("1", "x")))
}
