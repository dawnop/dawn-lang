const BANNER: String = comptime {
  "calc (" ++ join(map(range(0, 3), to_string), ".") ++ ")"
}
const PAIR: (Int, String) = comptime { (42, "answer") }
const FOUND: Option[Int] = comptime {
  [1, 2, 3] |> filter(fn(x) => x % 2 == 0) |> get(0)
}

pub fn main() -> Unit !io = {
  println(BANNER)
  let (n, s) = PAIR
  println("$n $s")
  match FOUND {
    Some(v) -> println("even: $v")
    None -> println("none")
  }
}
