# UFCS dot-calls resolve against names in scope — selective imports bring the
# std names in, and the sugar then chains like any function (spec §2.4).

use std/str.{trim, split}

pub fn main() -> Unit !io = {
  let s = "  a-b-c  "
  println(s.trim().split("-").join("+"))
  println("${[1, 2, 3].len()}")
}
