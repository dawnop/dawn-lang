type Color = | Red | Green | Blue

fn name(c: Color) -> String =
  match c { Red -> "r", Green -> "g", Blue -> "b" }

pub fn main() -> Unit !io = {
  let cs = [Red, Blue]
  match get(cs, 1) {
    Some(c) -> println(name(c))
    None -> println("?")
  }
  println("${[Red] == [Red]}")
  let words = ["a", "b"] ++ ["c"]
  println("${len(words)}")
}
