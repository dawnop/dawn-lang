# break/continue (spec §4.7): innermost loop only, all three loop forms,
# and comptime loops honor them too.

const FIRST_BIG_SEVEN: Int = comptime {
  var found = 0
  for i in 1..1000 {
    if i * 7 > 100 {
      found = i * 7
      break
    }
  }
  found
}

fn first_even(xs: List[Int]) -> Option[Int] = {
  var out: Option[Int] = None
  for x in xs {
    if x % 2 == 0 {
      out = Some(x)
      break
    }
  }
  out
}

pub fn main() -> Unit !io = {
  # while + break
  var n = 0
  while true {
    n = n + 1
    if n == 5 { break }
  }
  println(to_string(n))

  # for-in + continue: skip odds
  var sum = 0
  for x in [1, 2, 3, 4, 5, 6] {
    if x % 2 == 1 { continue }
    sum = sum + x
  }
  println(to_string(sum))

  # for-range + break, and continue in the same body
  var hits = 0
  for i in 0..100 {
    if i == 7 { break }
    if i % 2 == 0 { continue }
    hits = hits + i
  }
  println(to_string(hits))

  # nested: break exits only the inner loop
  var pairs = 0
  for i in 0..3 {
    for j in 0..10 {
      if j == 2 { break }
      pairs = pairs + 1
    }
  }
  println(to_string(pairs))

  println(to_string(first_even([3, 5, 8, 9])))
  println(to_string(FIRST_BIG_SEVEN))
}
