type Point = { x: Float, y: Float }
type Line = { a: Point, b: Point }

pub fn main() -> Unit !io = {
  let l = Line { a: Point { x: 1.0, y: 2.0 }, b: Point { x: 3.0, y: 4.0 } }
  println("${l.a.x} ${l.b.y}")
  let moved = Line { ..l, b: Point { ..l.b, x: 9.0 } }
  println("${moved.a.x} ${moved.b.x} ${moved.b.y}")
}
