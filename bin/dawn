#!/bin/sh
# dawn CLI launcher: the self-hosted toolchain is the daily driver (M8 phase
# 3). The standalone jar under build/ is rebuilt whenever selfhost/src or the
# bundled std changed, seeded from the Kotlin fat jar during the transition.
# DAWN_KOTLIN=1 is the escape hatch back to the Kotlin jar.
set -e

# resolve symlinks (e.g. ~/.local/bin/dawn) so ROOT is the real repo checkout
SELF="$(readlink -f "$0")"
ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"

# if JAVA_HOME is unset, try GraalVM under ~/tools. Both layouts: macOS bundles
# the JDK under Contents/Home, Linux tarballs put bin/ at the top level.
if [ -z "$JAVA_HOME" ]; then
  for d in "$HOME"/tools/graalvm-*/Contents/Home "$HOME"/tools/graalvm-*; do
    if [ -x "$d/bin/java" ]; then
      JAVA_HOME="$d"
      export JAVA_HOME
      break
    fi
  done
fi
JAVA=java
if [ -n "$JAVA_HOME" ] && [ -x "$JAVA_HOME/bin/java" ]; then
  JAVA="$JAVA_HOME/bin/java"
fi

KJAR="$ROOT/compiler/build/libs/dawn.jar"

if [ "${DAWN_KOTLIN:-}" = "1" ]; then
  if [ ! -f "$KJAR" ]; then
    echo "error: $KJAR not found" >&2
    echo "build it first: cd $ROOT && ./gradlew :compiler:fatJar" >&2
    exit 2
  fi
  exec "$JAVA" -jar "$KJAR" "$@"
fi

SJAR="$ROOT/build/dawn-selfhost.jar"
STD="$ROOT/compiler/src/main/resources/std"

needs_build=0
if [ ! -f "$SJAR" ]; then
  needs_build=1
elif [ -n "$(find "$ROOT/selfhost/src" "$STD" "$KJAR" -type f -newer "$SJAR" -print -quit 2>/dev/null)" ]; then
  needs_build=1
fi

if [ "$needs_build" = 1 ]; then
  if [ ! -f "$KJAR" ]; then
    echo "error: no selfhost jar and no seed to build one" >&2
    echo "build the seed first: cd $ROOT && ./gradlew :compiler:fatJar" >&2
    exit 2
  fi
  echo "dawn: rebuilding the selfhost toolchain (sources changed)..." >&2
  mkdir -p "$ROOT/build"
  "$JAVA" -jar "$KJAR" build "$ROOT/selfhost" -o "$SJAR.boot" > /dev/null
  "$JAVA" -Xss512m -cp "$SJAR.boot:$KJAR" main build "$ROOT/selfhost" -o "$SJAR.tmp" \
    --std "$STD" --embed-std "$STD" \
    --vendor dawn/tool --vendor org/objectweb/asm --vendor coursierapi > /dev/null
  rm -f "$SJAR.boot"
  mv "$SJAR.tmp" "$SJAR"
fi

exec "$JAVA" -Xss512m -jar "$SJAR" "$@"
