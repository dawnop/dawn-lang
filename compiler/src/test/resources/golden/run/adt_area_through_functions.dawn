type Shape =
  | Circle(r: Float)
  | Rect(w: Float, h: Float)
  | Point

fn area(s: Shape) -> Float =
  match s {
    Circle(r) -> 3.14159 * r * r
    Rect(w, h) -> w * h
    Point -> 0.0
  }

pub fn main() -> Unit !io = {
  let total = area(Circle(1.0)) + area(Rect(2.0, 3.0)) + area(Point)
  println("$total")
}
