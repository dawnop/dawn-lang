# Unit tests for the self-hosted parser. The exhaustive acceptance test is the
# golden diff (scripts/selfhost-parse-diff.sh, byte-identical to `dawn __parse`
# over the whole repo corpus); these are fast structural checks for the shapes
# that carry the most parser logic — rewrites, recovery, precedence.

use std/str
use parser.{parse_module}
use astdump.{render_module}
use ast.{
  Expr, EInt, EVar, ECall, EBinary, ECtor, EBlock,
  BinOp, OpAdd, OpMul,
  Stmt, SWhile,
  Decl, DFn, DConst, DUseModule, Module
}

fn rendered(src: String) -> String = {
  let (m, ds) = parse_module(src)
  render_module(m, ds)
}

test "a function declaration parses to one decl" {
  let (m, ds) = parse_module("fn f(x: Int) -> Int = x")
  assert len(ds) == 0
  assert len(m.decls) == 1
  match m.decls[0] {
    DFn(f) -> {
      assert f.name == "f"
      assert len(f.params) == 1
      assert f.params[0].name == "x"
    }
    _ -> { assert false }
  }
}

test "multiplication binds tighter than addition" {
  let (m, ds) = parse_module("const A: Int = 1 + 2 * 3")
  match m.decls[0] {
    DConst(name, is_pub, ann, init, lo, hi, nlo, nhi) ->
      match init {
        EBinary(op, left, right, olo, ohi, xlo, xhi) -> {
          assert op == OpAdd
          match right {
            EBinary(op2, l2, r2, a, b, c, d) -> { assert op2 == OpMul }
            _ -> { assert false }
          }
        }
        _ -> { assert false }
      }
    _ -> { assert false }
  }
}

test "pipe rewrites into a call with the left side first" {
  let (m, ds) = parse_module("fn f() = x |> g(y)")
  match m.decls[0] {
    DFn(f) ->
      match f.body {
        ECall(callee, args, a, b, c, d) -> {
          assert callee == "g"
          assert len(args) == 2
          match args[0] {
            EVar(n, e2, f2) -> { assert n == "x" }
            _ -> { assert false }
          }
        }
        _ -> { assert false }
      }
    _ -> { assert false }
  }
}

test "a broken declaration is reported and the next one still parses" {
  let (m, ds) = parse_module("fn f( = 1\n\nfn g() = 2")
  assert len(ds) > 0
  match m.decls[len(m.decls) - 1] {
    DFn(f) -> { assert f.name == "g" }
    _ -> { assert false }
  }
}

test "a binary operator may lead its continuation line" {
  # && at the start of the next line continues the expression (spec §1.7)
  let (m, ds) = parse_module("const A: Bool = x\n  && y")
  assert len(ds) == 0
  match m.decls[0] {
    DConst(name, is_pub, ann, init, lo, hi, nlo, nhi) ->
      match init {
        EBinary(op, l, r, a, b, c, d) -> ()
        _ -> { assert false }
      }
    _ -> { assert false }
  }
  # comparison and concat lead too
  let (m2, ds2) = parse_module("const B: Bool = x\n  == y")
  assert len(ds2) == 0
  let (m3, ds3) = parse_module("const C: String = x\n  ++ y")
  assert len(ds3) == 0
}

test "leading `-` does not continue (ambiguous with unary minus)" {
  # unlike &&, a `-` at line start starts fresh — here `- y` strands at top level
  let (m, ds) = parse_module("const A: Int = x\n  - y")
  assert len(ds) > 0
}

test "a bare assignment arm is reported and later arms/decls still parse" {
  # `A -> q = 1` has a bare assignment body; the arm resyncs, the `B` arm and the
  # following `g` both still parse — no cascade to end of file.
  let (m, ds) = parse_module("fn f() = match x {\n  A -> q = 1\n  B -> 2\n}\n\nfn g() = 3")
  assert len(ds) > 0
  assert str.contains(ds[0].hint, "braces")
  match m.decls[len(m.decls) - 1] {
    DFn(f) -> { assert f.name == "g" }
    _ -> { assert false }
  }
}

test "a keyword may be a member name after `.`" {
  # Java members can be named with Dawn keywords (`System.in`, `x.type`); after
  # `.` a keyword is unambiguously a member name, not syntax (spec §9.1).
  let out = rendered("fn f() = x.in")
  assert str.contains(out, "FieldAccess in")
  # the method form with a keyword name parses too
  let out2 = rendered("fn g() = x.type()")
  assert str.contains(out2, "MethodCall type")
  # a non-word after `.` is still an error
  let (m, ds) = parse_module("fn h() = x.42")
  assert len(ds) > 0
}

test "chained comparisons are an error" {
  let (m, ds) = parse_module("fn f() = a < b < c")
  assert len(ds) > 0
  assert ds[0].msg == "comparison operators cannot be chained"
  assert ds[0].hint == "write a < b && b < c"
}

test "interpolation holds a parsed expression" {
  let out = rendered("const A: String = \"x=\${1 + 2}\"")
  assert str.contains(out, "SInterp")
  assert str.contains(out, "Binary ADD")
}

test "a header expression refuses a record literal" {
  # `while C { g() }` — C stays a bare constructor and the brace opens the body
  let (m, ds) = parse_module("fn f() -> Unit = { while C { g() } }")
  assert len(ds) == 0
  match m.decls[0] {
    DFn(f) ->
      match f.body {
        EBlock(stmts, tail, a, b) ->
          match stmts[0] {
            SWhile(cond, body, c, d) ->
              match cond {
                ECtor(name, args, spread, has_parens, e2, f2, g2, h2) -> {
                  assert name == "C"
                  assert has_parens == false
                }
                _ -> { assert false }
              }
            _ -> { assert false }
          }
        _ -> { assert false }
      }
    _ -> { assert false }
  }
}

test "use ... as binds an explicit alias" {
  let (m, ds) = parse_module("use json/lexer as lex\n\nfn f() = 1")
  assert len(ds) == 0
  match m.decls[0] {
    DUseModule(segs, sel, aname, a, b, c, d) -> {
      assert segs == ["json", "lexer"]
      match aname {
        Some(n) -> { assert n.name == "lex" }
        None -> { assert false }
      }
    }
    _ -> { assert false }
  }
}

test "selective use keeps its import names" {
  let (m, ds) = parse_module("use json/value.{Json, render}\n\nfn f() = 1")
  match m.decls[0] {
    DUseModule(segs, selective, _al, a, b, c, d) -> {
      assert segs == ["json", "value"]
      match selective {
        Some(names) -> {
          assert len(names) == 2
          assert names[0].name == "Json"
        }
        None -> { assert false }
      }
    }
    _ -> { assert false }
  }
}

test "assert statements capture their source text" {
  let out = rendered("test \"t\" {\n  assert 1 + 1 == 2\n}")
  assert str.contains(out, "Assert src=1 + 1 == 2 ")
}

test "unterminated string in an interpolation-free file recovers" {
  let (m, ds) = parse_module("fn f() = \"abc")
  assert len(ds) > 0
  assert ds[0].msg == "unterminated string"
}
