fn compose[A, B, C](f: fn(A) -> B !e1, g: fn(B) -> C !e2) -> fn(A) -> C !(e1 | e2) =
  fn(a) => g(f(a))

fn readTag(x: Int) -> Int !io = {
  println("read $x")
  x
}
fn writeTag(x: Int) -> String !io = {
  println("write $x")
  "ok$x"
}

pub fn main() -> Unit !io = {
  let p = compose(readTag, writeTag)
  println(p(7))
}
