# Bitwise operators (Int only): & | ^ ~ << >> >>>. See docs/spec.md §4.3.
# A const exercises the comptime folder; main() exercises codegen.

const MASK: Int = (1 << 8) | 0xF

pub fn main() -> Unit !io = {
  # the six binary operators and the prefix ~
  println(to_string(6 & 3))
  println(to_string(6 | 1))
  println(to_string(6 ^ 3))
  println(to_string(1 << 4))
  println(to_string(256 >> 2))
  println(to_string(~0))

  # >> is arithmetic (sign-extends), >>> is logical (zero-fills)
  println(to_string(-8 >> 1))
  println(to_string(-8 >>> 60))

  # bitwise binds tighter than comparison: (6 & 3) == 2, no C footgun
  println(to_string(6 & 3 == 2))
  # shift is looser than +: (1 + 1) << 4
  println(to_string(1 + 1 << 4))
  # & tighter than ^ tighter than |: 1 | 6 ^ 3 & 2  ==  1 | (6 ^ (3 & 2))
  println(to_string(1 | 6 ^ 3 & 2))

  # comptime-folded constant
  println(to_string(MASK))
}
