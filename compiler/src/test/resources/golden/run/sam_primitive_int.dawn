# SAM conversion with a primitive-int interface (IntBinaryOperator): parameters
# widen int→Int at the bridge, the return narrows Int→int (checked, spec §9.4).
use java "java.util.stream.IntStream"

pub fn main() -> Unit !io = {
  let total = IntStream.range(1, 5).expect("s").reduce(0, fn(a, b) => a + b)
  println(to_string(total))
}
