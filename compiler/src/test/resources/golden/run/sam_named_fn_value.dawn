# A named pure Dawn function as a SAM argument (LongUnaryOperator): the
# fn-value path, not the deferred-lambda path (spec §9.4).
use java "java.util.stream.LongStream"

fn double_it(x: Int) -> Int = x * 2

pub fn main() -> Unit !io = {
  let s = LongStream.range(1, 4).expect("s").map(double_it).expect("s").sum()
  println(to_string(s))
}
