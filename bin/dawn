#!/bin/sh
# dawn CLI launcher: the self-hosted toolchain, seeded from the previous
# release (M8 phase 5 — the Kotlin implementation is archived at the
# kotlin-final tag). In a repo checkout the standalone jar under build/ is
# rebuilt whenever selfhost/src, std/ or the pinned seed changed; outside one
# (the playground server rsyncs bin/ + build/) it just runs the shipped jar.
set -e

# resolve symlinks (e.g. ~/.local/bin/dawn) so ROOT is the real repo checkout
SELF="$(readlink -f "$0")"
ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"

# if JAVA_HOME is unset, try GraalVM under ~/tools. Both layouts: macOS bundles
# the JDK under Contents/Home, Linux tarballs put bin/ at the top level.
if [ -z "$JAVA_HOME" ]; then
  for d in "$HOME"/tools/graalvm-*/Contents/Home "$HOME"/tools/graalvm-*; do
    if [ -x "$d/bin/java" ]; then
      JAVA_HOME="$d"
      export JAVA_HOME
      break
    fi
  done
fi
JAVA=java
if [ -n "$JAVA_HOME" ] && [ -x "$JAVA_HOME/bin/java" ]; then
  JAVA="$JAVA_HOME/bin/java"
fi

SJAR="$ROOT/build/dawn-selfhost.jar"
STD="$ROOT/std"

# deployed form: no sources, no seed resolver — run the shipped jar as-is
if [ ! -f "$ROOT/scripts/seedjar.sh" ]; then
  if [ ! -f "$SJAR" ]; then
    echo "error: $SJAR not found (deployments must ship build/dawn-selfhost.jar)" >&2
    exit 2
  fi
  exec "$JAVA" -Xss512m -jar "$SJAR" "$@"
fi

. "$ROOT/scripts/seedjar.sh"

needs_build=0
if [ ! -f "$SJAR" ]; then
  needs_build=1
elif [ -n "$(find "$ROOT/selfhost/src" "$ROOT/selfhost/dawn.toml" "$STD" \
    "$ROOT/scripts/seed-release.txt" -type f -newer "$SJAR" -print -quit 2>/dev/null)" ]; then
  needs_build=1
fi

if [ "$needs_build" = 1 ]; then
  SEED="$(seed_jar)"
  echo "dawn: rebuilding the selfhost toolchain (sources changed)..." >&2
  mkdir -p "$ROOT/build"
  "$JAVA" -Xss512m -jar "$SEED" build "$ROOT/selfhost" -o "$SJAR.tmp" \
    --std "$STD" --embed-std "$STD" \
    --vendor dawn/tool --vendor org/objectweb/asm --vendor coursierapi > /dev/null
  mv "$SJAR.tmp" "$SJAR"
fi

exec "$JAVA" -Xss512m -jar "$SJAR" "$@"
