type Expr =
  | Num(v: Int)
  | Add(l: Expr, r: Expr)
  | Mul(l: Expr, r: Expr)

fn eval(e: Expr) -> Int =
  match e {
    Num(v) -> v
    Add(l, r) -> eval(l) + eval(r)
    Mul(l, r) -> eval(l) * eval(r)
  }

pub fn main() -> Unit !io = {
  # (2 + 3) * 4
  let e = Mul(Add(Num(2), Num(3)), Num(4))
  println("${eval(e)}")
}
