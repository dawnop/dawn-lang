pub fn main() -> Unit !io = {
  # reverse: reversed copy, input untouched
  let xs = [1, 2, 3, 4]
  let empty: List[Int] = []
  println(to_string(reverse(xs)))
  println(to_string(xs))
  println(to_string(reverse(empty)))

  # take / drop: clamped to the length, never panic
  println(to_string(take(xs, 2)))
  println(to_string(take(xs, 99)))
  println(to_string(take(xs, 0)))
  println(to_string(drop(xs, 2)))
  println(to_string(drop(xs, 99)))
  println(to_string(drop(xs, 0)))

  # find: first element satisfying the predicate, else None
  println(to_string(find(xs, fn(n) => n % 2 == 0)))
  println(to_string(find(xs, fn(n) => n > 10)))

  # index_of / last_index_of: code-point index of a substring, else None
  println(to_string(index_of("qiniu://a", "://")))
  println(to_string(index_of("a/b/c", "/")))
  println(to_string(last_index_of("a/b/c", "/")))
  println(to_string(index_of("abc", "z")))
  # astral char counts as one code point (b sits at code-point index 2)
  println(to_string(index_of("a\u{1f600}b", "b")))
}
