# Map/Set semantics on the persistent HAMT (spec §2.2): insertion-order
# iteration, update keeps position, persistence, order-independent equality.

pub fn main() -> Unit !io = {
  var m: Map[String, Int] = map_empty()
  m = map_insert(m, "b", 2)
  m = map_insert(m, "a", 1)
  m = map_insert(m, "c", 3)
  m = map_insert(m, "b", 20)         # updating b keeps its original position

  println(to_string(map_size(m)))
  println(to_string(m["a"]))
  println(to_string(m["b"]))
  println(to_string(map_keys(m)))    # insertion order, b still first
  println(to_string(map_values(m)))
  println(to_string(map_has(m, "z")))

  let m2 = map_remove(m, "a")
  println(to_string(map_keys(m2)))
  println(to_string(map_keys(m)))    # original unchanged: the map is persistent

  # equal keys/values in any insertion order compare equal
  var p: Map[String, Int] = map_empty()
  p = map_insert(p, "c", 3)
  p = map_insert(p, "b", 20)
  p = map_insert(p, "a", 1)
  println(to_string(m == p))

  # Set: duplicate ignored, insertion order preserved
  var s: Set[Int] = set_empty()
  s = set_insert(s, 3)
  s = set_insert(s, 1)
  s = set_insert(s, 3)
  println(to_string(set_size(s)))
  println(to_string(set_to_list(s)))
  println(to_string(set_has(s, 1)))
}
