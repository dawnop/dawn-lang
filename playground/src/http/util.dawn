# Small Java-interop helpers the HTTP layer leans on.
use java "java.util.concurrent.CountDownLatch"

# Park the calling thread forever. main() returning would let the JVM exit out
# from under the server's request threads, so the entry point blocks here.
pub fn block_forever() -> Unit !io = {
  let latch = CountDownLatch.new(1)
  latch.await()
}
