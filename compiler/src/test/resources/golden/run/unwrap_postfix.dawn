use std/str
use java "java.net.URI"
use java "java.lang.StringBuilder"

# `!` unwraps an Option (spec §8.2). On Java interop it replaces the placeholder
# strings `.expect("uri")` forced on us — Java reference returns are Option (§9.2).
pub fn main() -> Unit !io = {
  println("${Some(41)! + 1}")
  println(Some("hi")!)

  # a line may end in `!` — the newline still separates statements
  let u = URI.create("https://dawnop.com/a/b")!
  println(u.getPath()!)

  # chains: unwrap, call, unwrap again
  println(URI.create("https://dawnop.com/x")!.getHost()!)

  # `!=` is one token; `x! != v` compares the unwrapped value
  println("${Some(1)! != 2}")

  # a constructor is never null, so it needs no `!` (spec §9.2)
  let sb = StringBuilder.new()
  println("${len(str.chars(sb.append("ab")!.toString()!))}")
}
