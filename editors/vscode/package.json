{
  "name": "dawn-lang",
  "displayName": "Dawn Language",
  "description": "Language support for Dawn: diagnostics, hover, go to definition, outline.",
  "version": "0.1.0",
  "publisher": "dawnop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dawnop/dawn-lang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "dawn",
        "aliases": ["Dawn"],
        "extensions": [".dawn"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dawn",
        "scopeName": "source.dawn",
        "path": "./syntaxes/dawn.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Dawn",
      "properties": {
        "dawn.lspPath": {
          "type": "string",
          "default": "dawn",
          "description": "Path to the dawn CLI (the language server runs as `dawn lsp`)."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
