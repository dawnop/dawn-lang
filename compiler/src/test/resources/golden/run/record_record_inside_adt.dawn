type Point = { x: Float, y: Float }
type Shape =
  | Circle(center: Point, r: Float)
  | Dot(at: Point)

fn cx(s: Shape) -> Float =
  match s {
    Circle(c, ..) -> c.x
    Dot(Point { x, ..}) -> x
  }

pub fn main() -> Unit !io = {
  println("${cx(Circle(Point { x: 1.5, y: 0.0 }, 2.0))}")
  println("${cx(Dot(Point { x: 4.5, y: 0.0 }))}")
}
