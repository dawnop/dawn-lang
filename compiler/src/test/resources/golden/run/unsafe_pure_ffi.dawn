use java "java.lang.Math"

# Layer 1: first-order pure wrappers. unsafe_pure lets a Java interop call back a
# pure function (docs/pure-ffi-design.md); the stamp lives only here.
pub fn maxi(a: Int, b: Int) -> Int = unsafe_pure { Math.max(a, b) }
pub fn rem(a: Int, b: Int) -> Int = unsafe_pure { Math.floorMod(a, b) }

# Layer 2: pure Dawn recursion over the vouched primitives — no stamp, stays pure.
pub fn gcd(a: Int, b: Int) -> Int = if b == 0 { a } else { gcd(b, rem(a, b)) }

pub fn main() -> Unit !io = {
  println("${maxi(3, 7)}")
  println("${gcd(48, 36)}")
}
