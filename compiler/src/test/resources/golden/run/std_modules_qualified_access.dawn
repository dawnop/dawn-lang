# The P0.7 stdlib shape (docs/stdlib-naming.md): std as real modules with short
# names — `use std/map`, then map.insert(...); hot names can come in selectively.
# Same-named fns across modules (str.len / bytes.len) resolve by qualification.

use std/map
use std/set
use std/cursor
use std/str
use std/bytes
use std/list.{take}

pub fn main() -> Unit !io = {
  let m = map.insert(map.empty(), "k", 1)
  println("${map.size(m)} ${unwrap_or(map.get(m, "k"), 0)}")
  let s = set.from([1, 2, 2, 3])
  println("${set.size(s)} ${set.has(s, 2)}")
  let text = "a,b,c"
  println(cursor.slice(text, cursor.start(text), cursor.end(text)))
  println("${str.len("héllo")} ${bytes.len(bytes.utf8("héllo"))}")
  println("${take([1, 2, 3], 2)}")
}
