# Int edge semantics pinned by spec §4.3: overflow wraps (two's complement),
# `/` truncates toward zero, `%` takes the sign of the dividend, and the
# MIN/-1 pair follows the same wrapping rule. Both backends must agree.

const MAX: Int = 9223372036854775807

fn min_int() -> Int = MAX + 1     # wraps to -9223372036854775808

pub fn main() -> Unit !io = {
  println(to_string(MAX + 1))             # wraps, no panic
  println(to_string(min_int() - 1))       # wraps back to MAX
  println(to_string(-7 / 2))              # toward zero, not floor
  println(to_string(7 / -2))
  println(to_string(-7 % 2))              # sign follows the dividend
  println(to_string(7 % -2))
  println(to_string(min_int() / -1))      # the one overflowing division: wraps
  println(to_string(min_int() % -1))
}
