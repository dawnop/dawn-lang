root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
ktlint_code_style = intellij_idea
# 140, not the usual 120: 18 lines exceed 120 and exactly one exceeds 140. The 18
# are the tabular one-line-per-case bytecode emissions in CodeGen.kt, which read
# worse broken. 140 bounds the file without touching the table.
max_line_length = 140

# ktlint is ~90% a formatter with opinions, not a bug-finder. Measured on this
# codebase: 4423 violations, of which 4366 are pure line-wrapping taste. Applying
# them (ktlintFormat) rewrites 57 of 71 files, +5272/-2134 — and it is not a
# canonical formatter the way ruff format or prettier are, so that churn buys no
# settled answer, just a different taste. It also actively hurts: it splits the
# deliberately grouped, KDoc'd declaration blocks in Checker.kt apart.
#
# So the wrapping family is off and layout stays hand-owned. What is left is the
# 57 findings a reviewer would agree with: dead/wildcard imports, naming, stray
# multi-spaces, indent, string templates.
#
# Revisit if this ever gets more than one author — taste needs an owner, and a
# machine is a fine one once "whose taste" stops having an obvious answer.
ktlint_standard_wrapping = disabled
ktlint_standard_argument-list-wrapping = disabled
ktlint_standard_statement-wrapping = disabled
ktlint_standard_parameter-list-wrapping = disabled
ktlint_standard_property-wrapping = disabled
ktlint_standard_binary-expression-wrapping = disabled
ktlint_standard_condition-wrapping = disabled
ktlint_standard_enum-wrapping = disabled
ktlint_standard_multiline-if-else = disabled
ktlint_standard_multiline-loop = disabled
ktlint_standard_class-signature = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_function-expression-body = disabled
ktlint_standard_function-literal = disabled
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled
ktlint_standard_spacing-between-declarations-with-comments = disabled
# indent and keyword-spacing belong to the same family and have to go with it.
# indent assumes ktlint owns the wrapping; with the rules above off the two fight
# and it "fixes" an aligned continuation into something neither aligned nor
# block-indented. keyword-spacing rejoins a deliberately split `else` into a
# 120-char line. Both make the code worse, measured on this codebase, not in theory.
ktlint_standard_indent = disabled
ktlint_standard_keyword-spacing = disabled

# Three more that misread this codebase rather than find anything wrong with it:
#
# property-naming wants camelCase for local vals like `val STR = "java/lang/String"`
# in CodeGen — but those ARE constants, and spelled as the JVM descriptors they
# hold. `str`/`iter`/`entry` would read worse and shadow real locals.
#
# no-multi-spaces flags deliberate column alignment (`ARROW,      // ->` in
# Token.kt, the comment tables in Formatter.kt). Same instinct as the KDoc-block
# splitting above: it sees layout it did not choose and calls it a mistake.
#
# filename assumes one top-level class per file; AstQuery.kt is a module (a class
# plus the function that is its real export) and is named for what it does.
ktlint_standard_property-naming = disabled
ktlint_standard_no-multi-spaces = disabled
ktlint_standard_filename = disabled

# All 14 wildcard imports here are the textbook cases for one: Opcodes.* is what
# the ASM docs themselves prescribe; dawn.ast.* is the AST vocabulary (69 top-level
# declarations — naming them would be 40 import lines per file, in six files);
# Type.*/TokenType.* are enum members. Expanding them is strictly worse.
ktlint_standard_no-wildcard-imports = disabled

[*.{js,ts,json,yml,yaml,html,css}]
indent_size = 2

[*.{md,dawn}]
# dawn has its own formatter (`dawn fmt`); editors should keep hands off.
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
