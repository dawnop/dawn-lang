# std/cursor — opaque positions in a String (spec §11).
#
# Short names, module-qualified at the call site: `use std/cursor`, then
# `cursor.next(s, c)`. The underlying operations are compiler intrinsics: their
# signatures use the opaque `Cursor` type, which std source cannot mint from an
# Int — that opacity is the whole point (arithmetic on a position is a type
# error). These wrappers give them their public, qualified spelling; `==` and
# the ordering operators work on `Cursor` directly (position order is a
# position's own business).

## The position before the first character.
pub fn start(s: String) -> Cursor = cursor_start(s)

## The position after the last character.
pub fn end(s: String) -> Cursor = cursor_end(s)

## Whether `c` is at the end of `s`.
pub fn done(s: String, c: Cursor) -> Bool = cursor_done(s, c)

## The code point at `c`, or -1 at the end.
pub fn char(s: String, c: Cursor) -> Int = cursor_char(s, c)

## The position one character forward (clamped to the end).
pub fn next(s: String, c: Cursor) -> Cursor = cursor_next(s, c)

## The position one character back (clamped to the start).
pub fn prev(s: String, c: Cursor) -> Cursor = cursor_prev(s, c)

## The text between two positions.
pub fn slice(s: String, from: Cursor, to: Cursor) -> String = cursor_slice(s, from, to)

## The position just past `sub`, which is known to start at `c` — the one
## sanctioned "advance past a literal" that would otherwise be cursor arithmetic.
pub fn skip(s: String, c: Cursor, sub: String) -> Cursor = cursor_skip(s, c, sub)

## The position of the first occurrence of `sub` at or after `from`, or `None`.
pub fn find(s: String, sub: String, from: Cursor) -> Option[Cursor] = index_of_from(s, sub, from)
