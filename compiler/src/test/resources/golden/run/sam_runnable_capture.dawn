# SAM conversion (spec §9.4): a capturing Dawn lambda becomes java.lang.Runnable,
# runs on another thread, and sees the captured value.
use java "java.lang.Thread"

fn spawn_hello(msg: String) -> Unit !io = {
  let t = Thread.new(fn() => println(msg))
  t.start()
  t.join()
}

pub fn main() -> Unit !io = spawn_hello("hi from a dawn callback")
