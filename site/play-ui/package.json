{
  "name": "dawn-play-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "The Playground editor bundle: CodeMirror 6 + Dawn highlighting + builtin completion. Built locally into site/assets; the server never runs node.",
  "scripts": {
    "gen-builtins": "node scripts/gen-builtins.mjs",
    "prebuild": "npm run gen-builtins",
    "predev": "npm run gen-builtins",
    "dev": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.8"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  }
}
