# spec §10.6: a top-level declaration may shadow a builtin or std name (Rust-style).
# Resolution is local decls → std → builtins, so the shadowing is total inside
# this module — the builtin spelling is unreachable here, on purpose.

fn len(s: String) -> Int = 42

fn fold(s: String) -> String = "folded!"

pub fn main() -> Unit !io = {
  println("${len("abc")}")
  println(fold("paper"))
}
