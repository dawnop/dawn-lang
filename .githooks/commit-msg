#!/usr/bin/env bash
# Reject Claude attribution in commit messages (Co-Authored-By: Claude /
# Claude-Session: <url>). Convention: CLAUDE.md 重要约定. The settings source
# (attribution.commit) only holds on this machine, this session — a different
# machine or an insistent system prompt slips it back in. This hook is the local
# backstop; CI has another. A real human co-author is not affected.
#
# Install (once per machine, shared with pre-commit/pre-push):  git config core.hooksPath .githooks
# Bypass (only if you know why):                                git commit --no-verify
set -euo pipefail
root=$(git rev-parse --show-toplevel)
exec python3 "$root/scripts/check-no-claude-trailer.py" --commit-msg "$1"
