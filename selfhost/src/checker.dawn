## An alias entry: the Kotlin AliasInfo without its mutable resolution slots
## (resolution results live in Cx.alias_resolved, the in-flight set in
## Cx.alias_resolving).
pub type AliasE = {
  name: String,
  tparams: List[Ty],
  # the unresolved target in the declaring module; None on imported aliases
  target: Option[TypeRef],
  nlo: Int,
  nhi: Int
}

## The checker state: every mutable member of the Kotlin Checker class.
pub type Cx = {
  diags: List[Diag],
  next_id: Int,
  adts: Adts,
  traits: Traits,
  # name-keyed views of the current module's scope
  fns: Map[String, Sig],
  # the bundled std's implicit surface (PRELUDE names); local decls shadow it
  std_fns: Map[String, Sig],
  adts_by_name: Map[String, Int],
  aliases: Map[String, AliasE],
  alias_resolved: Map[String, Ty],
  alias_resolving: Set[String],
  ctors_by_name: Map[String, (Int, Int)],
  traits_by_name: Map[String, Int],
  local_traits: List[String],
  local_impls: List[ImplI],
  impl_table: Map[(Int, Ty), ImplI],
  module_aliases: Map[String, String],
  # (alias, fn name) → the imported module's signature (for qualified calls)
  module_fn_sigs: Map[(String, String), Sig],
  imported_names: Map[String, String],
  # constants: declared type by name, in declaration order
  consts: Map[String, Ty],
  const_order: List[String],
  all_const_names: Set[String],
  const_cutoff: Option[Set[String]],
  # `use java` imports: simple name → fqcn
  java_classes: Map[String, String],
  # lexical scopes, innermost last; each maps name → symbol id
  scopes: List[Map[String, Int]],
  # symbol table: id → symbol
  syms: Map[Int, Sym],
  # effect bookkeeping for the body being checked
  used_effects: List[Eff],
  eff_witness: Map[Eff, (Int, Int, String)],
  current_eff_vars: Map[String, Eff],
  current_tparams: Map[String, Ty],
  current_sig: Option[Sig],
  # (tvar id, trait id) → dictionary symbol id
  dict_syms: Map[(Int, Int), Int],
  lambda_stack: List[LambdaCx],
  loop_stack: List[Int],
  in_test: Bool,
  reported_key_types: Set[String],
  is_std_module: Bool,
  owner_class: Option[String],
  src_path: Option[String],
  # UTF-16 offsets of line starts in the current source (set by the driver)
  line_starts: List[Int],
  # removed-name → where-it-went hints (populated by the std loader)
  moved: Map[String, String],
  # whole-module imports: alias → the exporter's surface (for call diagnostics)
  module_exports: Map[String, ModExports],
  # loop-stack indices that saw a break/continue (drives TSWhile/TSFor has_jumps)
  loop_jumps: Set[Int]
}

pub type LambdaCx = { boundary: Int, expected_ret: Option[Ty], captures: List[Int] }

## A fresh checker state for one module.
pub fn cx_new(owner_class: Option[String], src_path: Option[String]) -> Cx = {
  let is_std = match owner_class {
    Some(o) -> o == "std" || str.starts_with(o, "std/")
    None -> false
  }
  Cx {
    diags: [],
    # 0 and 1 are the prelude ADT ids (Option/Result); minted ids stay clear
    next_id: 2,
    adts: prelude_adts(),
    traits: prelude_traits(),
    fns: map.empty(),
    std_fns: map.empty(),
    adts_by_name: map.empty(),
    aliases: map.empty(),
    alias_resolved: map.empty(),
    alias_resolving: set.empty(),
    ctors_by_name: map.empty(),
    traits_by_name: map.empty(),
    local_traits: [],
    local_impls: [],
    impl_table: map.empty(),
    module_aliases: map.empty(),
    module_fn_sigs: map.empty(),
    imported_names: map.empty(),
    consts: map.empty(),
    const_order: [],
    all_const_names: set.empty(),
    const_cutoff: None,
    java_classes: map.empty(),
    scopes: [],
    syms: map.empty(),
    used_effects: [],
    eff_witness: map.empty(),
    current_eff_vars: map.empty(),
    current_tparams: map.empty(),
    current_sig: None,
    dict_syms: map.empty(),
    lambda_stack: [],
    loop_stack: [],
    in_test: false,
    reported_key_types: set.empty(),
    is_std_module: is_std,
    owner_class: owner_class,
    src_path: src_path,
    line_starts: [],
    moved: map.empty(),
    module_exports: map.empty(),
    loop_jumps: set.empty()
  }
}

# ---- diagnostics ----

pub fn cerr(cx: Cx, msg: String, lo: Int, hi: Int) -> Cx =
  Cx { ..cx, diags: cx.diags ++ [Diag { msg: msg, lo: lo, hi: hi, hint: "" }] }

pub fn cerr_h(cx: Cx, msg: String, lo: Int, hi: Int, hint: String) -> Cx =
  Cx { ..cx, diags: cx.diags ++ [Diag { msg: msg, lo: lo, hi: hi, hint: hint }] }

## An error with an optional hint (the Kotlin `sink.error(msg, span, hint?)`).
pub fn cerr_o(cx: Cx, msg: String, lo: Int, hi: Int, hint: Option[String]) -> Cx =
  match hint {
    Some(h) -> cerr_h(cx, msg, lo, hi, h)
    None -> cerr(cx, msg, lo, hi)
  }

# ---- fresh ids ----

pub fn fresh(cx: Cx) -> (Cx, Int) = (Cx { ..cx, next_id: cx.next_id + 1 }, cx.next_id)

pub fn fresh_tvar(cx: Cx, name: String) -> (Cx, Ty) = {
  let (cx1, id) = fresh(cx)
  (cx1, TyVar(name, id))
}

pub fn fresh_effvar(cx: Cx, name: String) -> (Cx, Eff) = {
  let (cx1, id) = fresh(cx)
  (cx1, EffVar(name, id))
}

# ---- scopes and symbols ----

pub fn push_scope(cx: Cx) -> Cx = {
  let empty: Map[String, Int] = map.empty()
  Cx { ..cx, scopes: cx.scopes ++ [empty] }
}

pub fn pop_scope(cx: Cx) -> Cx = Cx { ..cx, scopes: list.take(cx.scopes, len(cx.scopes) - 1) }

pub fn sym_of(cx: Cx, id: Int) -> Sym =
  match map.get(cx.syms, id) {
    Some(s) -> s
    None -> panic("unknown symbol id: ${id}")
  }

## Declare a name in the innermost scope (the Kotlin `declare`): re-binding in
## the same scope is an error; `_` never binds.
pub fn declare(cx: Cx, name: String, ty: Ty, mutable: Bool, lo: Int, hi: Int) -> (Cx, Int) = {
  var cx1 = cx
  let inner = cx1.scopes[len(cx1.scopes) - 1]
  if name != "_" && map.has(inner, name) {
    cx1 = cerr_h(cx1, "`" ++ name ++ "` is already bound in this scope", lo, hi,
      "let does not shadow; only nested blocks may reuse a name")
  }
  cx1 = alias_shadow(cx1, name, lo, hi)
  let (cx2, id) = fresh(cx1)
  let sym = Sym { name: name, ty: ty, mutable: mutable, dlo: lo, dhi: hi, dict_of: None }
  var cx3 = Cx { ..cx2, syms: map.insert(cx2.syms, id, sym) }
  if name != "_" {
    let inner2 = map.insert(cx3.scopes[len(cx3.scopes) - 1], name, id)
    cx3 = Cx { ..cx3, scopes: list.take(cx3.scopes, len(cx3.scopes) - 1) ++ [inner2] }
  }
  (cx3, id)
}

## Find a name in the scope stack, innermost first (no capture bookkeeping).
pub fn lookup(cx: Cx, name: String) -> Option[Int] = {
  var i = len(cx.scopes) - 1
  while i >= 0 {
    match map.get(cx.scopes[i], name) {
      Some(id) -> return Some(id)
      None -> ()
    }
    i = i - 1
  }
  None
}

## Every name currently in scope — the "did you mean" candidate pool.
pub fn local_names(cx: Cx) -> List[String] = {
  var out: List[String] = []
  for sc in cx.scopes { out = out ++ map.keys(sc) }
  out
}

## A local declaration may not shadow a whole-module alias (spec §10.3).
pub fn alias_shadow(cx: Cx, name: String, lo: Int, hi: Int) -> Cx =
  match map.get(cx.module_aliases, name) {
    None -> cx
    Some(mod_path) -> cerr_h(cx, "`" ++ name ++ "` shadows the imported module `" ++ mod_path ++ "`",
      lo, hi, "an imported module's alias and your names share one namespace; rename one")
  }

## Was a top-level name already shadowing an alias / clashing with an import?
pub fn alias_shadows(cx: Cx, name: String) -> Bool = map.has(cx.module_aliases, name)

pub fn import_clash(cx: Cx, name: String, lo: Int, hi: Int, kind: String) -> Cx =
  match map.get(cx.imported_names, name) {
    None -> cx
    Some(from) -> cerr_h(cx, kind ++ " `" ++ name ++ "` conflicts with a name imported from `" ++
        from ++ "`", lo, hi, "drop the import or rename this " ++ kind)
  }

pub fn import_clashes(cx: Cx, name: String) -> Bool = map.has(cx.imported_names, name)

# ---- effect bookkeeping ----

fn eff_seen(cx: Cx, e: Eff) -> Bool = {
  for u in cx.used_effects {
    if u == e { return true }
  }
  false
}

pub fn record_effect(cx: Cx, e: Eff, lo: Int, hi: Int, name: String) -> Cx = {
  if e == EPure { return cx }
  if eff_seen(cx, e) { return cx }
  Cx {
    ..cx,
    used_effects: cx.used_effects ++ [e],
    eff_witness: map.insert(cx.eff_witness, e, (lo, hi, name))
  }
}

## Resolve parsed effect atoms into a normalized Eff, interning variables per
## signature (the Kotlin resolveEff over currentEffVars).
pub fn resolve_eff(cx: Cx, atoms: List[String]) -> (Cx, Eff) = {
  var cx1 = cx
  var effs: List[Eff] = []
  for a in atoms {
    if a == "io" {
      effs = effs ++ [EIo]
    } else {
      match map.get(cx1.current_eff_vars, a) {
        Some(v) -> { effs = effs ++ [v] }
        None -> {
          let (cx2, v) = fresh_effvar(cx1, a)
          cx1 = Cx { ..cx2, current_eff_vars: map.insert(cx2.current_eff_vars, a, v) }
          effs = effs ++ [v]
        }
      }
    }
  }
  (cx1, eff_union(effs))
}

# ---- Map/Set key validity (spec §2.2) ----

## The first Float/Bytes anywhere inside a would-be key type, or None.
pub fn invalid_key_part(cx: Cx, t: Ty, seen: Set[String]) -> Option[Ty] =
  match t {
    TyFloat -> Some(TyFloat)
    TyBytes -> Some(TyBytes)
    TyList(e) -> invalid_key_part(cx, e, seen)
    TySet(e) -> invalid_key_part(cx, e, seen)
    TyMap(k, v) ->
      match invalid_key_part(cx, k, seen) {
        Some(b) -> Some(b)
        None -> invalid_key_part(cx, v, seen)
      }
    TyTuple(elems) -> {
      for e in elems {
        match invalid_key_part(cx, e, seen) {
          Some(b) -> return Some(b)
          None -> ()
        }
      }
      None
    }
    TyAdt(aid, targs) -> {
      let a = adt_of(cx.adts, aid)
      if set.has(seen, a.name) { return None }
      let seen2 = set.insert(seen, a.name)
      var m: Map[Int, Ty] = map.empty()
      var i = 0
      for tp in a.tparams {
        match tp {
          TyVar(_, id) ->
            match get(targs, i) {
              Some(arg) -> { m = map.insert(m, id, arg) }
              None -> ()
            }
          _ -> ()
        }
        i = i + 1
      }
      let em: Map[Int, Eff] = map.empty()
      for c in a.ctors {
        for f in c.fields {
          match invalid_key_part(cx, subst(f.ty, m, em), seen2) {
            Some(b) -> return Some(b)
            None -> ()
          }
        }
      }
      None
    }
    _ -> None
  }

## One report per offending key type per module.
pub fn check_key_type(cx: Cx, key_t: Ty, lo: Int, hi: Int) -> Cx = {
  if is_errorish(key_t) { return cx }
  let bad = match invalid_key_part(cx, key_t, set.empty()) {
    None -> return cx
    Some(b) -> b
  }
  let key_s = ty_show(cx.adts, key_t)
  if set.has(cx.reported_key_types, key_s) { return cx }
  var cx1 = Cx { ..cx, reported_key_types: set.insert(cx.reported_key_types, key_s) }
  let bad_s = ty_show(cx1.adts, bad)
  let inside = if bad == key_t { "" } else { " (inside `" ++ key_s ++ "`)" }
  let why = if bad == TyFloat {
    "NaN and -0.0 give Float two different equalities, so no hash can agree with `==`"
  } else {
    "Bytes hashes by identity, not content"
  }
  let hint = if bad == TyFloat {
    "key by an Int encoding (scaled integer, bits) or a String rendering instead"
  } else {
    "key by a String instead: decode(b, \"UTF-8\") or a hex rendering"
  }
  cerr_h(cx1, "`" ++ bad_s ++ "` cannot be part of a Map/Set key type" ++ inside ++ ": " ++ why,
    lo, hi, hint)
}

## Every Map key / Set element inside an instantiated type must be a valid key.
pub fn check_key_types_in(cx: Cx, t: Ty, lo: Int, hi: Int) -> Cx =
  match t {
    TyMap(k, v) -> check_key_types_in(check_key_type(cx, k, lo, hi), v, lo, hi)
    TySet(e) -> check_key_type(cx, e, lo, hi)
    TyList(e) -> check_key_types_in(cx, e, lo, hi)
    TyTuple(elems) -> {
      var cx1 = cx
      for e in elems { cx1 = check_key_types_in(cx1, e, lo, hi) }
      cx1
    }
    TyAdt(_, targs) -> {
      var cx1 = cx
      for e in targs { cx1 = check_key_types_in(cx1, e, lo, hi) }
      cx1
    }
    TyFn(params, ret, _) -> {
      var cx1 = cx
      for e in params { cx1 = check_key_types_in(cx1, e, lo, hi) }
      check_key_types_in(cx1, ret, lo, hi)
    }
    _ -> cx
  }

pub fn builtin_type_names() -> List[String] =
  ["Int", "Float", "Bool", "String", "Bytes", "Cursor", "Unit", "List", "Map", "Set"]

# ---- type resolution ----

## The span of the first effect variable inside an alias target, if any.
pub fn alias_effvar_span(ref: TypeRef) -> Option[(Int, Int)] =
  match ref {
    TFn(params, ret, effs, lo, hi) -> {
      for a in effs {
        if a != "io" { return Some((lo, hi)) }
      }
      for p in params {
        match alias_effvar_span(p) {
          Some(s) -> return Some(s)
          None -> ()
        }
      }
      alias_effvar_span(ret)
    }
    TTuple(elems, _, _) -> {
      for e in elems {
        match alias_effvar_span(e) {
          Some(s) -> return Some(s)
          None -> ()
        }
      }
      None
    }
    TNamed(_, targs, _, _) -> {
      for e in targs {
        match alias_effvar_span(e) {
          Some(s) -> return Some(s)
          None -> ()
        }
      }
      None
    }
  }

## Resolve an alias target once, memoized; TyError (and an error) on a cycle.
fn resolve_alias_target(cx: Cx, al: AliasE, use_lo: Int, use_hi: Int) -> (Cx, Ty) = {
  match map.get(cx.alias_resolved, al.name) {
    Some(t) -> return (cx, t)
    None -> ()
  }
  let ref = match al.target {
    None -> {
      let cx1 = Cx { ..cx, alias_resolved: map.insert(cx.alias_resolved, al.name, TyError) }
      return (cx1, TyError)
    }
    Some(r) -> r
  }
  if set.has(cx.alias_resolving, al.name) {
    var cx1 = cerr_h(cx, "type alias `" ++ al.name ++ "` refers to itself", use_lo, use_hi,
      "aliases are transparent and cannot be recursive")
    cx1 = Cx { ..cx1, alias_resolved: map.insert(cx1.alias_resolved, al.name, TyError) }
    return (cx1, TyError)
  }
  var tp: Map[String, Ty] = map.empty()
  for v in al.tparams {
    match v {
      TyVar(n, _) -> { tp = map.insert(tp, n, v) }
      _ -> ()
    }
  }
  var cx1 = Cx { ..cx, alias_resolving: set.insert(cx.alias_resolving, al.name) }
  # the alias target resolves with its own type parameters and a throwaway
  # effect-variable table (effect variables are rejected at declaration)
  let saved_tp = cx1.current_tparams
  let saved_ev = cx1.current_eff_vars
  let empty_ev: Map[String, Eff] = map.empty()
  cx1 = Cx { ..cx1, current_tparams: tp, current_eff_vars: empty_ev }
  let (cx2, t) = resolve_type(cx1, ref)
  var cx3 = Cx { ..cx2, current_tparams: saved_tp, current_eff_vars: saved_ev }
  cx3 = Cx {
    ..cx3,
    alias_resolving: set.remove(cx3.alias_resolving, al.name),
    alias_resolved: map.insert(cx3.alias_resolved, al.name, t)
  }
  (cx3, t)
}

## Resolve a parsed type reference against the current scope (the Kotlin
## resolveType with tparams/effVars defaulted to the current ones).
pub fn resolve_type(cx: Cx, ref: TypeRef) -> (Cx, Ty) =
  match ref {
    TTuple(elems, lo, hi) -> {
      var cx1 = cx
      var out: List[Ty] = []
      var i = 0
      for e in elems {
        let (cx2, t) = resolve_type(cx1, e)
        cx1 = cx2
        if t == TyUnit {
          cx1 = cerr(cx1, "tuple elements cannot be Unit", t_lo2(e), t_hi2(e))
          out = out ++ [TyError]
        } else {
          out = out ++ [t]
        }
        i = i + 1
      }
      (cx1, TyTuple(out))
    }
    TFn(params, ret, effs, lo, hi) -> {
      let (cx1, eff) = resolve_eff(cx, effs)
      var cx2 = cx1
      var ps: List[Ty] = []
      for p in params {
        let (cx3, t) = resolve_type(cx2, p)
        cx2 = cx3
        ps = ps ++ [t]
      }
      let (cx4, rt) = resolve_type(cx2, ret)
      (cx4, TyFn(ps, rt, eff))
    }
    TNamed(name, targs, lo, hi) -> resolve_named(cx, name, targs, lo, hi)
  }

fn t_lo2(t: TypeRef) -> Int =
  match t {
    TNamed(_, _, lo, _) -> lo
    TTuple(_, lo, _) -> lo
    TFn(_, _, _, lo, _) -> lo
  }

fn t_hi2(t: TypeRef) -> Int =
  match t {
    TNamed(_, _, _, hi) -> hi
    TTuple(_, _, hi) -> hi
    TFn(_, _, _, _, hi) -> hi
  }

fn resolve_named(cx: Cx, name: String, targs: List[TypeRef], lo: Int, hi: Int) -> (Cx, Ty) = {
  # type parameters shadow everything
  match map.get(cx.current_tparams, name) {
    Some(v) -> {
      if len(targs) > 0 {
        return (cerr(cx, "type parameter `" ++ name ++ "` cannot take type arguments", lo, hi),
          TyError)
      }
      return (cx, v)
    }
    None -> ()
  }
  match map.get(cx.aliases, name) {
    Some(al) -> {
      if len(targs) != len(al.tparams) {
        return (cerr(cx, "`" ++ al.name ++ "` takes " ++ to_string(len(al.tparams)) ++
            " type parameter(s), got " ++ to_string(len(targs)), lo, hi), TyError)
      }
      let (cx1, target) = resolve_alias_target(cx, al, lo, hi)
      if target == TyError { return (cx1, TyError) }
      if len(al.tparams) == 0 { return (cx1, target) }
      var cx2 = cx1
      var m: Map[Int, Ty] = map.empty()
      var i = 0
      for v in al.tparams {
        match v {
          TyVar(_, id) -> {
            let (cx3, at) = resolve_type(cx2, targs[i])
            cx2 = cx3
            m = map.insert(m, id, at)
          }
          _ -> ()
        }
        i = i + 1
      }
      let em: Map[Int, Eff] = map.empty()
      return (cx2, subst(target, m, em))
    }
    None -> ()
  }
  if name == "List" {
    if len(targs) != 1 {
      return (cerr(cx, "List takes exactly one type argument: List[T]", lo, hi), TyError)
    }
    let (cx1, e) = resolve_type(cx, targs[0])
    return (cx1, TyList(e))
  }
  if name == "Map" {
    if len(targs) != 2 {
      return (cerr(cx, "Map takes exactly two type arguments: Map[K, V]", lo, hi), TyError)
    }
    let (cx1, k) = resolve_type(cx, targs[0])
    let cx2 = check_key_type(cx1, k, t_lo2(targs[0]), t_hi2(targs[0]))
    let (cx3, v) = resolve_type(cx2, targs[1])
    return (cx3, TyMap(k, v))
  }
  if name == "Set" {
    if len(targs) != 1 {
      return (cerr(cx, "Set takes exactly one type argument: Set[T]", lo, hi), TyError)
    }
    let (cx1, e) = resolve_type(cx, targs[0])
    let cx2 = check_key_type(cx1, e, t_lo2(targs[0]), t_hi2(targs[0]))
    return (cx2, TySet(e))
  }
  match ty_named(name) {
    Some(t) -> {
      if len(targs) > 0 {
        return (cerr(cx, "`" ++ name ++ "` is not generic", lo, hi), TyError)
      }
      return (cx, t)
    }
    None -> ()
  }
  match map.get(cx.java_classes, name) {
    Some(fqcn) -> {
      if len(targs) > 0 {
        return (cerr(cx, "Java types take no type arguments (generics are erased)", lo, hi),
          TyError)
      }
      let j = unsafe_pure { class_info(fqcn) }
      return (cx, TyJava(fqcn, j.display))
    }
    None -> ()
  }
  match map.get(cx.adts_by_name, name) {
    None -> {
      let pool = map.keys(cx.adts_by_name) ++ map.keys(cx.aliases) ++
        map.keys(cx.java_classes) ++ builtin_type_names()
      let hint = match suggest.hint(name, pool) {
        Some(h) -> h
        None -> "builtin types: Int, Float, Bool, String, Unit, List — or declare `type " ++
          name ++ " = ...`"
      }
      (cerr_h(cx, "unknown type: " ++ name, lo, hi, hint), TyError)
    }
    Some(aid) -> {
      let info = adt_of(cx.adts, aid)
      if len(targs) != len(info.tparams) {
        return (cerr(cx, "`" ++ info.name ++ "` takes " ++ to_string(len(info.tparams)) ++
            " type parameter(s), got " ++ to_string(len(targs)), lo, hi), TyError)
      }
      var cx1 = cx
      var args: List[Ty] = []
      for a in targs {
        let (cx2, t) = resolve_type(cx1, a)
        cx1 = cx2
        args = args ++ [t]
      }
      (cx1, TyAdt(aid, args))
    }
  }
}

# ---- tests ----

fn test_cx() -> Cx = cx_new(None, None)

test "scalar and container types resolve" {
  let cx = test_cx()
  let (cx1, t) = resolve_type(cx, TNamed("Int", [], 0, 3))
  assert t == TyInt
  let (cx2, t2) = resolve_type(cx1,
    TNamed("Map", [TNamed("Int", [], 4, 7), TNamed("String", [], 9, 15)], 0, 16))
  assert t2 == TyMap(TyInt, TyString)
  assert len(cx2.diags) == 0
}

test "a float map key is rejected once per type" {
  let cx = test_cx()
  let (cx1, t) = resolve_type(cx,
    TNamed("Map", [TNamed("Float", [], 4, 9), TNamed("Int", [], 11, 14)], 0, 15))
  assert t == TyMap(TyFloat, TyInt)
  assert len(cx1.diags) == 1
  assert str.contains(cx1.diags[0].msg, "cannot be part of a Map/Set key type")
  # the same offending key type reports only once
  let (cx2, _) = resolve_type(cx1,
    TNamed("Map", [TNamed("Float", [], 24, 29), TNamed("Int", [], 31, 34)], 20, 35))
  assert len(cx2.diags) == 1
}

test "unknown types get suggestions" {
  let cx = test_cx()
  let (cx1, t) = resolve_type(cx, TNamed("Strin", [], 0, 5))
  assert t == TyError
  assert cx1.diags[0].msg == "unknown type: Strin"
  assert cx1.diags[0].hint == "did you mean `String`?"
}

test "effects intern per signature" {
  let cx = test_cx()
  let (cx1, e1) = resolve_eff(cx, ["e"])
  let (cx2, e2) = resolve_eff(cx1, ["e"])
  assert e1 == e2
  let (cx3, e3) = resolve_eff(cx2, ["io"])
  assert e3 == EIo
  let (cx4, e4) = resolve_eff(cx3, ["e", "f"])
  assert eff_suffix(e4) == " !(e|f)"
}

test "declare and lookup with scope discipline" {
  var cx = push_scope(test_cx())
  let (cx1, id) = declare(cx, "x", TyInt, false, 0, 1)
  assert lookup(cx1, "x") == Some(id)
  assert sym_of(cx1, id).ty == TyInt
  # re-binding in the same scope errors
  let (cx2, id2) = declare(cx1, "x", TyBool, false, 2, 3)
  assert len(cx2.diags) == 1
  # a nested block may reuse the name
  var cx3 = push_scope(cx2)
  let (cx4, id3) = declare(cx3, "x", TyString, false, 4, 5)
  assert len(cx4.diags) == 1
  assert sym_of(cx4, lookup(cx4, "x").expect("bound")).ty == TyString
  let cx5 = pop_scope(cx4)
  # the erroring re-declaration still overwrote the outer binding (Kotlin does too)
  assert sym_of(cx5, lookup(cx5, "x").expect("bound")).ty == TyBool
}

# ---- assignability, unification, printability ----

## Can `t` be used where `target` is expected? (Never/TyError as anything;
## a pure fn where an io fn is wanted.)
pub fn assignable(cx: Cx, t: Ty, target: Ty) -> Bool = {
  if t == target || is_errorish(t) || target == TyError { return true }
  match t {
    TyFn(ps, r, e) ->
      match target {
        TyFn(tps, tr, te) ->
          ps == tps && assignable(cx, r, tr) && (te == EIo || e == EPure || e == te)
        _ -> false
      }
    _ -> false
  }
}

## Unify branch types (Never and TyError are absorbed); errors mention `what`.
pub fn unify_branches(cx: Cx, a: Ty, b: Ty, lo: Int, hi: Int, what: String) -> (Cx, Ty) = {
  if a == TyNever || a == TyError { return (cx, b) }
  if b == TyNever || b == TyError { return (cx, a) }
  if a == b { return (cx, a) }
  (cerr(cx, what ++ " have mismatched types: " ++ ty_show(cx.adts, a) ++ " vs " ++
      ty_show(cx.adts, b), lo, hi), TyError)
}

## Structural unification of a declared type against an actual argument type,
## accumulating bindings (var id → type / effect). Returns the updated maps and
## whether the shapes agreed.
pub fn unify_into(
  cx: Cx,
  declared: Ty,
  actual: Ty,
  m: Map[Int, Ty],
  em: Map[Int, Eff]
) -> (Map[Int, Ty], Map[Int, Eff], Bool) = {
  if is_errorish(actual) { return (m, em, true) }
  match declared {
    TyVar(_, id) ->
      match map.get(m, id) {
        None -> (map.insert(m, id, actual), em, true)
        Some(bound) -> (m, em, bound == actual)
      }
    TyAdt(aid, dargs) ->
      match actual {
        TyAdt(aid2, aargs) -> {
          if aid != aid2 { return (m, em, false) }
          var m1 = m
          var em1 = em
          var ok = true
          var i = 0
          for d in dargs {
            match get(aargs, i) {
              Some(a) -> {
                let (m2, em2, ok2) = unify_into(cx, d, a, m1, em1)
                m1 = m2
                em1 = em2
                if not ok2 { ok = false }
              }
              None -> { ok = false }
            }
            i = i + 1
          }
          (m1, em1, ok)
        }
        _ -> (m, em, false)
      }
    TyList(d) ->
      match actual {
        TyList(a) -> unify_into(cx, d, a, m, em)
        _ -> (m, em, false)
      }
    TyMap(dk, dv) ->
      match actual {
        TyMap(ak, av) -> {
          let (m1, em1, ok1) = unify_into(cx, dk, ak, m, em)
          let (m2, em2, ok2) = unify_into(cx, dv, av, m1, em1)
          (m2, em2, ok1 && ok2)
        }
        _ -> (m, em, false)
      }
    TySet(d) ->
      match actual {
        TySet(a) -> unify_into(cx, d, a, m, em)
        _ -> (m, em, false)
      }
    TyTuple(delems) ->
      match actual {
        TyTuple(aelems) -> {
          if len(delems) != len(aelems) { return (m, em, false) }
          var m1 = m
          var em1 = em
          var ok = true
          var i = 0
          for d in delems {
            let (m2, em2, ok2) = unify_into(cx, d, aelems[i], m1, em1)
            m1 = m2
            em1 = em2
            if not ok2 { ok = false }
            i = i + 1
          }
          (m1, em1, ok)
        }
        _ -> (m, em, false)
      }
    TyFn(dps, dr, de) ->
      match actual {
        TyFn(aps, ar, ae) -> {
          if len(dps) != len(aps) { return (m, em, false) }
          var m1 = m
          var em1 = em
          var ok = true
          var i = 0
          for d in dps {
            let (m2, em2, ok2) = unify_into(cx, d, aps[i], m1, em1)
            m1 = m2
            em1 = em2
            if not ok2 { ok = false }
            i = i + 1
          }
          let (m3, em3, ok3) = unify_into(cx, dr, ar, m1, em1)
          let (em4, ok4) = unify_eff(de, ae, em3)
          (m3, em4, ok && ok3 && ok4)
        }
        _ -> (m, em, false)
      }
    _ -> (m, em, declared == actual)
  }
}

## Effect side of unification: pure ⊑ io; declared variables accumulate a lub.
pub fn unify_eff(declared: Eff, actual: Eff, em: Map[Int, Eff]) -> (Map[Int, Eff], Bool) =
  match declared {
    EPure -> (em, actual == EPure)
    EIo -> (em, true)
    EffVar(_, id) -> {
      let prev = match map.get(em, id) {
        Some(p) -> p
        None -> EPure
      }
      (map.insert(em, id, lub_eff(prev, actual)), true)
    }
    # a union in a declared parameter position is not inferred into; accept when
    # the actual is already subsumed
    EUnion(_) -> (em, eff_subsumes(subst_eff(declared, em), actual))
  }

## A rigid type parameter of the enclosing declaration is a known type; only a
## callee's still-unbound inference variables are not.
pub fn is_concrete(cx: Cx, t: Ty) -> Bool =
  match t {
    TyVar(_, id) -> {
      for v in map.values(cx.current_tparams) {
        match v {
          TyVar(_, id2) -> if id2 == id { return true }
          _ -> ()
        }
      }
      false
    }
    TyAdt(_, targs) -> {
      for a in targs {
        if not is_concrete(cx, a) { return false }
      }
      true
    }
    TyList(e) -> is_concrete(cx, e)
    TyMap(k, v) -> is_concrete(cx, k) && is_concrete(cx, v)
    TySet(e) -> is_concrete(cx, e)
    TyTuple(elems) -> {
      for a in elems {
        if not is_concrete(cx, a) { return false }
      }
      true
    }
    _ -> true
  }

## Does the type contain a function anywhere? (functions cannot be compared)
pub fn contains_fn(t: Ty) -> Bool =
  match t {
    TyFn(_, _, _) -> true
    TyTuple(elems) -> {
      for e in elems {
        if contains_fn(e) { return true }
      }
      false
    }
    TyList(e) -> contains_fn(e)
    TyMap(k, v) -> contains_fn(k) || contains_fn(v)
    TySet(e) -> contains_fn(e)
    _ -> false
  }

## A concrete type is printable now: primitives, containers/ADTs of printable types.
pub fn is_showable(cx: Cx, t: Ty) -> Bool =
  match t {
    TyInt | TyFloat | TyBool | TyString | TyBytes -> true
    TyList(e) -> is_showable(cx, e)
    TyMap(k, v) -> is_showable(cx, k) && is_showable(cx, v)
    TySet(e) -> is_showable(cx, e)
    TyTuple(elems) -> {
      for e in elems {
        if not is_showable(cx, e) { return false }
      }
      true
    }
    TyAdt(aid, targs) -> {
      if not adt_of(cx.adts, aid).derives_show { return false }
      for a in targs {
        if not is_showable(cx, a) { return false }
      }
      true
    }
    _ -> false
  }

## A field type may derive Show: like is_showable but type parameters pass.
pub fn is_showable_field(cx: Cx, t: Ty) -> Bool =
  match t {
    TyInt | TyFloat | TyBool | TyString | TyBytes | TyVar(_, _) -> true
    TyList(e) -> is_showable_field(cx, e)
    TyMap(k, v) -> is_showable_field(cx, k) && is_showable_field(cx, v)
    TySet(e) -> is_showable_field(cx, e)
    TyTuple(elems) -> {
      for e in elems {
        if not is_showable_field(cx, e) { return false }
      }
      true
    }
    TyAdt(aid, targs) -> {
      if not adt_of(cx.adts, aid).derives_show { return false }
      for a in targs {
        if not is_showable_field(cx, a) { return false }
      }
      true
    }
    _ -> false
  }

## A targeted hint for why `t` is not printable.
pub fn show_hint(cx: Cx, t: Ty) -> String =
  match t {
    TyAdt(aid, _) -> {
      let a = adt_of(cx.adts, aid)
      if not a.derives_show {
        "add `derive Show` to `type " ++ a.name ++ "`"
      } else {
        "one of its type arguments is not printable"
      }
    }
    TyVar(_, _) -> "a type parameter is not printable; require a concrete printable type"
    TyFn(_, _, _) -> "functions cannot be printed"
    _ -> "printable types are Int, Float, Bool, String, and `derive Show` values"
  }

## Int/Float/Bool/String and List/tuple/record/ADT built from them (spec §7.2).
pub fn is_const_serializable(cx: Cx, t: Ty, visited: Set[Int]) -> Bool =
  match t {
    TyInt | TyFloat | TyBool | TyString -> true
    TyList(e) -> is_const_serializable(cx, e, visited)
    TyTuple(elems) -> {
      for e in elems {
        if not is_const_serializable(cx, e, visited) { return false }
      }
      true
    }
    TyAdt(aid, targs) -> {
      # recursive types terminate here
      if set.has(visited, aid) { return true }
      let v2 = set.insert(visited, aid)
      let a = adt_of(cx.adts, aid)
      var m: Map[Int, Ty] = map.empty()
      var i = 0
      for tp in a.tparams {
        match tp {
          TyVar(_, id) ->
            match get(targs, i) {
              Some(arg) -> { m = map.insert(m, id, arg) }
              None -> ()
            }
          _ -> ()
        }
        i = i + 1
      }
      for a2 in targs {
        if not is_const_serializable(cx, a2, v2) { return false }
      }
      let em: Map[Int, Eff] = map.empty()
      for c in a.ctors {
        for f in c.fields {
          if not is_const_serializable(cx, subst(f.ty, m, em), v2) { return false }
        }
      }
      true
    }
    _ -> false
  }

# ---- tests (slice 2) ----

test "assignability admits pure where io is wanted" {
  let cx = test_cx()
  assert assignable(cx, TyFn([TyInt], TyInt, EPure), TyFn([TyInt], TyInt, EIo))
  assert not assignable(cx, TyFn([TyInt], TyInt, EIo), TyFn([TyInt], TyInt, EPure))
  assert assignable(cx, TyNever, TyInt)
  assert not assignable(cx, TyInt, TyBool)
}

test "unification binds and checks variables" {
  let cx = test_cx()
  let t = TyVar("T", 100)
  let m0: Map[Int, Ty] = map.empty()
  let em0: Map[Int, Eff] = map.empty()
  let (m1, em1, ok1) = unify_into(cx, TyList(t), TyList(TyInt), m0, em0)
  assert ok1
  assert map.get(m1, 100) == Some(TyInt)
  # a second, conflicting binding fails
  let (m2, em2, ok2) = unify_into(cx, t, TyBool, m1, em1)
  assert not ok2
  # effect variables accumulate a lub
  let e = EffVar("e", 101)
  let (m3, em3, ok3) = unify_into(cx, TyFn([t], TyUnit, e), TyFn([TyInt], TyUnit, EIo), m1, em1)
  assert ok3
  assert map.get(em3, 101) == Some(EIo)
}

test "printability and const-serializability" {
  let cx = test_cx()
  assert is_showable(cx, TyList(TyInt))
  assert is_showable(cx, opt_ty(TyString))
  assert not is_showable(cx, TyFn([], TyUnit, EPure))
  assert not is_showable(cx, TyUnit)
  assert is_const_serializable(cx, opt_ty(TyTuple([TyInt, TyString])), set.empty())
  assert not is_const_serializable(cx, TyMap(TyInt, TyInt), set.empty())
  assert not is_const_serializable(cx, TyVar("T", 5), set.empty())
  assert show_hint(cx, TyFn([], TyUnit, EPure)) == "functions cannot be printed"
}

# ---- declaration passes ----

## Pass 0 (the top of the Kotlin check()): prelude ADTs with their constructors,
## prelude traits with their methods in the fn namespace, prelude Ord impls.
pub fn seed_prelude(cx: Cx) -> Cx = {
  var cx1 = cx
  # Option/Result and their constructors
  var abn = cx1.adts_by_name
  var cbn = cx1.ctors_by_name
  for aid in [OPTION_ID, RESULT_ID] {
    let a = adt_of(cx1.adts, aid)
    abn = map.insert(abn, a.name, aid)
    var i = 0
    for c in a.ctors {
      cbn = map.insert(cbn, c.name, (aid, i))
      i = i + 1
    }
  }
  # prelude traits: methods enter the fn namespace
  var tbn = cx1.traits_by_name
  var fns2 = cx1.fns
  let ord = trait_of(cx1.traits, ORD_ID)
  tbn = map.insert(tbn, ord.name, ORD_ID)
  for entry in ord.methods {
    let (mname, ms) = entry
    fns2 = map.insert(fns2, mname, ms.sig)
  }
  # prelude Ord impls over the native scalars
  var it = cx1.impl_table
  for i in prelude_impls() { it = map.insert(it, (i.trait_id, i.subject), i) }
  Cx {
    ..cx1,
    adts_by_name: abn,
    ctors_by_name: cbn,
    traits_by_name: tbn,
    fns: fns2,
    impl_table: it
  }
}

## Pass 0.5: `use java` imports, resolved by reflection (spec §9).
pub fn pass_java_uses(cx: Cx, m: Module) -> Cx !io = {
  var cx1 = cx
  for d in module_java_uses(m) {
    match find_class(d.fqcn) {
      None -> {
        cx1 = cerr_h(cx1, "Java class not found: " ++ d.fqcn, d.nlo, d.nhi,
          "the JDK is always visible; third-party jars must be passed with --cp <jars>")
      }
      Some(j) -> {
        if map.has(cx1.java_classes, d.simple) {
          cx1 = cerr(cx1, "`" ++ d.simple ++ "` is already imported", d.nlo, d.nhi)
        } else {
          cx1 = Cx { ..cx1, java_classes: map.insert(cx1.java_classes, d.simple, j.fqcn) }
        }
      }
    }
  }
  cx1
}

test "prelude seeding wires names to ids" {
  let cx = seed_prelude(test_cx())
  assert map.get(cx.adts_by_name, "Option") == Some(OPTION_ID)
  assert map.get(cx.ctors_by_name, "Ok") == Some((RESULT_ID, 0))
  assert map.get(cx.ctors_by_name, "None") == Some((OPTION_ID, 1))
  assert map.get(cx.traits_by_name, "Ord") == Some(ORD_ID)
  assert map.has(cx.fns, "cmp")
  assert map.has(cx.impl_table, (ORD_ID, TyInt))
  assert not map.has(cx.impl_table, (ORD_ID, TyBool))
}

## What pass 1 learned about one `type` declaration, for pass 2 to finish.
## `accepted` maps parsed-ctor index → ctor slot in the ADT; `first_ok`
## reproduces the Kotlin quirk that pass 2's tparam scope comes from the
## FIRST parsed constructor's acceptance.
pub type Shell = { adt: Int, accepted: List[(Int, Int)], first_ok: Bool }

fn no_shell() -> Option[Shell] = None

fn no_fields() -> List[FieldDecl] = []

fn no_params() -> List[Param] = []

fn no_tparams() -> List[TypeParamDecl] = []

fn no_effs() -> List[String] = []

fn no_fn_decls() -> List[FnDecl] = []

fn no_params2() -> List[Param] = no_params()

fn no_body() -> Option[Expr] = None

fn dup_names(names: List[String]) -> Bool = {
  var seen: Set[String] = set.empty()
  for n in names {
    if set.has(seen, n) { return true }
    seen = set.insert(seen, n)
  }
  false
}

## Pass 1: type headers (shells only), so recursive types resolve. Returns one
## Option[Shell] per module type declaration, aligned by index.
pub fn pass_type_shells(cx: Cx, m: Module) -> (Cx, List[Option[Shell]]) = {
  var cx1 = cx
  var shells: List[Option[Shell]] = []
  for d in module_types(m) {
    if map.has(cx1.java_classes, d.name) {
      cx1 = cerr(cx1, "`" ++ d.name ++ "` collides with an imported Java class", d.nlo, d.nhi)
      shells = shells ++ [no_shell()]
      continue
    }
    if alias_shadows(cx1, d.name) {
      cx1 = alias_shadow(cx1, d.name, d.nlo, d.nhi)
      shells = shells ++ [no_shell()]
      continue
    }
    if import_clashes(cx1, d.name) {
      cx1 = import_clash(cx1, d.name, d.nlo, d.nhi, "type")
      shells = shells ++ [no_shell()]
      continue
    }
    let is_builtin_name = match ty_named(d.name) {
      Some(_) -> true
      None -> d.name == "List" || d.name == "Map" || d.name == "Set"
    }
    if is_builtin_name {
      cx1 = cerr(cx1, "`" ++ d.name ++ "` is a builtin type and cannot be redefined", d.nlo, d.nhi)
      shells = shells ++ [no_shell()]
      continue
    }
    if map.has(cx1.adts_by_name, d.name) || map.has(cx1.aliases, d.name) {
      let msg = if d.name == "Option" || d.name == "Result" {
        "`" ++ d.name ++ "` is a prelude type and cannot be redefined"
      } else {
        "type `" ++ d.name ++ "` is defined twice"
      }
      cx1 = cerr(cx1, msg, d.nlo, d.nhi)
      shells = shells ++ [no_shell()]
      continue
    }
    if dup_names(d.tparams) {
      cx1 = cerr(cx1, "duplicate type parameter names", d.nlo, d.nhi)
    }
    match d.alias_target {
      Some(target) -> {
        match alias_effvar_span(target) {
          Some(sp) -> {
            let (alo, ahi) = sp
            cx1 = cerr_h(cx1, "a type alias cannot carry effect variables", alo, ahi,
              "write !io, or leave the function type pure")
          }
          None -> ()
        }
        var tvs: List[Ty] = []
        for tn in d.tparams {
          let (cx2, v) = fresh_tvar(cx1, tn)
          cx1 = cx2
          tvs = tvs ++ [v]
        }
        cx1 = Cx {
          ..cx1,
          aliases: map.insert(cx1.aliases, d.name, AliasE {
            name: d.name,
            tparams: tvs,
            target: Some(target),
            nlo: d.nlo,
            nhi: d.nhi
          })
        }
        shells = shells ++ [no_shell()]
        continue
      }
      None -> ()
    }
    var tvs: List[Ty] = []
    for tn in d.tparams {
      let (cx2, v) = fresh_tvar(cx1, tn)
      cx1 = cx2
      tvs = tvs ++ [v]
    }
    var derives_show = false
    var derives_ord = false
    for b in d.derives {
      if b.name == "Show" {
        derives_show = true
      } else if b.name == "Ord" {
        derives_ord = true
      } else {
        cx1 = cerr_h(cx1, "unknown derivable trait `" ++ b.name ++ "`", b.lo, b.hi,
          "Show and Ord can be derived")
      }
    }
    let (cx3, aid) = fresh(cx1)
    cx1 = cx3
    var accepted: List[(Int, Int)] = []
    var first_ok = false
    var ctor_infos: List[CtorI] = []
    var slot = 0
    var pi = 0
    var cbn = cx1.ctors_by_name
    for c in d.ctors {
      let builtin_ctor = match ty_named(c.name) {
        Some(_) -> true
        None -> false
      }
      if builtin_ctor {
        cx1 = cerr(cx1, "constructor `" ++ c.name ++ "` collides with a builtin type name",
          c.nlo, c.nhi)
      } else if map.has(cbn, c.name) {
        cx1 = cerr(cx1, "constructor `" ++ c.name ++
            "` is already defined (constructors share one module-wide namespace)", c.nlo, c.nhi)
      } else {
        cbn = map.insert(cbn, c.name, (aid, slot))
        ctor_infos = ctor_infos ++ [CtorI { adt: aid, name: c.name, fields: [] }]
        accepted = accepted ++ [(pi, slot)]
        if pi == 0 { first_ok = true }
        slot = slot + 1
      }
      pi = pi + 1
    }
    let info = AdtI {
      id: aid,
      name: d.name,
      is_record: d.is_record,
      tparams: tvs,
      ctors: ctor_infos,
      derives_show: derives_show,
      derives_ord: derives_ord,
      owner: cx1.owner_class
    }
    cx1 = Cx {
      ..cx1,
      ctors_by_name: cbn,
      adts: map.insert(cx1.adts, aid, info),
      adts_by_name: map.insert(cx1.adts_by_name, d.name, aid)
    }
    shells = shells ++ [Some(Shell { adt: aid, accepted: accepted, first_ok: first_ok })]
  }
  (cx1, shells)
}

fn accepted_slot(sh: Shell, pi: Int) -> Option[Int] = {
  for a in sh.accepted {
    let (p, slot) = a
    if p == pi { return Some(slot) }
  }
  None
}

## Pass 2: constructor field types (may reference any type declared above).
pub fn pass_ctor_fields(cx: Cx, m: Module, shells: List[Option[Shell]]) -> Cx = {
  var cx1 = cx
  var di = 0
  for d in module_types(m) {
    let sh = match shells[di] {
      None -> {
        di = di + 1
        continue
      }
      Some(s) -> s
    }
    let info = adt_of(cx1.adts, sh.adt)
    # the Kotlin quirk: the tparam scope comes from the FIRST parsed ctor's info
    var tp: Map[String, Ty] = map.empty()
    if sh.first_ok {
      for v in info.tparams {
        match v {
          TyVar(n, _) -> { tp = map.insert(tp, n, v) }
          _ -> ()
        }
      }
    }
    let saved_tp = cx1.current_tparams
    cx1 = Cx { ..cx1, current_tparams: tp }
    var new_ctors = info.ctors
    var pi = 0
    for c in d.ctors {
      let slot = match accepted_slot(sh, pi) {
        None -> {
          pi = pi + 1
          continue
        }
        Some(s) -> s
      }
      var fields: List[FieldI] = []
      var fnames: Set[String] = set.empty()
      for f in c.fields {
        if set.has(fnames, f.name) {
          cx1 = cerr(cx1, "field `" ++ f.name ++ "` is declared twice in `" ++ c.name ++ "`",
            f.lo, f.hi)
          continue
        }
        fnames = set.insert(fnames, f.name)
        let (cx2, ft0) = resolve_type(cx1, f.tref)
        cx1 = cx2
        var ft = ft0
        if ft == TyUnit {
          cx1 = cerr_h(cx1, "constructor fields cannot be Unit", f.lo, f.hi,
            "a no-payload case is just a bare constructor")
          ft = TyError
        }
        fields = fields ++ [FieldI { name: f.name, ty: ft }]
      }
      let old = new_ctors[slot]
      new_ctors = list.take(new_ctors, slot) ++ [CtorI { ..old, fields: fields }] ++
        list.drop(new_ctors, slot + 1)
      pi = pi + 1
    }
    cx1 = Cx {
      ..cx1,
      current_tparams: saved_tp,
      adts: map.insert(cx1.adts, sh.adt, AdtI { ..info, ctors: new_ctors })
    }
    di = di + 1
  }
  cx1
}

test "type shells and fields build recursive types" {
  # type Tree[T] = | Leaf | Node(v: T, kids: List[Tree[T]])
  let m = Module { decls: [DType(TypeDeclR {
    is_pub: false,
    name: "Tree",
    tparams: ["T"],
    ctors: [
      CtorDecl { name: "Leaf", fields: no_fields(), lo: 0, hi: 4, nlo: 0, nhi: 4 },
      CtorDecl {
        name: "Node",
        fields: [
          FieldDecl { name: "v", tref: TNamed("T", [], 10, 11), lo: 8, hi: 11 },
          FieldDecl {
            name: "kids",
            tref: TNamed("List", [TNamed("Tree", [TNamed("T", [], 24, 25),], 19, 26)], 13, 27),
            lo: 13,
            hi: 27
          }
        ],
        lo: 5,
        hi: 28,
        nlo: 5,
        nhi: 9
      }
    ],
    is_record: false,
    derives: [],
    alias_target: None,
    lo: 0,
    hi: 28,
    nlo: 5,
    nhi: 9
  })] }
  var cx = seed_prelude(test_cx())
  let (cx1, shells) = pass_type_shells(cx, m)
  let cx2 = pass_ctor_fields(cx1, m, shells)
  assert len(cx2.diags) == 0
  let aid = map.get(cx2.adts_by_name, "Tree").expect("registered")
  let a = adt_of(cx2.adts, aid)
  assert len(a.ctors) == 2
  assert a.ctors[1].fields[1].name == "kids"
  match a.ctors[1].fields[1].ty {
    TyList(inner) ->
      match inner {
        TyAdt(aid2, args) -> {
          assert aid2 == aid
          assert args == a.tparams
        }
        _ -> { assert false }
      }
    _ -> { assert false }
  }
}

test "duplicate constructors and prelude clashes are caught" {
  let mk = fn(name: String) => DType(TypeDeclR {
    is_pub: false,
    name: name,
    tparams: [],
    ctors: [CtorDecl { name: "C" ++ name, fields: [], lo: 0, hi: 1, nlo: 0, nhi: 1 }],
    is_record: false,
    derives: [],
    alias_target: None,
    lo: 0,
    hi: 1,
    nlo: 0,
    nhi: 1
  })
  let m = Module { decls: [mk("Option"), mk("A"), mk("A")] }
  var cx = seed_prelude(test_cx())
  let (cx1, shells) = pass_type_shells(cx, m)
  assert len(cx1.diags) == 2
  assert cx1.diags[0].msg == "`Option` is a prelude type and cannot be redefined"
  assert cx1.diags[1].msg == "type `A` is defined twice"
}

## Pass 2.25: resolve every alias target now, so cycles and unknown names are
## reported at the declaration even if the alias is never used.
pub fn pass_resolve_aliases(cx: Cx) -> Cx = {
  var cx1 = cx
  for name in map.keys(cx.aliases) {
    let al = map.get(cx1.aliases, name).expect("alias listed")
    let (cx2, _) = resolve_alias_target(cx1, al, al.nlo, al.nhi)
    cx1 = cx2
  }
  cx1
}

## Pass 2.5: derive Show — every field must be renderable (type parameters
## allowed, resolved at use).
pub fn pass_derive_show(cx: Cx, m: Module, shells: List[Option[Shell]]) -> Cx = {
  var cx1 = cx
  var di = 0
  for d in module_types(m) {
    let sh = match shells[di] {
      None -> {
        di = di + 1
        continue
      }
      Some(s) -> s
    }
    let info = adt_of(cx1.adts, sh.adt)
    if not info.derives_show {
      di = di + 1
      continue
    }
    var pi = 0
    for c in d.ctors {
      let slot = match accepted_slot(sh, pi) {
        None -> {
          pi = pi + 1
          continue
        }
        Some(s2) -> s2
      }
      let ci = info.ctors[slot]
      var fi = 0
      for f in ci.fields {
        if not is_showable_field(cx1, f.ty) {
          # the field's declaration span: find the parsed field by name
          var flo = d.nlo
          var fhi = d.nhi
          for pf in c.fields {
            if pf.name == f.name {
              flo = pf.lo
              fhi = pf.hi
            }
          }
          cx1 = cerr_h(cx1, "cannot derive Show for `" ++ info.name ++ "`: field `" ++
              f.name ++ "` of type " ++ ty_show(cx1.adts, f.ty) ++ " is not printable",
            flo, fhi, show_hint(cx1, f.ty))
        }
        fi = fi + 1
      }
      pi = pi + 1
    }
    di = di + 1
  }
  cx1
}

test "alias cycles and derive Show violations are reported at the declaration" {
  # alias A = B, alias B = A  → cycle; type P = { f: fn() -> Unit } derive Show → not printable
  let m = Module { decls: [
    DType(TypeDeclR {
      is_pub: false,
      name: "A",
      tparams: [],
      ctors: [],
      is_record: false,
      derives: [],
      alias_target: Some(TNamed("B", [], 10, 11)),
      lo: 0,
      hi: 11,
      nlo: 6,
      nhi: 7
    }),
    DType(TypeDeclR {
      is_pub: false,
      name: "B",
      tparams: [],
      ctors: [],
      is_record: false,
      derives: [],
      alias_target: Some(TNamed("A", [], 22, 23)),
      lo: 12,
      hi: 23,
      nlo: 18,
      nhi: 19
    }),
    DType(TypeDeclR {
      is_pub: false,
      name: "P",
      tparams: [],
      ctors: [CtorDecl {
        name: "P",
        fields: [FieldDecl {
          name: "f",
          tref: TFn([], TNamed("Unit", [], 40, 44), [], 33, 44),
          lo: 30,
          hi: 44
        }],
        lo: 24,
        hi: 46,
        nlo: 29,
        nhi: 30
      }],
      is_record: true,
      derives: [Bound { name: "Show", lo: 50, hi: 54 }],
      alias_target: None,
      lo: 24,
      hi: 54,
      nlo: 29,
      nhi: 30
    })
  ] }
  var cx = seed_prelude(test_cx())
  let (cx1, shells) = pass_type_shells(cx, m)
  var cx2 = pass_ctor_fields(cx1, m, shells)
  cx2 = pass_resolve_aliases(cx2)
  cx2 = pass_derive_show(cx2, m, shells)
  var saw_cycle = false
  var saw_show = false
  for dg in cx2.diags {
    if str.contains(dg.msg, "refers to itself") { saw_cycle = true }
    if str.contains(dg.msg, "cannot derive Show for `P`") { saw_show = true }
  }
  assert saw_cycle
  assert saw_show
}

## Pass 2.75a: register trait headers and method signatures; methods enter the
## fn namespace (the Kotlin registerTraits).
pub fn pass_register_traits(cx: Cx, m: Module) -> Cx = {
  var cx1 = cx
  for d in module_traits(m) {
    if alias_shadows(cx1, d.name) {
      cx1 = alias_shadow(cx1, d.name, d.nlo, d.nhi)
      continue
    }
    if import_clashes(cx1, d.name) {
      cx1 = import_clash(cx1, d.name, d.nlo, d.nhi, "trait")
      continue
    }
    let is_builtin_name = match ty_named(d.name) {
      Some(_) -> true
      None -> d.name == "List" || d.name == "Map" || d.name == "Set"
    }
    if is_builtin_name {
      cx1 = cerr(cx1, "`" ++ d.name ++ "` is a builtin type and cannot be a trait name",
        d.nlo, d.nhi)
      continue
    }
    if map.has(cx1.adts_by_name, d.name) || map.has(cx1.aliases, d.name) ||
      map.has(cx1.java_classes, d.name) {
        cx1 = cerr_h(cx1, "trait `" ++ d.name ++ "` collides with a type of the same name",
          d.nlo, d.nhi, "traits and types share one namespace; rename one")
        continue
      }
    if map.has(cx1.traits_by_name, d.name) {
      let msg = if d.name == "Ord" {
        "`" ++ d.name ++ "` is a prelude trait and cannot be redefined"
      } else {
        "trait `" ++ d.name ++ "` is defined twice"
      }
      cx1 = cerr(cx1, msg, d.nlo, d.nhi)
      continue
    }
    let (cx2, tvar) = fresh_tvar(cx1, d.tp)
    let (cx3, tid) = fresh(cx2)
    cx1 = cx3
    var methods: List[(String, MethodSig)] = []
    var tp: Map[String, Ty] = map.empty()
    tp = map.insert(tp, d.tp, tvar)
    let saved_tp = cx1.current_tparams
    for me in d.methods {
      var non_io = false
      for a in me.effs {
        if a != "io" { non_io = true }
      }
      if non_io {
        cx1 = cerr_h(cx1, "trait methods cannot declare effect variables", me.nlo, me.nhi,
          "a trait method is pure or !io")
        continue
      }
      let saved_ev = cx1.current_eff_vars
      let empty_ev: Map[String, Eff] = map.empty()
      cx1 = Cx { ..cx1, current_tparams: tp, current_eff_vars: empty_ev }
      var ptys: List[Ty] = []
      for p in me.params {
        let (cx4, t) = resolve_type(cx1, p.tref)
        cx1 = cx4
        ptys = ptys ++ [t]
      }
      let (cx5, ret) = resolve_type(cx1, me.ret)
      cx1 = cx5
      let leaked = map.size(cx1.current_eff_vars) > 0
      cx1 = Cx { ..cx1, current_tparams: saved_tp, current_eff_vars: saved_ev }
      if leaked {
        cx1 = cerr_h(cx1, "trait method signatures cannot carry effect variables", me.nlo, me.nhi,
          "write !io on the function type, or leave it pure")
        continue
      }
      let eff = if len(me.effs) == 0 { EPure } else { EIo }
      let sig = Sig {
        name: me.name,
        param_tys: ptys,
        param_names: map(me.params, fn(p) => p.name),
        ret: ret,
        eff: eff,
        is_builtin: false,
        tparams: [tvar],
        constraints: [[tid]],
        owner: cx1.owner_class,
        trait_id: Some(tid),
        inferring: false
      }
      # like top-level fns, a trait method may shadow a builtin/std name
      if alias_shadows(cx1, me.name) {
        cx1 = alias_shadow(cx1, me.name, me.nlo, me.nhi)
      } else if import_clashes(cx1, me.name) {
        cx1 = import_clash(cx1, me.name, me.nlo, me.nhi, "trait method")
      } else if map.has(cx1.fns, me.name) {
        let prev = map.get(cx1.fns, me.name).expect("present")
        let msg = match prev.trait_id {
          Some(ptid) -> "`" ++ me.name ++ "` is already a method of trait `" ++
            trait_of(cx1.traits, ptid).name ++ "` (trait methods share the function namespace)"
          None -> "trait method `" ++ me.name ++ "` collides with a function of the same name"
        }
        cx1 = cerr(cx1, msg, me.nlo, me.nhi)
      } else {
        cx1 = Cx { ..cx1, fns: map.insert(cx1.fns, me.name, sig) }
        let has_default = match me.body {
          Some(_) -> true
          None -> false
        }
        methods = methods ++ [(me.name, MethodSig { sig: sig, has_default: has_default })]
      }
    }
    let info = TraitI {
      id: tid,
      name: d.name,
      tvar: tvar,
      is_pub: d.is_pub,
      owner: cx1.owner_class,
      src_path: cx1.src_path,
      methods: methods
    }
    cx1 = Cx {
      ..cx1,
      traits: map.insert(cx1.traits, tid, info),
      traits_by_name: map.insert(cx1.traits_by_name, d.name, tid),
      local_traits: cx1.local_traits ++ [d.name]
    }
  }
  cx1
}

test "trait registration puts methods in the fn namespace" {
  # trait Eq2[T] { fn eq2(a: T, b: T) -> Bool }
  let m = Module { decls: [DTrait("Eq2", "T", 10, 11, [TraitMethod {
    name: "eq2",
    params: [
      Param { name: "a", tref: TNamed("T", [], 22, 23), lo: 19, hi: 20 },
      Param { name: "b", tref: TNamed("T", [], 28, 29), lo: 25, hi: 26 }
    ],
    ret: TNamed("Bool", [], 34, 38),
    effs: [],
    body: no_body(),
    lo: 14,
    hi: 38,
    nlo: 17,
    nhi: 20
  }], false, 0, 40, 6, 9)] }
  var cx = seed_prelude(test_cx())
  cx = pass_register_traits(cx, m)
  assert len(cx.diags) == 0
  let tid = map.get(cx.traits_by_name, "Eq2").expect("registered")
  let tr = trait_of(cx.traits, tid)
  assert len(tr.methods) == 1
  let s = map.get(cx.fns, "eq2").expect("in fn namespace")
  assert s.trait_id == Some(tid)
  assert sig_render(cx.adts, cx.traits, s) == "fn eq2[T: Eq2](a: T, b: T) -> Bool"
  # a second trait with the same method name collides
  let m2 = Module { decls: [DTrait("Eq3", "T", 10, 11, [TraitMethod {
    name: "eq2",
    params: no_params(),
    ret: TNamed("Bool", [], 34, 38),
    effs: [],
    body: no_body(),
    lo: 14,
    hi: 38,
    nlo: 17,
    nhi: 20
  }], false, 0, 40, 6, 9)] }
  let cx2 = pass_register_traits(cx, m2)
  assert len(cx2.diags) == 1
  assert str.contains(cx2.diags[0].msg, "already a method of trait `Eq2`")
}

## The subject-type restriction for v1 impls (spec/docs trait.md).
fn impl_subject_ok(cx: Cx, subject: Ty) -> Bool =
  match subject {
    TyInt | TyFloat | TyBool | TyString -> true
    TyAdt(aid, _) -> len(adt_of(cx.adts, aid).tparams) == 0
    _ -> false
  }

## Pass 2.75b: register impls — derive Ord first (so an explicit duplicate
## reports as the duplicate), then subject rules, the orphan rule, program-wide
## coherence, and method signature matching (the Kotlin registerImpls).
## Also returns each impl's resolved method signatures (aligned with
## module_impls × methods; None where registration failed), for body checking.
pub fn pass_register_impls(
  cx: Cx,
  m: Module,
  shells: List[Option[Shell]]
) -> (Cx, List[List[Option[Sig]]]) = {
  var cx1 = cx
  var impl_sigs: List[List[Option[Sig]]] = []
  # local ADT ids (for the orphan rule)
  var local_adts: Set[Int] = set.empty()
  for sh in shells {
    match sh {
      Some(s) -> { local_adts = set.insert(local_adts, s.adt) }
      None -> ()
    }
  }
  # derive Ord first
  var di = 0
  for d in module_types(m) {
    let sh = match shells[di] {
      None -> {
        di = di + 1
        continue
      }
      Some(s) -> s
    }
    let info = adt_of(cx1.adts, sh.adt)
    if not info.derives_ord {
      di = di + 1
      continue
    }
    var dlo = d.nlo
    var dhi = d.nhi
    for b in d.derives {
      if b.name == "Ord" {
        dlo = b.lo
        dhi = b.hi
      }
    }
    if len(info.tparams) > 0 {
      cx1 = cerr_h(cx1, "cannot derive Ord for the generic type `" ++ info.name ++ "`",
        dlo, dhi, "v1 Ord subjects are non-generic; order concrete values instead")
      di = di + 1
      continue
    }
    let subject = TyAdt(sh.adt, [])
    let ii = ImplI {
      trait_id: ORD_ID,
      subject: subject,
      lo: dlo,
      hi: dhi,
      derived: true,
      owner: cx1.owner_class,
      src_path: cx1.src_path,
      provided: []
    }
    cx1 = Cx {
      ..cx1,
      impl_table: map.insert(cx1.impl_table, (ORD_ID, subject), ii),
      local_impls: cx1.local_impls ++ [ii]
    }
    di = di + 1
  }
  # explicit impls
  for d in module_impls(m) {
    let tid = match map.get(cx1.traits_by_name, d.trait_name) {
      None -> {
        let pool = map.keys(cx1.traits_by_name)
        let hint = match suggest.hint(d.trait_name, pool) {
          Some(h) -> h
          None -> "declare `trait " ++ d.trait_name ++ "[T] { ... }` or import it first"
        }
        cx1 = cerr_h(cx1, "unknown trait: " ++ d.trait_name, d.tlo, d.thi, hint)
        impl_sigs = impl_sigs ++ [no_msigs(len(d.methods))]
        continue
      }
      Some(t) -> t
    }
    let tr = trait_of(cx1.traits, tid)
    let empty_tp: Map[String, Ty] = map.empty()
    let empty_ev: Map[String, Eff] = map.empty()
    cx1 = Cx { ..cx1, current_tparams: empty_tp, current_eff_vars: empty_ev }
    let (cx2, subject) = resolve_type(cx1, d.subject)
    cx1 = cx2
    if subject == TyError {
      impl_sigs = impl_sigs ++ [no_msigs(len(d.methods))]
      continue
    }
    if not impl_subject_ok(cx1, subject) {
      cx1 = cerr_h(cx1, "`" ++ ty_show(cx1.adts, subject) ++ "` cannot be an impl subject",
        t_lo2(d.subject), t_hi2(d.subject),
        "v1 impls cover named non-generic types and Int/Float/Bool/String; " ++
          "generic subjects (List, Map, tuples, instantiated generics) need conditional impls (v2)")
      impl_sigs = impl_sigs ++ [no_msigs(len(d.methods))]
      continue
    }
    # orphan rule: the impl lives with the trait or with the subject type
    var trait_local = false
    for n in cx1.local_traits {
      if n == d.trait_name { trait_local = true }
    }
    let subject_local = match subject {
      TyAdt(aid, _) -> set.has(local_adts, aid)
      _ -> false
    }
    if not trait_local && not subject_local {
      cx1 = cerr_h(cx1, "orphan impl: `" ++ tr.name ++ "[" ++ ty_show(cx1.adts, subject) ++
          "]` may not live here", d.tlo, d.thi,
        "an impl belongs to the module that declares `" ++ tr.name ++
          "` or the one that declares `" ++ ty_show(cx1.adts, subject) ++ "`")
      impl_sigs = impl_sigs ++ [no_msigs(len(d.methods))]
      continue
    }
    # coherence: at most one impl per (trait, type) in the whole program
    match map.get(cx1.impl_table, (tid, subject)) {
      Some(prev) -> {
        let where2 = match prev.src_path {
          Some(p) -> if cx1.src_path == Some(p) { "" } else { " (previous impl in " ++ p ++ ")" }
          None -> ""
        }
        let hint = if prev.derived {
          "`" ++ ty_show(cx1.adts, subject) ++ "` already derives " ++ tr.name ++
            "; drop the derive or this impl"
        } else {
          "the program allows one impl per trait and type"
        }
        cx1 = cerr_h(cx1, "duplicate impl: `" ++ tr.name ++ "[" ++ ty_show(cx1.adts, subject) ++
            "]` is already implemented" ++ where2, d.tlo, d.thi, hint)
        impl_sigs = impl_sigs ++ [no_msigs(len(d.methods))]
        continue
      }
      None -> ()
    }
    var inst: Map[Int, Ty] = map.empty()
    match tr.tvar {
      TyVar(_, vid) -> { inst = map.insert(inst, vid, subject) }
      _ -> ()
    }
    let em0: Map[Int, Eff] = map.empty()
    var provided: List[String] = []
    var msigs: List[Option[Sig]] = []
    for me in d.methods {
      var ms: Option[MethodSig] = None
      for entry in tr.methods {
        let (mname, msig) = entry
        if mname == me.name { ms = Some(msig) }
      }
      let msv = match ms {
        None -> {
          var mnames: List[String] = []
          for entry in tr.methods {
            let (mname, _) = entry
            mnames = mnames ++ [mname]
          }
          cx1 = cerr_o(cx1, "trait `" ++ tr.name ++ "` has no method `" ++ me.name ++ "`",
            me.nlo, me.nhi, suggest.hint(me.name, mnames))
          msigs = msigs ++ [no_sig()]
          continue
        }
        Some(v) -> v
      }
      var already = false
      for pn in provided {
        if pn == me.name { already = true }
      }
      if already {
        cx1 = cerr(cx1, "method `" ++ me.name ++ "` is implemented twice in this impl",
          me.nlo, me.nhi)
        msigs = msigs ++ [no_sig()]
        continue
      }
      var non_io = false
      for a in me.effs {
        if a != "io" { non_io = true }
      }
      if non_io {
        cx1 = cerr_h(cx1, "impl methods cannot declare effect variables", me.nlo, me.nhi,
          "an impl method is pure or !io")
        msigs = msigs ++ [no_sig()]
        continue
      }
      let saved_ev = cx1.current_eff_vars
      let empty_ev2: Map[String, Eff] = map.empty()
      cx1 = Cx { ..cx1, current_eff_vars: empty_ev2 }
      var ptys: List[Ty] = []
      for p in me.params {
        let (cx3, t) = resolve_type(cx1, p.tref)
        cx1 = cx3
        ptys = ptys ++ [t]
      }
      let (cx4, ret) = match me.ret {
        Some(r) -> resolve_type(cx1, r)
        None -> (cx1, TyError)
      }
      cx1 = cx4
      let eff = if len(me.effs) == 0 { EPure } else { EIo }
      let leaked = map.size(cx1.current_eff_vars) > 0
      cx1 = Cx { ..cx1, current_eff_vars: saved_ev }
      if leaked {
        cx1 = cerr(cx1, "impl method signatures cannot carry effect variables", me.nlo, me.nhi)
        msigs = msigs ++ [no_sig()]
        continue
      }
      let inst2 = inst
      let adts2 = cx1.adts
      let want = map(msv.sig.param_tys, fn(t) => subst(t, inst2, em0))
      let want_ret = subst(msv.sig.ret, inst2, em0)
      let want_render = "fn " ++ me.name ++ "(" ++
        join(map(want, fn(t) => ty_show(adts2, t)), ", ") ++ ") -> " ++
        ty_show(cx1.adts, want_ret) ++ eff_suffix(msv.sig.eff)
      if ptys != want || ret != want_ret {
        cx1 = cerr_h(cx1, "`" ++ me.name ++ "` does not match the trait's signature",
          me.nlo, me.nhi, "trait `" ++ tr.name ++ "` declares it as " ++ want_render)
      } else if not eff_subsumes(msv.sig.eff, eff) {
        cx1 = cerr_h(cx1, "`" ++ me.name ++ "` is declared !" ++ eff_show2(eff) ++
            " but trait `" ++ tr.name ++ "` declares it pure", me.nlo, me.nhi,
          "drop !" ++ eff_show2(eff) ++ " here, or declare the trait method !" ++ eff_show2(eff))
      }
      provided = provided ++ [me.name]
      msigs = msigs ++ [Some(Sig {
        name: me.name,
        param_tys: ptys,
        param_names: map(me.params, fn(p) => p.name),
        ret: ret,
        eff: eff,
        is_builtin: false,
        tparams: [],
        constraints: [],
        owner: cx1.owner_class,
        trait_id: None,
        inferring: false
      })]
    }
    var missing: List[MethodSig] = []
    for entry in tr.methods {
      let (mname, msig) = entry
      var have = false
      for pn in provided {
        if pn == mname { have = true }
      }
      if not msig.has_default && not have { missing = missing ++ [msig] }
    }
    if len(missing) > 0 {
      var names2: List[String] = []
      var renders: List[String] = []
      for msig in missing {
        names2 = names2 ++ ["`" ++ msig.sig.name ++ "`"]
        var ps: List[String] = []
        var i = 0
        for pt in msig.sig.param_tys {
          let pn = match get(msig.sig.param_names, i) {
            Some(n) -> n
            None -> "_"
          }
          ps = ps ++ [pn ++ ": " ++ ty_show(cx1.adts, subst(pt, inst, em0))]
          i = i + 1
        }
        renders = renders ++ ["fn " ++ msig.sig.name ++ "(" ++ join(ps, ", ") ++ ") -> " ++
            ty_show(cx1.adts, subst(msig.sig.ret, inst, em0)) ++ eff_suffix(msig.sig.eff)]
      }
      cx1 = cerr_h(cx1, "impl `" ++ tr.name ++ "[" ++ ty_show(cx1.adts, subject) ++
          "]` is missing " ++ join(names2, ", "), d.tlo, d.thi,
        "provide: " ++ join(renders, "; "))
    }
    let info = ImplI {
      trait_id: tid,
      subject: subject,
      lo: d.lo,
      hi: d.hi,
      derived: false,
      owner: cx1.owner_class,
      src_path: cx1.src_path,
      provided: provided
    }
    cx1 = Cx {
      ..cx1,
      impl_table: map.insert(cx1.impl_table, (tid, subject), info),
      local_impls: cx1.local_impls ++ [info]
    }
    impl_sigs = impl_sigs ++ [msigs]
  }
  # derive Ord field check, after every impl is known
  di = 0
  for d in module_types(m) {
    let sh = match shells[di] {
      None -> {
        di = di + 1
        continue
      }
      Some(s) -> s
    }
    let info = adt_of(cx1.adts, sh.adt)
    let derived_ord = match map.get(cx1.impl_table, (ORD_ID, TyAdt(sh.adt, []))) {
      Some(ii) -> info.derives_ord && ii.derived
      None -> false
    }
    if not derived_ord {
      di = di + 1
      continue
    }
    var dlo = d.nlo
    var dhi = d.nhi
    for b in d.derives {
      if b.name == "Ord" {
        dlo = b.lo
        dhi = b.hi
      }
    }
    for ci in info.ctors {
      for f in ci.fields {
        let scalar_ok = f.ty == TyInt || f.ty == TyFloat || f.ty == TyString
        let adt_ok = match f.ty {
          TyAdt(_, _) -> map.has(cx1.impl_table, (ORD_ID, f.ty))
          _ -> false
        }
        if not scalar_ok && not adt_ok {
          cx1 = cerr_h(cx1, "cannot derive Ord for `" ++ info.name ++ "`: field `" ++
              f.name ++ "` of type " ++ ty_show(cx1.adts, f.ty) ++ " is not orderable",
            dlo, dhi, "orderable fields are Int, Float, String, and types with an Ord impl")
        }
      }
    }
    di = di + 1
  }
  (cx1, impl_sigs)
}

## Render a concrete effect for the impl-method error text ("io").
fn eff_show2(e: Eff) -> String = if e == EIo { "io" } else { "" }

test "impl registration enforces coherence and signature matching" {
  # trait Eq4[T] { fn eq4(a: T, b: T) -> Bool }  impl Eq4[Int] twice + one bad sig
  let tm = TraitMethod {
    name: "eq4",
    params: [
      Param { name: "a", tref: TNamed("T", [], 22, 23), lo: 19, hi: 20 },
      Param { name: "b", tref: TNamed("T", [], 28, 29), lo: 25, hi: 26 }
    ],
    ret: TNamed("Bool", [], 34, 38),
    effs: [],
    body: no_body(),
    lo: 14,
    hi: 38,
    nlo: 17,
    nhi: 20
  }
  fn good_impl(lo: Int) -> Decl = DImpl("Eq4", lo, lo + 3, TNamed("Int", [], lo + 4, lo + 7), [FnDecl {
    is_pub: false,
    name: "eq4",
    tparams: no_tparams(),
    params: [
      Param { name: "a", tref: TNamed("Int", [], 0, 1), lo: 0, hi: 1 },
      Param { name: "b", tref: TNamed("Int", [], 2, 3), lo: 2, hi: 3 }
    ],
    ret: Some(TNamed("Bool", [], 4, 8)),
    effs: no_effs(),
    body: EBool(true, 9, 13),
    lo: 0,
    hi: 13,
    nlo: 0,
    nhi: 3
  }], lo, lo + 20)
  let m = Module { decls: [
    DTrait("Eq4", "T", 10, 11, [tm], false, 0, 40, 6, 9),
    good_impl(50),
    good_impl(80)
  ] }
  var cx = seed_prelude(test_cx())
  cx = pass_register_traits(cx, m)
  let none_shells: List[Option[Shell]] = []
  let (cxri, _) = pass_register_impls(cx, m, none_shells)
  cx = cxri
  assert len(cx.diags) == 1
  assert str.contains(cx.diags[0].msg, "duplicate impl: `Eq4[Int]`")
  assert len(cx.local_impls) == 1
  # a missing method reports with the expected render
  let m2 = Module { decls: [
    DTrait("Eq5", "T", 10, 11, [TraitMethod { ..tm, name: "eq5" }], false, 0, 40, 6, 9),
    DImpl("Eq5", 50, 53, TNamed("Int", [], 54, 57), no_fn_decls(), 50, 70)
  ] }
  var cx2 = seed_prelude(test_cx())
  cx2 = pass_register_traits(cx2, m2)
  let (cxri2, _) = pass_register_impls(cx2, m2, none_shells)
  cx2 = cxri2
  assert len(cx2.diags) == 1
  assert str.contains(cx2.diags[0].msg, "is missing `eq5`")
  assert cx2.diags[0].hint == "provide: fn eq5(a: Int, b: Int) -> Bool"
}

## Resolve `[T: Ord + Show]` bounds against the visible traits, aligned per
## parameter (the Kotlin resolveBounds).
pub fn resolve_bounds(cx: Cx, tparams: List[TypeParamDecl]) -> (Cx, List[List[Int]]) = {
  var all_empty = true
  for tp in tparams {
    if len(tp.bounds) > 0 { all_empty = false }
  }
  if all_empty {
    let none: List[List[Int]] = []
    return (cx, none)
  }
  var cx1 = cx
  var out: List[List[Int]] = []
  for tp in tparams {
    var bnames: List[String] = []
    for b in tp.bounds { bnames = bnames ++ [b.name] }
    if dup_names(bnames) {
      cx1 = cerr(cx1, "duplicate trait bound on `" ++ tp.name ++ "`", tp.lo, tp.hi)
    }
    var ids: List[Int] = []
    for b in tp.bounds {
      match map.get(cx1.traits_by_name, b.name) {
        None -> {
          let hint = match suggest.hint(b.name, map.keys(cx1.traits_by_name)) {
            Some(h) -> h
            None -> "declare `trait " ++ b.name ++ "[T] { ... }` or import it first"
          }
          cx1 = cerr_h(cx1, "unknown trait: " ++ b.name, b.lo, b.hi, hint)
        }
        Some(tid) -> {
          var have = false
          for x in ids {
            if x == tid { have = true }
          }
          if not have { ids = ids ++ [tid] }
        }
      }
    }
    out = out ++ [ids]
  }
  (cx1, out)
}

## Pass 3: function signatures. Returns the per-decl signature list (aligned
## with module_fns order) plus per-decl effect-variable tables for body checks.
pub fn pass_fn_signatures(cx: Cx, m: Module) -> (Cx, List[Sig], List[Map[String, Eff]]) = {
  var cx1 = cx
  var sigs: List[Sig] = []
  var evs: List[Map[String, Eff]] = []
  for d in module_fns(m) {
    var tpnames: List[String] = []
    for tp in d.tparams { tpnames = tpnames ++ [tp.name] }
    if dup_names(tpnames) {
      cx1 = cerr(cx1, "duplicate type parameter names", d.nlo, d.nhi)
    }
    var tvars: List[Ty] = []
    var tp_scope: Map[String, Ty] = map.empty()
    for tp in d.tparams {
      let (cx2, v) = fresh_tvar(cx1, tp.name)
      cx1 = cx2
      tvars = tvars ++ [v]
      tp_scope = map.insert(tp_scope, tp.name, v)
    }
    let saved_tp = cx1.current_tparams
    let saved_ev = cx1.current_eff_vars
    let empty_ev: Map[String, Eff] = map.empty()
    cx1 = Cx { ..cx1, current_tparams: tp_scope, current_eff_vars: empty_ev }
    let (cx3, eff) = resolve_eff(cx1, d.effs)
    cx1 = cx3
    let inferring = match d.ret {
      Some(_) -> false
      None -> true
    }
    var ptys: List[Ty] = []
    for p in d.params {
      let (cx4, t) = resolve_type(cx1, p.tref)
      cx1 = cx4
      ptys = ptys ++ [t]
    }
    let (cx5, ret) = match d.ret {
      Some(r) -> resolve_type(cx1, r)
      None -> (cx1, TyError)
    }
    cx1 = cx5
    let (cx6, constraints) = resolve_bounds(cx1, d.tparams)
    cx1 = cx6
    let ev = cx1.current_eff_vars
    cx1 = Cx { ..cx1, current_tparams: saved_tp, current_eff_vars: saved_ev }
    # until the body is checked, an unannotated fn assumes the worst effect
    let final_eff = if inferring && len(d.effs) == 0 { EIo } else { eff }
    let sig = Sig {
      name: d.name,
      param_tys: ptys,
      param_names: map(d.params, fn(p) => p.name),
      ret: ret,
      eff: final_eff,
      is_builtin: false,
      tparams: tvars,
      constraints: constraints,
      owner: cx1.owner_class,
      trait_id: None,
      inferring: inferring
    }
    sigs = sigs ++ [sig]
    evs = evs ++ [ev]
    # a top-level fn may shadow a builtin or std name (spec §10.6)
    if alias_shadows(cx1, d.name) {
      cx1 = alias_shadow(cx1, d.name, d.nlo, d.nhi)
    } else if import_clashes(cx1, d.name) {
      cx1 = import_clash(cx1, d.name, d.nlo, d.nhi, "function")
    } else if map.has(cx1.fns, d.name) {
      let prev = map.get(cx1.fns, d.name).expect("present")
      let msg = match prev.trait_id {
        Some(ptid) -> "`" ++ d.name ++ "` is already a method of trait `" ++
          trait_of(cx1.traits, ptid).name ++ "` (trait methods share the function namespace)"
        None -> "function `" ++ d.name ++ "` is defined twice"
      }
      cx1 = cerr(cx1, msg, d.nlo, d.nhi)
    } else {
      cx1 = Cx { ..cx1, fns: map.insert(cx1.fns, d.name, sig) }
    }
  }
  (cx1, sigs, evs)
}

test "fn signatures resolve with bounds and worst-effect inference" {
  # fn f[T: Ord](x: T) -> T   and   fn g(x: Int) = x  (inferring → io placeholder)
  let m = Module { decls: [
    DFn(FnDecl {
      is_pub: false,
      name: "f",
      tparams: [TypeParamDecl {
        name: "T",
        bounds: [Bound { name: "Ord", lo: 9, hi: 12 }],
        lo: 6,
        hi: 12
      }],
      params: [Param { name: "x", tref: TNamed("T", [], 17, 18), lo: 14, hi: 15 }],
      ret: Some(TNamed("T", [], 23, 24)),
      effs: no_effs(),
      body: EVar("x", 27, 28),
      lo: 0,
      hi: 28,
      nlo: 3,
      nhi: 4
    }),
    DFn(FnDecl {
      is_pub: false,
      name: "g",
      tparams: no_tparams(),
      params: [Param { name: "x", tref: TNamed("Int", [], 36, 39), lo: 33, hi: 34 }],
      ret: None,
      effs: no_effs(),
      body: EVar("x", 43, 44),
      lo: 30,
      hi: 44,
      nlo: 33,
      nhi: 34
    })
  ] }
  var cx = seed_prelude(test_cx())
  let (cx1, sigs, evs) = pass_fn_signatures(cx, m)
  assert len(cx1.diags) == 0
  assert sig_render(cx1.adts, cx1.traits, sigs[0]) == "fn f[T: Ord](x: T) -> T"
  assert sigs[1].inferring
  assert sigs[1].eff == EIo
  assert map.get(cx1.fns, "g") == Some(sigs[1])
}

## Pass 3.5: constant declarations — types only (initializers run later, after
## signature inference). The Kotlin declareConst.
## Also returns each declared type (aligned with module_consts; None where the
## name was skipped for alias/import clashes), for initializer checking.
pub fn pass_const_decls(cx: Cx, m: Module) -> (Cx, List[Option[Ty]]) = {
  var cx1 = cx
  var decl_tys: List[Option[Ty]] = []
  var all: Set[String] = set.empty()
  for d in module_consts(m) { all = set.insert(all, d.name) }
  cx1 = Cx { ..cx1, all_const_names: all }
  for d in module_consts(m) {
    if alias_shadows(cx1, d.name) {
      cx1 = alias_shadow(cx1, d.name, d.nlo, d.nhi)
      decl_tys = decl_tys ++ [no_ty2()]
      continue
    }
    if import_clashes(cx1, d.name) {
      cx1 = import_clash(cx1, d.name, d.nlo, d.nhi, "constant")
      decl_tys = decl_tys ++ [no_ty2()]
      continue
    }
    let empty_tp: Map[String, Ty] = map.empty()
    let empty_ev: Map[String, Eff] = map.empty()
    cx1 = Cx { ..cx1, current_tparams: empty_tp, current_eff_vars: empty_ev }
    let (cx2, declared0) = resolve_type(cx1, d.ann)
    cx1 = cx2
    var declared = declared0
    if not is_const_serializable(cx1, declared, set.empty()) && declared != TyError {
      cx1 = cerr_h(cx1, "`" ++ ty_show(cx1.adts, declared) ++
          "` is not a constant-serializable type", t_lo2(d.ann), t_hi2(d.ann),
        "constants hold Int/Float/Bool/String and List/tuple/record/ADT values built from them (spec §7.2)")
      declared = TyError
    }
    # the initializer still checks against the annotation as written (the
    # Kotlin resolvedAnn survives the constType poisoning)
    decl_tys = decl_tys ++ [Some(declared0)]
    if map.has(cx1.ctors_by_name, d.name) || map.has(cx1.adts_by_name, d.name) ||
      map.has(cx1.traits_by_name, d.name) {
        cx1 = cerr(cx1, "`" ++ d.name ++ "` collides with a type, trait, or constructor name",
          d.nlo, d.nhi)
      } else if map.has(cx1.consts, d.name) {
        cx1 = cerr(cx1, "constant `" ++ d.name ++ "` is defined twice", d.nlo, d.nhi)
      } else {
        cx1 = Cx {
          ..cx1,
          consts: map.insert(cx1.consts, d.name, declared),
          const_order: cx1.const_order ++ [d.name]
        }
      }
  }
  (cx1, decl_tys)
}

## Pass 4: the entry point check (main's shape and visibility).
pub fn pass_main_check(cx: Cx, m: Module, sigs: List[Sig]) -> Cx = {
  var cx1 = cx
  var i = 0
  for d in module_fns(m) {
    if d.name == "main" {
      let sig = sigs[i]
      if len(sig.param_tys) > 0 || sig.ret != TyUnit {
        cx1 = cerr(cx1, "main must have the signature fn main() -> Unit !io", d.nlo, d.nhi)
      }
      if not d.is_pub {
        cx1 = cerr_h(cx1, "main must be pub", d.nlo, d.nhi, "write pub fn main() -> Unit !io")
      }
    }
    i = i + 1
  }
  cx1
}

test "const declarations register in order with serializability checks" {
  let m = Module { decls: [
    DConst("A", false, TNamed("Int", [], 9, 12), EInt(1, 15, 16), 0, 16, 6, 7),
    DConst("B", false,
      TNamed("Map", [TNamed("Int", [], 30, 33), TNamed("Int", [], 35, 38)], 26, 39),
      EInt(0, 42, 43), 20, 43, 26, 27),
    DConst("A", false, TNamed("Int", [], 55, 58), EInt(2, 61, 62), 46, 62, 52, 53)
  ] }
  var cx = seed_prelude(test_cx())
  let (cxcd, _) = pass_const_decls(cx, m)
  cx = cxcd
  assert cx.const_order == ["A", "B"]
  assert map.get(cx.consts, "B") == Some(TyError)
  assert len(cx.diags) == 2
  assert str.contains(cx.diags[0].msg, "not a constant-serializable type")
  assert cx.diags[1].msg == "constant `A` is defined twice"
}

test "main shape violations are reported" {
  let m = Module { decls: [DFn(FnDecl {
    is_pub: false,
    name: "main",
    tparams: no_tparams(),
    params: no_params2(),
    ret: Some(TNamed("Int", [], 20, 23)),
    effs: ["io"],
    body: EInt(0, 26, 27),
    lo: 0,
    hi: 27,
    nlo: 3,
    nhi: 7
  })] }
  var cx = seed_prelude(test_cx())
  let (cx1, sigs, evs) = pass_fn_signatures(cx, m)
  let cx2 = pass_main_check(cx1, m, sigs)
  assert len(cx2.diags) == 2
  assert cx2.diags[0].msg == "main must have the signature fn main() -> Unit !io"
  assert cx2.diags[1].msg == "main must be pub"
}

# ---- expression checking (pass 5 groundwork) ----
#
# Each check function returns (Cx, Ty, TExpr): the type for the checker's own
# reasoning, the typed node for comptime/codegen. Kotlin's checkExpr writes the
# type onto the AST node; here the TExpr simply carries what it needs.

## Unary operators (the Kotlin inferExpr's Unary arm).
pub fn check_unary(
  cx: Cx,
  op: UnOp,
  t: Ty,
  operand: TExpr,
  olo: Int,
  ohi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) =
  match op {
    OpNot -> {
      if t != TyBool && not is_errorish(t) {
        let cx1 = cerr(cx, "not expects Bool, got " ++ ty_show(cx.adts, t), olo, ohi)
        (cx1, TyError, XError(lo, hi))
      } else {
        (cx, TyBool, XUnary(UNot, operand, lo, hi, TyBool))
      }
    }
    OpNeg -> {
      if not is_numeric(t) && not is_errorish(t) {
        let cx1 = cerr(cx, "negation expects a number, got " ++ ty_show(cx.adts, t), olo, ohi)
        (cx1, TyError, XError(lo, hi))
      } else {
        (cx, t, XUnary(UNeg, operand, lo, hi, t))
      }
    }
    OpBnot -> {
      if t != TyInt && not is_errorish(t) {
        let cx1 = cerr(cx, "`~` expects Int, got " ++ ty_show(cx.adts, t), olo, ohi)
        (cx1, TyError, XError(lo, hi))
      } else {
        (cx, TyInt, XUnary(UBnot, operand, lo, hi, TyInt))
      }
    }
  }

## ast.BinOp → tast.TBinOp.
pub fn tbin_of(op: BinOp) -> TBinOp =
  match op {
    OpAdd -> BAdd
    OpSub -> BSub
    OpMul -> BMul
    OpDiv -> BDiv
    OpMod -> BMod
    OpConcat -> BConcat
    OpEq -> BEq
    OpNeq -> BNeq
    OpLt -> BLt
    OpLe -> BLe
    OpGt -> BGt
    OpGe -> BGe
    OpAnd -> BAnd
    OpOr -> BOr
    OpBand -> BBand
    OpBor -> BBor
    OpBxor -> BBxor
    OpShl -> BShl
    OpShr -> BShr
    OpUshr -> BUshr
  }

test "unary checking types and poisons" {
  let cx = test_cx()
  let (cx1, t1, x1) = check_unary(cx, OpNot, TyBool, XBool(true, 0, 4), 0, 4, 0, 4)
  assert t1 == TyBool
  assert len(cx1.diags) == 0
  let (cx2, t2, x2) = check_unary(cx, OpNeg, TyString, XError(0, 1), 0, 1, 0, 1)
  assert t2 == TyError
  assert cx2.diags[0].msg == "negation expects a number, got String"
}

## Satisfy one trait requirement at a use site (the Kotlin resolveWitness,
## specialized here for Ord over `<' family operators): a concrete subject
## resolves through the impl table; the caller's own rigid type parameter
## forwards the caller's dictionary (which every enclosing lambda captures).
## Returns the witness for the typed node.
pub fn resolve_ord_witness(cx: Cx, t: Ty, lo: Int, hi: Int) -> (Cx, Option[WitRef]) = {
  if is_errorish(t) { return (cx, no_wit()) }
  match t {
    TyVar(_, vid) ->
      match map.get(cx.dict_syms, (vid, ORD_ID)) {
        None -> {
          let cx1 = cerr_h(cx, "values of type " ++ ty_show(cx.adts, t) ++
              " cannot be ordered", lo, hi, "add the bound: [" ++ ty_show(cx.adts, t) ++ ": Ord]")
          (cx1, no_wit())
        }
        Some(sym) -> {
          var stack: List[LambdaCx] = []
          for lc in cx.lambda_stack {
            var caps = lc.captures
            var have = false
            for c in caps {
              if c == sym { have = true }
            }
            if not have { caps = caps ++ [sym] }
            stack = stack ++ [LambdaCx { ..lc, captures: caps }]
          }
          (Cx { ..cx, lambda_stack: stack }, Some(WForward(sym)))
        }
      }
    _ ->
      match map.get(cx.impl_table, (ORD_ID, t)) {
        Some(_) -> (cx, Some(WConcrete(ORD_ID, t)))
        None -> {
          let hint: Option[String] = match t {
            TyAdt(aid, _) ->
              if len(adt_of(cx.adts, aid).tparams) == 0 {
                let ts = ty_show(cx.adts, t)
                Some("implement it: impl Ord[" ++ ts ++ "] { fn cmp(a: " ++ ts ++ ", b: " ++
                    ts ++ ") -> Int = ... }")
              } else {
                None
              }
            _ -> None
          }
          (cerr_o(cx, "values of type " ++ ty_show(cx.adts, t) ++ " cannot be ordered",
            lo, hi, hint), no_wit())
        }
      }
  }
}

## Binary operators over already-checked operand types (the Kotlin checkBinary
## after both sides are typed; short-circuit evaluation order is the caller's
## job since it must thread Cx through left then right).
pub fn check_binary_typed(
  cx: Cx,
  op: BinOp,
  lt: Ty,
  rt: Ty,
  left: TExpr,
  right: TExpr,
  llo: Int,
  lhi: Int,
  rlo: Int,
  rhi: Int,
  olo: Int,
  ohi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) = {
  let node = fn(ord: Option[WitRef], t: Ty) => XBinary(tbin_of(op), left, right, ord, olo, ohi, lo, hi, t)
  # one side already failed: pick a plausible result type, stay silent
  if is_errorish(lt) || is_errorish(rt) {
    let t = match op {
      OpAdd | OpSub | OpMul | OpDiv | OpMod ->
        if is_numeric(lt) { lt } else if is_numeric(rt) { rt } else { TyError }
      OpBand | OpBor | OpBxor | OpShl | OpShr | OpUshr -> TyInt
      OpConcat ->
        match lt {
          TyList(_) -> lt
          _ ->
            match rt {
              TyList(_) -> rt
              _ -> TyString
            }
        }
      _ -> TyBool
    }
    return (cx, t, node(no_wit(), t))
  }
  match op {
    OpAdd | OpSub | OpMul | OpDiv | OpMod -> {
      if not is_numeric(lt) {
        return (cerr(cx, "arithmetic expects numbers, left side is " ++ ty_show(cx.adts, lt),
          llo, lhi), TyError, node(no_wit(), TyError))
      }
      if lt != rt {
        let hint: Option[String] = if is_numeric(rt) {
          Some("there are no implicit conversions; use to_float() (M1) or unify the literal types")
        } else {
          None
        }
        return (cerr_o(cx, "both sides must have the same type: " ++ ty_show(cx.adts, lt) ++
            " vs " ++ ty_show(cx.adts, rt), olo, ohi, hint), TyError, node(no_wit(), TyError))
      }
      (cx, lt, node(no_wit(), lt))
    }
    OpBand | OpBor | OpBxor | OpShl | OpShr | OpUshr -> {
      if lt != TyInt {
        return (cerr(cx, "bitwise operators expect Int, left side is " ++ ty_show(cx.adts, lt),
          llo, lhi), TyError, node(no_wit(), TyError))
      }
      if rt != TyInt {
        return (cerr(cx, "bitwise operators expect Int, right side is " ++ ty_show(cx.adts, rt),
          rlo, rhi), TyError, node(no_wit(), TyError))
      }
      (cx, TyInt, node(no_wit(), TyInt))
    }
    OpConcat -> {
      if lt == TyString && rt == TyString { return (cx, TyString, node(no_wit(), TyString)) }
      if lt == TyBytes && rt == TyBytes { return (cx, TyBytes, node(no_wit(), TyBytes)) }
      let both_lists = match lt {
        TyList(_) ->
          match rt {
            TyList(_) -> true
            _ -> false
          }
        _ -> false
      }
      if both_lists {
        if lt != rt {
          return (cerr(cx, "`++` needs lists of the same element type: " ++
              ty_show(cx.adts, lt) ++ " vs " ++ ty_show(cx.adts, rt), olo, ohi),
            TyError, node(no_wit(), TyError))
        }
        return (cx, lt, node(no_wit(), lt))
      }
      (cerr_h(cx, "`++` concatenates Strings, Bytes or Lists, got " ++ ty_show(cx.adts, lt) ++
          " ++ " ++ ty_show(cx.adts, rt), olo, ohi,
        "use + for numbers; interpolation \"{x}{y}\" also builds strings"), TyError,
        node(no_wit(), TyError))
    }
    OpEq | OpNeq -> {
      if contains_fn(lt) || contains_fn(rt) {
        return (cerr_h(cx, "functions cannot be compared", olo, ohi,
          "compare the values they produce, not the functions themselves"), TyError,
          node(no_wit(), TyError))
      }
      if lt != rt {
        return (cerr(cx, "== requires both sides to have the same type: " ++
            ty_show(cx.adts, lt) ++ " vs " ++ ty_show(cx.adts, rt), olo, ohi), TyError,
          node(no_wit(), TyError))
      }
      (cx, TyBool, node(no_wit(), TyBool))
    }
    OpLt | OpLe | OpGt | OpGe -> {
      if lt != rt {
        return (cerr(cx, "comparison requires both sides to have the same type: " ++
            ty_show(cx.adts, lt) ++ " vs " ++ ty_show(cx.adts, rt), olo, ohi), TyError,
          node(no_wit(), TyError))
      }
      # native fast path; Cursor orders too (spec §11)
      if lt == TyInt || lt == TyFloat || lt == TyString || lt == TyCursor {
        return (cx, TyBool, node(no_wit(), TyBool))
      }
      let (cx1, w) = resolve_ord_witness(cx, lt, olo, ohi)
      (cx1, TyBool, node(w, TyBool))
    }
    OpAnd | OpOr -> {
      if lt != TyBool {
        return (cerr(cx, "logical operators expect Bool, left side is " ++ ty_show(cx.adts, lt),
          llo, lhi), TyError, node(no_wit(), TyError))
      }
      if rt != TyBool {
        return (cerr(cx, "logical operators expect Bool, right side is " ++ ty_show(cx.adts, rt),
          rlo, rhi), TyError, node(no_wit(), TyError))
      }
      (cx, TyBool, node(no_wit(), TyBool))
    }
  }
}

test "binary checking covers the operator families" {
  let cx = test_cx()
  let l = XInt(1, 0, 1)
  let r = XInt(2, 4, 5)
  let (cx1, t1, _) = check_binary_typed(cx, OpAdd, TyInt, TyInt, l, r, 0, 1, 4, 5, 2, 3, 0, 5)
  assert t1 == TyInt
  let (cx2, t2, _) = check_binary_typed(cx, OpAdd, TyInt, TyFloat, l, r, 0, 1, 4, 5, 2, 3, 0, 5)
  assert t2 == TyError
  assert str.contains(cx2.diags[0].msg, "both sides must have the same type")
  let (cx3, t3, _) = check_binary_typed(cx, OpLt, TyInt, TyInt, l, r, 0, 1, 4, 5, 2, 3, 0, 5)
  assert t3 == TyBool
  assert len(cx3.diags) == 0
  # ordering a Bool needs an Ord impl and there is none
  let (cx4, t4, _) = check_binary_typed(cx, OpLt, TyBool, TyBool, l, r, 0, 1, 4, 5, 2, 3, 0, 5)
  assert cx4.diags[0].msg == "values of type Bool cannot be ordered"
  let (cx5, t5, _) = check_binary_typed(cx, OpConcat, TyString, TyString, l, r, 0, 1, 4, 5, 2, 3, 0, 5)
  assert t5 == TyString
  let (cx6, t6, _) = check_binary_typed(cx, OpEq,
    TyFn([], TyUnit, EPure), TyFn([], TyUnit, EPure), l, r, 0, 1, 4, 5, 2, 3, 0, 5)
  assert cx6.diags[0].msg == "functions cannot be compared"
}

## Builtins with no public spelling (docs/stdlib-naming.md): the container and
## cursor families are implementation detail behind std/map, std/set and
## std/cursor — visible when checking std itself, hidden from user code.
pub fn internal_builtins() -> Set[String] = {
  var out: Set[String] = set.empty()
  for op in ["empty", "from", "insert", "remove", "get", "has", "size", "keys", "values", "entries"] {
    out = set.insert(out, "map_" ++ op)
  }
  for op in ["empty", "from", "insert", "remove", "has", "size", "to_list"] {
    out = set.insert(out, "set_" ++ op)
  }
  for op in ["start", "end", "done", "char", "next", "prev", "slice", "skip"] {
    out = set.insert(out, "cursor_" ++ op)
  }
  set.insert(out, "index_of_from")
}

## The builtin table as visible from this module: user-code resolution skips
## the internal intrinsics (the Kotlin `builtin(name)`).
pub fn builtin_sig(cx: Cx, name: String) -> Option[Sig] = {
  let sig = match map.get(builtins(), name) {
    None -> return None
    Some(s) -> s
  }
  if not cx.is_std_module && set.has(internal_builtins(), name) { None } else { Some(sig) }
}

## The visible builtin names — the "did you mean" pool half.
## Resolution for a called/read function name: local decls → std → builtins
## (spec §10.6 — the shadowing is total in this module).
pub fn lookup_fn_sig(cx: Cx, name: String) -> Option[Sig] =
  match map.get(cx.fns, name) {
    Some(s) -> Some(s)
    None ->
      match map.get(cx.std_fns, name) {
        Some(s) -> Some(s)
        None -> builtin_sig(cx, name)
      }
  }

## The candidate pool for "did you mean" on a function name.
pub fn fn_pool(cx: Cx) -> List[String] =
  map.keys(cx.fns) ++ map.keys(cx.std_fns) ++ visible_builtin_names(cx)

pub fn visible_builtin_names(cx: Cx) -> List[String] = {
  var out: List[String] = []
  let hidden = internal_builtins()
  for n in map.keys(builtins()) {
    if cx.is_std_module || not set.has(hidden, n) { out = out ++ [n] }
  }
  out
}

test "internal builtins hide from user code but not std" {
  let user = test_cx()
  assert builtin_sig(user, "map_insert") == None
  assert builtin_sig(user, "len") != None
  let std_cx = cx_new(Some("std/map"), None)
  assert builtin_sig(std_cx, "map_insert") != None
  var has_map_insert = false
  for n in visible_builtin_names(user) {
    if n == "map_insert" { has_map_insert = true }
  }
  assert not has_map_insert
}

## return / return expr — early return from the enclosing fn (or lambda).
## The value is checked by the caller (recursion lives there); this decides the
## target type or errors. Returns Some(target) when a value should be checked
## against it, None when the return is malformed (already reported).
pub fn return_target(cx: Cx, lo: Int, hi: Int) -> (Cx, Option[Ty]) = {
  if len(cx.lambda_stack) > 0 {
    let lc = cx.lambda_stack[len(cx.lambda_stack) - 1]
    match lc.expected_ret {
      Some(t) -> (cx, Some(t))
      None -> (cerr_h(cx,
        "`return` inside a lambda needs the lambda's return type to be known from context",
        lo, hi, "make the expected function type explicit, or drop the return"), None)
    }
  } else {
    match cx.current_sig {
      None -> (cerr(cx, "`return` can only be used inside a function", lo, hi), None)
      Some(fs) ->
        if fs.inferring {
          (cerr_h(cx, "`return` needs the function's return type to be declared", lo, hi,
            "add `-> T` to fn " ++ fs.name ++ "(...)"), None)
        } else {
          (cx, Some(fs.ret))
        }
    }
  }
}

## break/continue — valid only inside a loop of the current function.
## Returns the loop's marker id (its span-lo works as identity) or -1.
pub fn check_loop_jump(cx: Cx, kw: String, lo: Int, hi: Int) -> (Cx, Bool) = {
  if len(cx.loop_stack) == 0 {
    return (cerr(cx, "`" ++ kw ++ "` can only be used inside a loop body", lo, hi), false)
  }
  let depth = cx.loop_stack[len(cx.loop_stack) - 1]
  if depth != len(cx.lambda_stack) {
    return (cerr_h(cx, "`" ++ kw ++ "` cannot cross a lambda boundary to reach the loop outside",
      lo, hi, "a lambda is its own function: use `return` to exit it, or restructure the loop"),
      false)
  }
  (Cx { ..cx, loop_jumps: set.insert(cx.loop_jumps, len(cx.loop_stack) - 1) }, true)
}

## expr? — unwrap Ok/Some or early-return the Err/None (spec §8.1).
pub fn check_propagate_typed(cx: Cx, ot: Ty, operand: TExpr, lo: Int, hi: Int) -> (Cx, Ty, TExpr) = {
  if is_errorish(ot) { return (cx, TyError, XError(lo, hi)) }
  # the node closes over the result type once it is known
  let node = fn(t: Ty) => XPropagate(operand, lo, hi, t)
  # inside a lambda, ? returns from the lambda — its return type must be known
  var sig_ret = TyError
  if len(cx.lambda_stack) > 0 {
    let lc = cx.lambda_stack[len(cx.lambda_stack) - 1]
    sig_ret = match lc.expected_ret {
      Some(t) -> t
      None -> return (cerr_h(cx,
        "`?` inside a lambda needs the lambda's return type to be known from context", lo, hi,
        "handle the Option/Result with match, or make the expected function type explicit"),
        TyError, XError(lo, hi))
    }
  } else {
    sig_ret = match cx.current_sig {
      None -> return (cerr(cx,
        "`?` can only be used inside a function that returns Option or Result", lo, hi),
        TyError, XError(lo, hi))
      Some(fs) ->
        if fs.inferring {
          return (cerr_h(cx, "`?` needs the function's return type to be declared", lo, hi,
            "add `-> Option[...]` / `-> Result[...]` to fn " ++ fs.name ++ "(...)"),
            TyError, XError(lo, hi))
        } else {
          fs.ret
        }
    }
  }
  match ot {
    TyAdt(aid, targs) -> {
      if aid == OPTION_ID {
        let ret_is_opt = match sig_ret {
          TyAdt(rid, _) -> rid == OPTION_ID
          _ -> false
        }
        if not ret_is_opt {
          return (cerr(cx,
            "`?` on an Option requires the function to return Option[...], but it returns " ++
              ty_show(cx.adts, sig_ret), lo, hi), TyError, XError(lo, hi))
        }
        return (cx, targs[0], node(targs[0]))
      }
      if aid == RESULT_ID {
        match sig_ret {
          TyAdt(rid, rargs) -> {
            if rid != RESULT_ID {
              return (cerr(cx,
                "`?` on a Result requires the function to return Result[...], but it returns " ++
                  ty_show(cx.adts, sig_ret), lo, hi), TyError, XError(lo, hi))
            }
            if rargs[1] != targs[1] {
              return (cerr_h(cx, "`?` error types differ: " ++ ty_show(cx.adts, ot) ++ " vs " ++
                  ty_show(cx.adts, sig_ret), lo, hi,
                "v0.1 has no automatic error conversion; match and rewrap the error"),
                TyError, XError(lo, hi))
            }
            return (cx, targs[0], node(targs[0]))
          }
          _ -> return (cerr(cx,
            "`?` on a Result requires the function to return Result[...], but it returns " ++
              ty_show(cx.adts, sig_ret), lo, hi), TyError, XError(lo, hi))
        }
      }
      (cerr_h(cx, "`?` needs an Option or Result, got " ++ ty_show(cx.adts, ot), lo, hi,
        "`?` unwraps an Option or Result and early-returns on None/Err; this value is neither"),
        TyError, XError(lo, hi))
    }
    _ -> (cerr_h(cx, "`?` needs an Option or Result, got " ++ ty_show(cx.adts, ot), lo, hi,
      "`?` unwraps an Option or Result and early-returns on None/Err; this value is neither"),
      TyError, XError(lo, hi))
  }
}

test "propagate demands matching option and result shapes" {
  var cx = test_cx()
  let ret_sig = Sig {
    name: "f",
    param_tys: [],
    param_names: [],
    ret: opt_ty(TyInt),
    eff: EPure,
    is_builtin: false,
    tparams: [],
    constraints: [],
    owner: None,
    trait_id: None,
    inferring: false
  }
  cx = Cx { ..cx, current_sig: Some(ret_sig) }
  let (cx1, t1, _) = check_propagate_typed(cx, opt_ty(TyString), XError(0, 1), 0, 1)
  assert t1 == TyString
  assert len(cx1.diags) == 0
  let (cx2, t2, _) = check_propagate_typed(cx, result_ty(TyInt, TyString), XError(0, 1), 0, 1)
  assert str.contains(cx2.diags[0].msg, "requires the function to return Result")
  let (cx3, t3, _) = check_propagate_typed(cx, TyInt, XError(0, 1), 0, 1)
  assert str.contains(cx3.diags[0].msg, "`?` needs an Option or Result, got Int")
}

test "loop jumps respect lambda boundaries" {
  var cx = test_cx()
  let (cx1, ok1) = check_loop_jump(cx, "break", 0, 5)
  assert not ok1
  assert cx1.diags[0].msg == "`break` can only be used inside a loop body"
  cx = Cx { ..cx, loop_stack: [0] }
  let (cx2, ok2) = check_loop_jump(cx, "break", 0, 5)
  assert ok2
  cx = Cx { ..cx, lambda_stack: [LambdaCx { boundary: 0, expected_ret: None, captures: [] }] }
  let (cx3, ok3) = check_loop_jump(cx, "continue", 0, 8)
  assert not ok3
  assert str.contains(cx3.diags[0].msg, "cannot cross a lambda boundary")
}

## expr! — Option[T] -> T, panicking on None (spec §8.2). The panic message is
## assembled by the caller (it needs source/line info); this checks the type.
pub fn check_unwrap_typed(cx: Cx, ot: Ty, operand: TExpr, msg: String, lo: Int, hi: Int) -> (Cx, Ty, TExpr) = {
  if is_errorish(ot) { return (cx, TyError, XError(lo, hi)) }
  match ot {
    TyAdt(aid, targs) ->
      if aid == OPTION_ID {
        (cx, targs[0], XUnwrap(operand, msg, lo, hi, targs[0]))
      } else {
        let hint = if aid == RESULT_ID {
          "`!` unwraps an Option; on a Result use `?` to propagate, or match the Ok/Err"
        } else {
          "`!` unwraps an Option and panics on None; this value is not an Option"
        }
        (cerr_h(cx, "`!` needs an Option, got " ++ ty_show(cx.adts, ot), lo, hi, hint),
          TyError, XError(lo, hi))
      }
    _ -> (cerr_h(cx, "`!` needs an Option, got " ++ ty_show(cx.adts, ot), lo, hi,
      "`!` unwraps an Option and panics on None; this value is not an Option"),
      TyError, XError(lo, hi))
  }
}

## xs[i] / m[k] — the asserting variants (spec §4.8). The index expression is
## checked by the caller against the wanted type this returns.
pub fn index_wanted(cx: Cx, tt: Ty, lo: Int, hi: Int) -> (Cx, Option[(Ty, Ty, Bool)]) =
  match tt {
    TyList(elem) -> (cx, Some((TyInt, elem, false)))
    TyMap(k, v) -> (cx, Some((k, v, true)))
    _ ->
      if is_errorish(tt) {
        (cx, None)
      } else {
        (cerr_h(cx, "`[]` indexes a List or Map, got " ++ ty_show(cx.adts, tt), lo, hi,
          "when absence is a normal case, use get(xs, i) / map_get(m, k) instead"), None)
      }
  }

## Record field access p.x — resolve against the record's single constructor.
pub fn check_field_access_typed(
  cx: Cx,
  tt: Ty,
  target: TExpr,
  fname: String,
  flo: Int,
  fhi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) = {
  if is_errorish(tt) { return (cx, TyError, XError(lo, hi)) }
  let bad_hint: Option[String] = match tt {
    TyAdt(aid, _) ->
      if adt_of(cx.adts, aid).is_record {
        None
      } else {
        Some("`" ++ adt_of(cx.adts, aid).name ++ "` is a sum type; destructure it with match")
      }
    _ -> None
  }
  let is_record = match tt {
    TyAdt(aid, _) -> adt_of(cx.adts, aid).is_record
    _ -> false
  }
  if not is_record {
    return (cerr_o(cx, "`.` field access needs a record value, got " ++ ty_show(cx.adts, tt),
      flo, fhi, bad_hint), TyError, XError(lo, hi))
  }
  match tt {
    TyAdt(aid, targs) -> {
      let a = adt_of(cx.adts, aid)
      let ci = a.ctors[0]
      var idx = -1
      var fty = TyError
      var i = 0
      for f in ci.fields {
        if f.name == fname {
          idx = i
          fty = f.ty
        }
        i = i + 1
      }
      if idx < 0 {
        var fnames: List[String] = []
        for f in ci.fields { fnames = fnames ++ [f.name] }
        let hint = match suggest.hint(fname, fnames) {
          Some(h) -> h
          None -> "fields: " ++ join(fnames, ", ")
        }
        return (cerr_h(cx, "`" ++ a.name ++ "` has no field `" ++ fname ++ "`", flo, fhi, hint),
          TyError, XError(lo, hi))
      }
      var m: Map[Int, Ty] = map.empty()
      var j = 0
      for tp in a.tparams {
        match tp {
          TyVar(_, vid) ->
            match get(targs, j) {
              Some(arg) -> { m = map.insert(m, vid, arg) }
              None -> ()
            }
          _ -> ()
        }
        j = j + 1
      }
      let em: Map[Int, Eff] = map.empty()
      {
        let rt = subst(fty, m, em)
        (cx, rt, XField(target, idx, lo, hi, rt))
      }
    }
    _ -> (cx, TyError, XError(lo, hi))
  }
}

test "unwrap, index, and field access resolve their shapes" {
  let cx = test_cx()
  let (cx1, t1, _) = check_unwrap_typed(cx, opt_ty(TyInt), XError(0, 1), "m", 0, 2)
  assert t1 == TyInt
  let (cx2, t2, _) = check_unwrap_typed(cx, result_ty(TyInt, TyString), XError(0, 1), "m", 0, 2)
  assert str.contains(cx2.diags[0].hint, "on a Result use `?`")
  let (cx3, w) = index_wanted(cx, TyMap(TyString, TyInt), 0, 4)
  assert w == Some((TyString, TyInt, true))
  let (cx4, w2) = index_wanted(cx, TyBool, 0, 4)
  assert w2 == None
  assert str.contains(cx4.diags[0].msg, "indexes a List or Map")
}

test "field access follows record shape with substitution" {
  # type Box[T] = { v: T } — access .v on Box[Int]
  var cx = seed_prelude(test_cx())
  let (cx0, tv) = fresh_tvar(cx, "T")
  let (cx1, aid) = fresh(cx0)
  let info = AdtI {
    id: aid,
    name: "Box",
    is_record: true,
    tparams: [tv],
    ctors: [CtorI { adt: aid, name: "Box", fields: [FieldI { name: "v", ty: tv }] }],
    derives_show: false,
    derives_ord: false,
    owner: None
  }
  cx = Cx {
    ..cx1,
    adts: map.insert(cx1.adts, aid, info),
    adts_by_name: map.insert(cx1.adts_by_name, "Box", aid)
  }
  let (cx2, t, x) = check_field_access_typed(cx, TyAdt(aid, [TyInt]), XError(0, 1), "v", 2, 3, 0, 3)
  assert t == TyInt
  assert x == XField(XError(0, 1), 0, 0, 3, TyInt)
  let (cx3, t2, _) = check_field_access_typed(cx, TyAdt(aid, [TyInt]), XError(0, 1), "w", 2, 3, 0, 3)
  assert cx3.diags[0].msg == "`Box` has no field `w`"
  # a single-character name never triggers a guess; the fields list shows instead
  assert cx3.diags[0].hint == "fields: v"
  let (cx4, t3, _) = check_field_access_typed(cx, opt_ty(TyInt), XError(0, 1), "v", 2, 3, 0, 3)
  assert str.contains(cx4.diags[0].hint, "sum type; destructure it with match")
}

# ---- pattern checking ----

## Does the pattern introduce any binding (recursively)?
pub fn binds_anything(p: Pattern) -> Bool =
  match p {
    PBind(_, _, _) -> true
    PCtor(_, pargs, _, _, _, _, _, _) -> {
      for a in pargs {
        if binds_anything(a.pat) { return true }
      }
      false
    }
    PTuple(elems, _, _) -> {
      for e in elems {
        if binds_anything(e) { return true }
      }
      false
    }
    PList(pre, _, rest_name, _, post, _, _) -> {
      match rest_name {
        Some(_) -> return true
        None -> ()
      }
      for e in pre ++ post {
        if binds_anything(e) { return true }
      }
      false
    }
    _ -> false
  }

## First refutable subpattern's span, or None if `p` always matches (spec §5.2).
pub fn refutable_part(cx: Cx, p: Pattern) -> Option[(Int, Int)] =
  match p {
    PWild(_, _) -> None
    PBind(_, _, _) -> None
    PLit(_, lo, hi) -> Some((lo, hi))
    PTuple(elems, _, _) -> {
      for e in elems {
        match refutable_part(cx, e) {
          Some(s) -> return Some(s)
          None -> ()
        }
      }
      None
    }
    PList(pre, has_rest, _, _, post, lo, hi) ->
      # only [..rest] matches every list; any fixed element constrains the length
      if has_rest && len(pre) == 0 && len(post) == 0 { None } else { Some((lo, hi)) }
    PCtor(cname, pargs, _, _, _, _, lo, hi) -> {
      match map.get(cx.ctors_by_name, cname) {
        Some(key) -> {
          let (aid, _) = key
          if len(adt_of(cx.adts, aid).ctors) > 1 { return Some((lo, hi)) }
        }
        None -> ()
      }
      for a in pargs {
        match refutable_part(cx, a.pat) {
          Some(s) -> return Some(s)
          None -> ()
        }
      }
      None
    }
  }

## Check one pattern against the scrutinee type, declaring its bindings and
## producing the typed pattern (the Kotlin checkPattern).
pub fn check_pattern(cx: Cx, p: Pattern, scrut: Ty, mutable: Bool) -> (Cx, TPat) =
  match p {
    PWild(_, _) -> (cx, TPWild)
    PBind(name, lo, hi) -> {
      let (cx1, sym) = declare(cx, name, scrut, mutable, lo, hi)
      (cx1, TPBind(sym, name))
    }
    PLit(lit, lo, hi) -> check_lit_pattern(cx, lit, scrut, lo, hi)
    PTuple(elems, lo, hi) -> {
      let matches2 = match scrut {
        TyTuple(stys) -> len(stys) == len(elems)
        _ -> false
      }
      if matches2 {
        match scrut {
          TyTuple(stys) -> {
            var cx1 = cx
            var subs: List[TPat] = []
            var i = 0
            for sub in elems {
              let (cx2, tp) = check_pattern(cx1, sub, stys[i], mutable)
              cx1 = cx2
              subs = subs ++ [tp]
              i = i + 1
            }
            (cx1, TPTuple(subs))
          }
          _ -> (cx, TPWild)
        }
      } else {
        var cx1 = cx
        if not is_errorish(scrut) {
          let is_tuple = match scrut {
            TyTuple(_) -> true
            _ -> false
          }
          let msg = match scrut {
            TyTuple(stys) -> "this pattern has " ++ to_string(len(elems)) ++
              " elements but the scrutinee is " ++ ty_show(cx1.adts, scrut)
            _ -> "tuple pattern does not match scrutinee type " ++ ty_show(cx1.adts, scrut)
          }
          let hint = match scrut {
            TyTuple(stys) -> "a tuple pattern must bind exactly " ++ to_string(len(stys)) ++
              " element(s)"
            _ -> "match a tuple pattern only against a tuple value"
          }
          cx1 = cerr_h(cx1, msg, lo, hi, hint)
        }
        var subs: List[TPat] = []
        for sub in elems {
          let (cx2, tp) = check_pattern(cx1, sub, TyError, mutable)
          cx1 = cx2
          subs = subs ++ [tp]
        }
        (cx1, TPTuple(subs))
      }
    }
    PList(pre, has_rest, rest_name, rest_span, post, lo, hi) -> {
      var cx1 = cx
      let elem = match scrut {
        TyList(e) -> e
        _ -> {
          if not is_errorish(scrut) {
            cx1 = cerr(cx1, "list pattern does not match scrutinee type " ++
                ty_show(cx1.adts, scrut), lo, hi)
          }
          TyError
        }
      }
      var pres: List[TPat] = []
      for sub in pre {
        let (cx2, tp) = check_pattern(cx1, sub, elem, mutable)
        cx1 = cx2
        pres = pres ++ [tp]
      }
      var posts: List[TPat] = []
      for sub in post {
        let (cx2, tp) = check_pattern(cx1, sub, elem, mutable)
        cx1 = cx2
        posts = posts ++ [tp]
      }
      var rest_sym: Option[Int] = None
      match rest_name {
        Some(rn) -> {
          let (rlo, rhi) = match rest_span {
            Some(s) -> s
            None -> (lo, hi)
          }
          let (cx3, sym) = declare(cx1, rn, TyList(elem), mutable, rlo, rhi)
          cx1 = cx3
          rest_sym = Some(sym)
        }
        None -> ()
      }
      (cx1, TPList(pres, has_rest, rest_sym, posts))
    }
    PCtor(cname, pargs, has_rest, has_parens, nlo, nhi, lo, hi) ->
      check_ctor_pattern(cx, cname, pargs, has_rest, has_parens, nlo, nhi, lo, hi, scrut, mutable)
  }

fn check_lit_pattern(cx: Cx, lit: Expr, scrut: Ty, lo: Int, hi: Int) -> (Cx, TPat) = {
  # the literal's own type; string patterns are interpolation-free (parser ensured)
  let (lt, lv) = match lit {
    EInt(v, _, _) -> (TyInt, LInt(v))
    EFloat(v, _, _) -> (TyFloat, LFloat(v))
    EBool(v, _, _) -> (TyBool, LBool(v))
    EStr(parts, _, _) -> {
      var s = ""
      for pt in parts {
        match pt {
          SPText(v) -> { s = s ++ v }
          _ -> ()
        }
      }
      (TyString, LStr(s))
    }
    _ -> (TyError, LInt(0))
  }
  var cx1 = cx
  if lt != scrut && not is_errorish(scrut) && not is_errorish(lt) {
    cx1 = cerr(cx1, "pattern type " ++ ty_show(cx1.adts, lt) ++
        " does not match scrutinee type " ++ ty_show(cx1.adts, scrut), lo, hi)
  }
  (cx1, TPLit(lv))
}

fn check_ctor_pattern(
  cx: Cx,
  cname: String,
  pargs: List[PatArg],
  has_rest: Bool,
  has_parens: Bool,
  nlo: Int,
  nhi: Int,
  lo: Int,
  hi: Int,
  scrut: Ty,
  mutable: Bool
) -> (Cx, TPat) = {
  var cx1 = cx
  let key = match map.get(cx1.ctors_by_name, cname) {
    None -> {
      cx1 = cerr_o(cx1, "undefined constructor in pattern: " ++ cname, nlo, nhi,
        suggest.hint(cname, map.keys(cx1.ctors_by_name)))
      # still check subpatterns so their bindings exist (as TyError)
      for a in pargs {
        let (cx2, _) = check_pattern(cx1, a.pat, TyError, mutable)
        cx1 = cx2
      }
      return (cx1, TPWild)
    }
    Some(k) -> k
  }
  let (aid, cslot) = key
  let a2 = adt_of(cx1.adts, aid)
  let ci = a2.ctors[cslot]
  let scrut_matches = match scrut {
    TyAdt(said, _) -> said == aid
    _ -> false
  }
  if not scrut_matches {
    if not is_errorish(scrut) {
      cx1 = cerr(cx1, "`" ++ cname ++ "` is a " ++ a2.name ++
          " constructor, but the scrutinee is " ++ ty_show(cx1.adts, scrut), nlo, nhi)
    }
  }
  # instantiate field types with the scrutinee's type arguments
  var inst: Map[Int, Ty] = map.empty()
  if scrut_matches {
    match scrut {
      TyAdt(_, sargs) -> {
        var i = 0
        for tp in a2.tparams {
          match tp {
            TyVar(_, vid) ->
              match get(sargs, i) {
                Some(arg) -> { inst = map.insert(inst, vid, arg) }
                None -> ()
              }
            _ -> ()
          }
          i = i + 1
        }
      }
      _ -> ()
    }
  }
  let em: Map[Int, Eff] = map.empty()
  var field_tys: List[Ty] = []
  for f in ci.fields { field_tys = field_tys ++ [subst(f.ty, inst, em)] }
  let n = len(ci.fields)
  if not has_parens && n > 0 {
    cx1 = cerr_h(cx1, "constructor `" ++ ci.name ++ "` has " ++ to_string(n) ++
        " field(s); a bare name does not match it", lo, hi,
      "write " ++ ci.name ++ "(..) to ignore the fields, or destructure them")
    for a in pargs {
      let (cx2, _) = check_pattern(cx1, a.pat, TyError, mutable)
      cx1 = cx2
    }
    return (cx1, TPWild)
  }
  var slots: List[Option[TPat]] = []
  for _i in 0 ..n { slots = slots ++ [no_tpat()] }
  var saw_named = false
  var i = 0
  for a in pargs {
    var idx = -1
    match a.name {
      Some(an) -> {
        saw_named = true
        var j = 0
        for f in ci.fields {
          if f.name == an { idx = j }
          j = j + 1
        }
        if idx < 0 {
          var fnames: List[String] = []
          for f in ci.fields { fnames = fnames ++ [f.name] }
          let hint = match suggest.hint(an, fnames) {
            Some(h) -> h
            None -> "constructor: " ++ ctor_render(cx1.adts, ci)
          }
          cx1 = cerr_h(cx1, "`" ++ ci.name ++ "` has no field `" ++ an ++ "`",
            pat_lo(a.pat), pat_hi(a.pat), hint)
          let (cx2, _) = check_pattern(cx1, a.pat, TyError, mutable)
          cx1 = cx2
          i = i + 1
          continue
        }
      }
      None -> {
        if saw_named {
          cx1 = cerr(cx1, "positional patterns cannot follow named patterns",
            pat_lo(a.pat), pat_hi(a.pat))
          let (cx2, _) = check_pattern(cx1, a.pat, TyError, mutable)
          cx1 = cx2
          i = i + 1
          continue
        }
        idx = i
        if idx >= n {
          let (cx2, _) = check_pattern(cx1, a.pat, TyError, mutable)
          cx1 = cx2
          i = i + 1
          continue
        }
      }
    }
    let already = match slots[idx] {
      Some(_) -> true
      None -> false
    }
    if already {
      cx1 = cerr(cx1, "field `" ++ ci.fields[idx].name ++ "` is matched twice",
        pat_lo(a.pat), pat_hi(a.pat))
      let (cx2, _) = check_pattern(cx1, a.pat, TyError, mutable)
      cx1 = cx2
      i = i + 1
      continue
    }
    let (cx3, tp) = check_pattern(cx1, a.pat, field_tys[idx], mutable)
    cx1 = cx3
    slots = list.take(slots, idx) ++ [Some(tp)] ++ list.drop(slots, idx + 1)
    i = i + 1
  }
  if len(pargs) > n {
    cx1 = cerr_h(cx1, "`" ++ ci.name ++ "` has " ++ to_string(n) ++ " field(s), the pattern names " ++
        to_string(len(pargs)), lo, hi, "constructor: " ++ ctor_render(cx1.adts, ci))
  } else if not has_rest {
    var missing: List[String] = []
    var k = 0
    for f in ci.fields {
      match slots[k] {
        None -> { missing = missing ++ [f.name] }
        Some(_) -> ()
      }
      k = k + 1
    }
    if len(missing) > 0 {
      cx1 = cerr_h(cx1, "pattern for `" ++ ci.name ++ "` does not mention: " ++
          join(missing, ", "), lo, hi, "add `..` to ignore the remaining fields")
    }
  }
  (cx1, TPCtor(aid, cslot, slots))
}

fn no_tpat() -> Option[TPat] = None

test "patterns bind, refute, and lower" {
  var cx = seed_prelude(push_scope(test_cx()))
  # Some(x) against Option[Int] binds x: Int
  let p = PCtor("Some", [PatArg { name: None, pat: PBind("x", 5, 6) }], false, true, 0, 4, 0, 7)
  let (cx1, tp) = check_pattern(cx, p, opt_ty(TyInt), false)
  assert len(cx1.diags) == 0
  assert sym_of(cx1, lookup(cx1, "x").expect("bound")).ty == TyInt
  match tp {
    TPCtor(aid, ci, slots) -> {
      assert aid == OPTION_ID
      assert ci == 0
      assert len(slots) == 1
    }
    _ -> { assert false }
  }
  # refutability: Some(x) is refutable, (a, b) is not, [x] is
  assert refutable_part(cx, p) != None
  let tup = PTuple([PBind("a", 0, 1), PBind("b", 3, 4)], 0, 5)
  assert refutable_part(cx, tup) == None
  assert refutable_part(cx, PList([PWild(1, 2)], false, None, None, [], 0, 3)) != None
  assert binds_anything(p)
  assert not binds_anything(PWild(0, 1))
}

test "ctor pattern field discipline" {
  var cx = seed_prelude(push_scope(test_cx()))
  # Ok(v: x, ..) on Result[Int, String]; then a missing-field case
  let good = PCtor("Ok", [PatArg { name: Some("value"), pat: PBind("x", 5, 6) }],
    false, true, 0, 2, 0, 7)
  let (cx1, _) = check_pattern(cx, good, result_ty(TyInt, TyString), false)
  assert len(cx1.diags) == 0
  let bare = PCtor("Ok", no_pargs(), false, false, 0, 2, 0, 2)
  let (cx2, _) = check_pattern(cx, bare, result_ty(TyInt, TyString), false)
  assert str.contains(cx2.diags[0].msg, "a bare name does not match it")
  let wrong = PCtor("Ok", [PatArg { name: Some("nope"), pat: PWild(5, 6) }],
    false, true, 0, 2, 0, 7)
  let (cx3, _) = check_pattern(cx, wrong, result_ty(TyInt, TyString), false)
  assert cx3.diags[0].msg == "`Ok` has no field `nope`"
  assert str.contains(cx3.diags[1].msg, "does not mention: value")
}

fn no_pargs() -> List[PatArg] = []

## Every lowercase name mentioned in call/value position — the call-graph
## over-approximation for return-type inference ordering (Kotlin nameRefs).
pub fn name_refs(e: Expr, out: Set[String]) -> Set[String] =
  match e {
    EVar(name, _, _) -> set.insert(out, name)
    ECall(callee, args, _, _, _, _) -> {
      var o = set.insert(out, callee)
      for a in args { o = name_refs(a, o) }
      o
    }
    EMethod(target, name, args, _, _, _, _) -> {
      var o = name_refs(target, set.insert(out, name))
      for a in args { o = name_refs(a, o) }
      o
    }
    EApply(target, args, _, _) -> {
      var o = name_refs(target, out)
      for a in args { o = name_refs(a, o) }
      o
    }
    ELambda(_, body, _, _) -> name_refs(body, out)
    EBlock(stmts, tail, _, _) -> {
      var o = out
      for s in stmts { o = stmt_name_refs(s, o) }
      match tail {
        Some(t) -> name_refs(t, o)
        None -> o
      }
    }
    EIf(cond, thn, els, _, _) -> {
      var o = name_refs(thn, name_refs(cond, out))
      match els {
        Some(x) -> name_refs(x, o)
        None -> o
      }
    }
    EMatch(scrut, arms, _, _) -> {
      var o = name_refs(scrut, out)
      for arm in arms {
        match arm.guard {
          Some(g) -> { o = name_refs(g, o) }
          None -> ()
        }
        o = name_refs(arm.body, o)
      }
      o
    }
    ECtor(_, cargs, spread, _, _, _, _, _) -> {
      var o = out
      match spread {
        Some(sp) -> { o = name_refs(sp, o) }
        None -> ()
      }
      for a in cargs { o = name_refs(a.e, o) }
      o
    }
    EFieldAcc(target, _, _, _, _, _) -> name_refs(target, out)
    EListLit(elems, _, _) -> {
      var o = out
      for x in elems { o = name_refs(x, o) }
      o
    }
    ETupleLit(elems, _, _) -> {
      var o = out
      for x in elems { o = name_refs(x, o) }
      o
    }
    EBinary(_, l, r, _, _, _, _) -> name_refs(r, name_refs(l, out))
    EUnary(_, operand, _, _) -> name_refs(operand, out)
    EPropagate(operand, _, _) -> name_refs(operand, out)
    EUnwrap(operand, _, _) -> name_refs(operand, out)
    EIndex(target, index, _, _) -> name_refs(index, name_refs(target, out))
    EReturn(v, _, _) ->
      match v {
        Some(x) -> name_refs(x, out)
        None -> out
      }
    EStr(parts, _, _) -> {
      var o = out
      for pt in parts {
        match pt {
          SPInterp(x) -> { o = name_refs(x, o) }
          _ -> ()
        }
      }
      o
    }
    EComptime(body, _, _) -> name_refs(body, out)
    EUnsafePure(body, _, _) -> name_refs(body, out)
    _ -> out
  }

fn stmt_name_refs(s: Stmt, out: Set[String]) -> Set[String] =
  match s {
    SLet(_, _, _, init, _, _) -> name_refs(init, out)
    SLetPat(_, _, init, _, _) -> name_refs(init, out)
    SLocalFn(_, _, _, _, body, _, _, _, _) -> name_refs(body, out)
    SAssign(_, value, _, _, _, _) -> name_refs(value, out)
    SExpr(e, _, _) -> name_refs(e, out)
    SAssert(cond, _, _, _) -> name_refs(cond, out)
    SWhile(cond, body, _, _) -> name_refs(body, name_refs(cond, out))
    SFor(_, from, to, body, _, _) -> {
      var o = name_refs(from, out)
      match to {
        Some(t) -> { o = name_refs(t, o) }
        None -> ()
      }
      name_refs(body, o)
    }
  }

test "name refs walk every call position" {
  let e = EBlock(
    [SLet("x", false, None, ECall("g", [EVar("y", 0, 1)], 0, 1, 0, 4), 0, 5)],
    Some(EMethod(EVar("m", 6, 7), "h", [ELambda(no_lparams(), EVar("z", 10, 11), 8, 12)],
      8, 9, 6, 13)),
    0,
    14
  )
  let refs = name_refs(e, set.empty())
  for n in ["g", "y", "m", "h", "z"] {
    assert set.has(refs, n)
  }
  assert not set.has(refs, "x")
}

fn no_lparams() -> List[LambdaParam] = []

# ---- module exports and imports (spec §10) ----

## The pub surface of one checked module (the Kotlin ModuleExports): carried by
## value, with the ADT/trait table fragments an importer grafts into its own
## id tables. `all_names` lets an importer tell "private" apart from "unknown".
pub type ModExports = {
  mod_path: String,
  class_name: String,
  fns: Map[String, Sig],
  types_by_name: Map[String, Int],
  aliases: Map[String, AliasE],
  # pub aliases as resolved in the declaring module (imports consume this;
  # re-resolving the target against the importer's scope would fail)
  alias_resolved: Map[String, Ty],
  ctors: Map[String, (Int, Int)],
  consts: Map[String, Ty],
  all_names: List[String],
  src_path: Option[String],
  traits_by_name: Map[String, Int],
  impls: List[ImplI],
  adt_infos: Map[Int, AdtI],
  trait_infos: Map[Int, TraitI]
}

## Resolve module imports: whole-module `use` decls become aliases; selective
## `use m.{...}` decls inject the named pub members (the Kotlin processImports).
## `env` maps modPath → exports for every module checked before this one.
pub fn pass_imports(cx: Cx, m: Module, env: Map[String, ModExports]) -> Cx = {
  var cx1 = cx
  for u in module_uses(m) {
    let exp = match map.get(env, u.path) {
      None -> {
        # std paths never reach the module loader, so unknown ones report here
        if len(u.segs) > 0 && u.segs[0] == "std" {
          var std_names: List[String] = []
          for k in map.keys(env) {
            if str.starts_with(k, "std/") { std_names = std_names ++ [k] }
          }
          cx1 = cerr_h(cx1, "no bundled std module `" ++ u.path ++ "`", u.nlo, u.nhi,
            "bundled modules: " ++ join(sort(std_names), ", "))
        }
        continue
      }
      Some(e) -> e
    }
    # graft the exporter's table fragments into this checker's id tables
    var adts2 = cx1.adts
    for k in map.keys(exp.adt_infos) {
      match map.get(exp.adt_infos, k) {
        Some(v) -> { adts2 = map.insert(adts2, k, v) }
        None -> ()
      }
    }
    var traits2 = cx1.traits
    for k in map.keys(exp.trait_infos) {
      match map.get(exp.trait_infos, k) {
        Some(v) -> { traits2 = map.insert(traits2, k, v) }
        None -> ()
      }
    }
    cx1 = Cx { ..cx1, adts: adts2, traits: traits2 }
    match u.selective {
      None -> {
        match map.get(cx1.module_aliases, u.alias_name) {
          Some(prev_path) ->
            if prev_path != exp.mod_path {
              cx1 = cerr_h(cx1, "module alias `" ++ u.alias_name ++
                  "` is imported from two modules (`" ++ prev_path ++ "` and `" ++
                  exp.mod_path ++ "`)", u.nlo, u.nhi,
                "rename with selective imports, or reorganize the modules")
            }
          None -> ()
        }
        var mfs = cx1.module_fn_sigs
        for fname in map.keys(exp.fns) {
          match map.get(exp.fns, fname) {
            Some(sig) -> { mfs = map.insert(mfs, (u.alias_name, fname), sig) }
            None -> ()
          }
        }
        cx1 = Cx {
          ..cx1,
          module_aliases: map.insert(cx1.module_aliases, u.alias_name, exp.mod_path),
          module_fn_sigs: mfs,
          module_exports: map.insert(cx1.module_exports, u.alias_name, exp)
        }
      }
      Some(names) -> {
        for imp in names {
          cx1 = inject_selective(cx1, u.path, exp, imp.name, imp.lo, imp.hi)
        }
      }
    }
  }
  cx1
}

fn inject_selective(
  cx: Cx,
  from_path: String,
  exp: ModExports,
  name: String,
  lo: Int,
  hi: Int
) -> Cx = {
  var cx1 = cx
  let f = map.get(exp.fns, name)
  let ty = map.get(exp.types_by_name, name)
  let cn = map.get(exp.consts, name)
  let ct = map.get(exp.ctors, name)
  let al = map.get(exp.aliases, name)
  let tr = map.get(exp.traits_by_name, name)
  let nothing = f == None && ty == None && cn == None && ct == None && al == None && tr == None
  if nothing {
    var known = false
    for n in exp.all_names {
      if n == name { known = true }
    }
    if known {
      return cerr_h(cx1, "`" ++ name ++ "` is private to module `" ++ from_path ++ "`",
        lo, hi, "add `pub` to its declaration in " ++ from_path)
    }
    let pool = map.keys(exp.fns) ++ map.keys(exp.types_by_name) ++ map.keys(exp.consts) ++
      map.keys(exp.ctors) ++ map.keys(exp.traits_by_name)
    return cerr_o(cx1, "module `" ++ from_path ++ "` has no exported name `" ++ name ++ "`",
      lo, hi, suggest.hint(name, pool))
  }
  match map.get(cx1.imported_names, name) {
    Some(prev) ->
      return cerr(cx1, "`" ++ name ++ "` is imported more than once (from `" ++ prev ++
          "` and `" ++ from_path ++ "`)", lo, hi)
    None -> ()
  }
  cx1 = Cx { ..cx1, imported_names: map.insert(cx1.imported_names, name, from_path) }
  match f {
    Some(sig) -> { cx1 = Cx { ..cx1, fns: map.insert(cx1.fns, name, sig) } }
    None -> ()
  }
  # a type brings its constructors (spec §10.3); a ctor may also be named directly
  match ty {
    Some(aid) -> {
      var cbn = cx1.ctors_by_name
      let a = adt_of(cx1.adts, aid)
      var i = 0
      for c in a.ctors {
        cbn = map.insert(cbn, c.name, (aid, i))
        i = i + 1
      }
      cx1 = Cx {
        ..cx1,
        adts_by_name: map.insert(cx1.adts_by_name, name, aid),
        ctors_by_name: cbn
      }
    }
    None -> ()
  }
  match al {
    Some(ae) -> {
      cx1 = Cx { ..cx1, aliases: map.insert(cx1.aliases, name, AliasE { ..ae, target: no_tref() }) }
      match map.get(exp.alias_resolved, name) {
        Some(t) -> {
          cx1 = Cx { ..cx1, alias_resolved: map.insert(cx1.alias_resolved, name, t) }
        }
        None -> ()
      }
    }
    None -> ()
  }
  match ct {
    Some(k) -> { cx1 = Cx { ..cx1, ctors_by_name: map.insert(cx1.ctors_by_name, name, k) } }
    None -> ()
  }
  match cn {
    Some(t) -> {
      cx1 = Cx {
        ..cx1,
        consts: map.insert(cx1.consts, name, t),
        const_order: cx1.const_order ++ [name]
      }
    }
    None -> ()
  }
  match tr {
    Some(tid) -> { cx1 = Cx { ..cx1, traits_by_name: map.insert(cx1.traits_by_name, name, tid) } }
    None -> ()
  }
  cx1
}

# ---- effect isolation frames ----

## Saved effect state around an isolated body (comptime blocks, const
## initializers, unsafe_pure). The Kotlin originals save/restore the checker's
## mutable members; here the frame is just the old values.
pub type EffFrame = {
  used: List[Eff],
  witness: Map[Eff, (Int, Int, String)],
  sig: Option[Sig],
  dicts: Map[(Int, Int), Int],
  scopes: List[Map[String, Int]],
  lambdas: List[LambdaCx],
  loops: List[Int]
}

## Enter a comptime-style isolated context: fresh scope, no enclosing function,
## empty effect record (the Kotlin checkComptimeBody's prologue).
pub fn enter_isolated(cx: Cx) -> (Cx, EffFrame) = {
  let frame = EffFrame {
    used: cx.used_effects,
    witness: cx.eff_witness,
    sig: cx.current_sig,
    dicts: cx.dict_syms,
    scopes: cx.scopes,
    lambdas: cx.lambda_stack,
    loops: cx.loop_stack
  }
  let empty_w: Map[Eff, (Int, Int, String)] = map.empty()
  let empty_d: Map[(Int, Int), Int] = map.empty()
  let fresh_scope: Map[String, Int] = map.empty()
  (Cx {
    ..cx,
    used_effects: [],
    eff_witness: empty_w,
    current_sig: None,
    dict_syms: empty_d,
    scopes: [fresh_scope],
    lambda_stack: [],
    loop_stack: []
  }, frame)
}

## Leave the isolated context: every effect the body used is an error (`what`
## names the construct), then the frame is restored.
pub fn leave_isolated(cx: Cx, frame: EffFrame, what: String, blo: Int, bhi: Int) -> Cx = {
  var cx1 = cx
  for used in cx.used_effects {
    let (wlo, whi, name) = match map.get(cx.eff_witness, used) {
      Some(w) -> w
      None -> (blo, bhi, "?")
    }
    cx1 = cerr_h(cx1, what ++ " must be pure, but `" ++ name ++ "` is !" ++ eff_show(used),
      wlo, whi, "compile-time evaluation cannot perform io (spec §7.2)")
  }
  Cx {
    ..cx1,
    used_effects: frame.used,
    eff_witness: frame.witness,
    current_sig: frame.sig,
    dict_syms: frame.dicts,
    scopes: frame.scopes,
    lambda_stack: frame.lambdas,
    loop_stack: frame.loops
  }
}

## Render one effect for messages ("io", "e", "(e1|e2)").
fn eff_show(e: Eff) -> String =
  match e {
    EPure -> ""
    EIo -> "io"
    EffVar(n, _) -> n
    EUnion(vs) -> {
      var names: List[String] = []
      for v in vs {
        let (_, n) = v
        names = names ++ [n]
      }
      "(" ++ join(sort(names), "|") ++ ")"
    }
  }

test "isolated contexts capture and report their effects" {
  var cx = test_cx()
  cx = Cx { ..cx, used_effects: [EIo] }
  let (cx1, frame) = enter_isolated(cx)
  assert len(cx1.used_effects) == 0
  # the body records io
  let cx2 = record_effect(cx1, EIo, 5, 8, "println")
  let cx3 = leave_isolated(cx2, frame, "const initializers", 0, 10)
  assert len(cx3.diags) == 1
  assert cx3.diags[0].msg == "const initializers must be pure, but `println` is !io"
  # the outer effect record is restored
  assert cx3.used_effects == [EIo]
}

## Does this expression need an expected type to check at all? (drives the
## two-round argument checking; the Kotlin needsExpected.)
pub fn needs_expected(cx: Cx, e: Expr) -> Bool =
  match e {
    EListLit(elems, _, _) -> {
      if len(elems) == 0 { return true }
      for x in elems {
        if not needs_expected(cx, x) { return false }
      }
      true
    }
    ETupleLit(elems, _, _) -> {
      for x in elems {
        if needs_expected(cx, x) { return true }
      }
      false
    }
    # a generic function used as a value is instantiated from the expected type
    EVar(name, _, _) -> {
      match lookup(cx, name) {
        Some(_) -> return false
        None -> ()
      }
      match lookup_fn_sig(cx, name) {
        Some(s) -> len(s.tparams) > 0
        None -> false
      }
    }
    ECtor(cname, cargs, spread, has_parens, _, _, _, _) ->
      match map.get(cx.ctors_by_name, cname) {
        None -> false
        Some(key) -> {
          let (aid, cslot) = key
          let a = adt_of(cx.adts, aid)
          let ci = a.ctors[cslot]
          # bare nullary generic ctor (None): element type comes from expected;
          # bare ctor-with-fields as a fn value (Some): needs the expected fn type
          (len(ci.fields) == 0 && len(a.tparams) > 0) ||
            (not has_parens && len(ci.fields) > 0 && not a.is_record)
        }
      }
    ELambda(params, _, _, _) -> {
      for p in params {
        match p.ann {
          None -> return true
          Some(_) -> ()
        }
      }
      false
    }
    # a zero-arg generic call (map_empty()) can only be typed from context
    ECall(callee, args, _, _, _, _) -> {
      match lookup(cx, callee) {
        Some(_) -> return false
        None -> ()
      }
      match lookup_fn_sig(cx, callee) {
        Some(s) -> len(s.tparams) > 0 && len(args) == 0
        None -> false
      }
    }
    # same for its module-qualified spelling (map.empty(), spec §10.3) — needs
    # the import env, resolved by the caller via a pre-filled table; here the
    # alias fns live in cx via pass_imports' std handling at check time
    EMethod(target, name, args, _, _, _, _) ->
      match target {
        EVar(rname, _, _) -> {
          match lookup(cx, rname) {
            Some(_) -> return false
            None -> ()
          }
          match map.get(cx.module_fn_sigs, (rname, name)) {
            Some(s) -> len(s.tparams) > 0 && len(args) == 0
            None -> false
          }
        }
        _ -> false
      }
    _ -> false
  }

## A top-level function or builtin used as a value; generics need the expected
## type (the Kotlin checkFnValue).
pub fn check_fn_value(
  cx: Cx,
  name: String,
  f: Sig,
  expected: Option[Ty],
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) = {
  var has_bounds = false
  for bs in f.constraints {
    if len(bs) > 0 { has_bounds = true }
  }
  if has_bounds {
    let ps = join(f.param_names, ", ")
    let msg = match f.trait_id {
      Some(_) -> "trait method `" ++ name ++ "` cannot be used as a value"
      None -> "`" ++ name ++ "` has trait bounds and cannot be used as a value"
    }
    return (cerr_h(cx, msg, lo, hi,
      "wrap it in a lambda: fn(" ++ ps ++ ") => " ++ name ++ "(" ++ ps ++ ")"),
      TyError, XError(lo, hi))
  }
  let declared = TyFn(f.param_tys, f.ret, f.eff)
  let eff_is_var = match f.eff {
    EffVar(_, _) -> true
    _ -> false
  }
  let node = fn(t: Ty) => XFnValue(f.owner, name, f.is_builtin, t, lo, hi)
  if len(f.tparams) == 0 && not eff_is_var {
    return (cx, declared, node(declared))
  }
  let exp: Option[(List[Ty], Ty, Eff)] = match expected {
    Some(TyFn(eps, eret, eeff)) ->
      if len(eps) == len(f.param_tys) { Some((eps, eret, eeff)) } else { None }
    _ -> None
  }
  let (eps, eret, eeff) = match exp {
    None ->
      return (cerr_h(cx, "cannot infer the type parameter(s) of `" ++ name ++
          "` used as a value here", lo, hi,
        "wrap it in a lambda with annotated parameters: fn(x: Int) => " ++ name ++ "(x)"),
        TyError, XError(lo, hi))
    Some(v) -> v
  }
  var m: Map[Int, Ty] = map.empty()
  var em: Map[Int, Eff] = map.empty()
  var i = 0
  for d in f.param_tys {
    let a = eps[i]
    if is_concrete(cx, a) {
      let (m2, em2, _) = unify_into(cx, d, a, m, em)
      m = m2
      em = em2
    }
    i = i + 1
  }
  if is_concrete(cx, eret) {
    let (m3, em3, _) = unify_into(cx, f.ret, eret, m, em)
    m = m3
    em = em3
  }
  var unbound: List[String] = []
  for tp in f.tparams {
    match tp {
      TyVar(n, vid) -> if not map.has(m, vid) { unbound = unbound ++ [n] }
      _ -> ()
    }
  }
  if len(unbound) > 0 {
    return (cerr_h(cx, "cannot infer type parameter(s) " ++ join(unbound, ", ") ++ " for `" ++
        name ++ "` used as a value", lo, hi, "wrap it in a lambda with annotated parameters"),
      TyError, XError(lo, hi))
  }
  match f.eff {
    EffVar(_, eid) -> if not map.has(em, eid) { em = map.insert(em, eid, eeff) }
    _ -> ()
  }
  var cx1 = cx
  if f.is_builtin && name == "to_string" {
    let t0 = match f.tparams[0] {
      TyVar(_, vid) ->
        match map.get(m, vid) {
          Some(t) -> t
          None -> TyError
        }
      _ -> TyError
    }
    if not is_showable(cx1, t0) && not is_errorish(t0) {
      cx1 = cerr_h(cx1, "cannot print a value of type " ++ ty_show(cx1.adts, t0), lo, hi,
        show_hint(cx1, t0))
    }
  }
  let inst = subst(declared, m, em)
  (cx1, inst, node(inst))
}

test "fn values instantiate from the expected type" {
  let cx = test_cx()
  let bs = builtins()
  # len: List[T] -> Int as a value with expected fn(List[Int]) -> Int
  let len_sig = map.get(bs, "len").expect("len")
  let (cx1, t1, _) = check_fn_value(cx, "len", len_sig,
    Some(TyFn([TyList(TyInt)], TyInt, EPure)), 0, 3)
  assert len(cx1.diags) == 0
  assert t1 == TyFn([TyList(TyInt)], TyInt, EPure)
  # without context the generic cannot instantiate
  let (cx2, t2, _) = check_fn_value(cx, "len", len_sig, None, 0, 3)
  assert str.contains(cx2.diags[0].msg, "cannot infer the type parameter(s) of `len`")
  # a bounded sig refuses to be a value (no table builtin carries bounds since
  # the ordering family moved to std/list, so the exemplar is hand-built)
  let tv = TyVar("T", 0)
  let bounded = Sig {
    name: "sortish", param_tys: [TyList(tv)], param_names: ["xs"], ret: TyList(tv),
    eff: EPure, is_builtin: true, tparams: [tv], constraints: [[ORD_ID]],
    owner: None, trait_id: None, inferring: false
  }
  let (cx3, t3, _) = check_fn_value(cx, "sortish", bounded, None, 0, 4)
  assert cx3.diags[0].msg == "`sortish` has trait bounds and cannot be used as a value"
  # a non-generic sig passes through untouched
  let join_sig = map.get(bs, "join").expect("join")
  let (cx4, t4, _) = check_fn_value(cx, "join", join_sig, None, 0, 4)
  assert t4 == TyFn([TyList(TyString), TyString], TyString, EPure)
}

## A constructor used bare as a function value: `map(xs, Some)`. Generics come
## from the expected fn type (the Kotlin checkCtorValue).
pub fn check_ctor_value(
  cx: Cx,
  aid: Int,
  cslot: Int,
  eps: List[Ty],
  eret: Ty,
  eeff: Eff,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) = {
  let a = adt_of(cx.adts, aid)
  let ci = a.ctors[cslot]
  var params: List[Ty] = []
  for f in ci.fields { params = params ++ [f.ty] }
  let ret = adt_self_ty(a)
  let node = fn(t: Ty) => XCtorValue(aid, cslot, lo, hi, t)
  if len(eps) != len(params) {
    return (cerr_h(cx, "`" ++ ci.name ++ "` takes " ++ to_string(len(params)) ++
        " field(s), but " ++ ty_show(cx.adts, TyFn(eps, eret, eeff)) ++ " is expected", lo, hi,
      "constructor: " ++ ctor_render(cx.adts, ci)), TyError, XError(lo, hi))
  }
  if len(a.tparams) == 0 {
    let t0 = TyFn(params, ret, EPure)
    return (cx, t0, node(t0))
  }
  var m: Map[Int, Ty] = map.empty()
  var em: Map[Int, Eff] = map.empty()
  var i = 0
  for d in params {
    let arg = eps[i]
    if is_concrete(cx, arg) {
      let (m2, em2, _) = unify_into(cx, d, arg, m, em)
      m = m2
      em = em2
    }
    i = i + 1
  }
  if is_concrete(cx, eret) {
    let (m3, em3, _) = unify_into(cx, ret, eret, m, em)
    m = m3
    em = em3
  }
  var unbound: List[String] = []
  for tp in a.tparams {
    match tp {
      TyVar(n, vid) -> if not map.has(m, vid) { unbound = unbound ++ [n] }
      _ -> ()
    }
  }
  if len(unbound) > 0 {
    return (cerr_h(cx, "cannot infer type parameter(s) " ++ join(unbound, ", ") ++ " for `" ++
        ci.name ++ "` used as a value", lo, hi,
      "annotate the surrounding context, or wrap it in a lambda"), TyError, XError(lo, hi))
  }
  var ips: List[Ty] = []
  for d in params { ips = ips ++ [subst(d, m, em)] }
  let t1 = TyFn(ips, subst(ret, m, em), EPure)
  (cx, t1, node(t1))
}

## Satisfy one trait requirement at a use site (the general resolveWitness):
## rigid type parameter → the caller's dictionary is forwarded (and captured by
## every enclosing lambda); concrete subject → coherence gives the unique impl.
pub fn resolve_witness(
  cx: Cx,
  trait_id: Int,
  t: Ty,
  lo: Int,
  hi: Int,
  requirer: String
) -> (Cx, Option[WitRef]) = {
  if is_errorish(t) { return (cx, no_wit()) }
  let tr = trait_of(cx.traits, trait_id)
  match t {
    TyVar(_, vid) ->
      match map.get(cx.dict_syms, (vid, trait_id)) {
        None -> {
          let ts = ty_show(cx.adts, t)
          (cerr_h(cx, requirer ++ " requires `" ++ tr.name ++ "[" ++ ts ++ "]`, but `" ++
              ts ++ "` has no such bound", lo, hi,
            "add the bound: [" ++ ts ++ ": " ++ tr.name ++ "]"), no_wit())
        }
        Some(sym) -> {
          var stack: List[LambdaCx] = []
          for lc in cx.lambda_stack {
            var caps = lc.captures
            var have = false
            for c in caps {
              if c == sym { have = true }
            }
            if not have { caps = caps ++ [sym] }
            stack = stack ++ [LambdaCx { ..lc, captures: caps }]
          }
          (Cx { ..cx, lambda_stack: stack }, Some(WForward(sym)))
        }
      }
    _ ->
      match map.get(cx.impl_table, (trait_id, t)) {
        Some(_) -> (cx, Some(WConcrete(trait_id, t)))
        None -> {
          let ts = ty_show(cx.adts, t)
          let hint = if trait_id == ORD_ID && not is_adt(t) {
            "only Int, Float, String and types with an `impl Ord` can be ordered"
          } else if is_nongeneric_adt(cx, t) {
            "define `impl " ++ tr.name ++ "[" ++ ts ++ "] { ... }` in the module declaring `" ++
              ts ++ "` or `" ++ tr.name ++ "`"
          } else if t == TyInt || t == TyFloat || t == TyBool || t == TyString {
            "define `impl " ++ tr.name ++ "[" ++ ts ++ "] { ... }` in the module declaring `" ++
              tr.name ++ "`"
          } else {
            "v1 impl subjects are named non-generic types and Int/Float/Bool/String"
          }
          (cerr_h(cx, "no impl of `" ++ tr.name ++ "` for `" ++ ts ++ "`", lo, hi, hint), no_wit())
        }
      }
  }
}

fn is_adt(t: Ty) -> Bool =
  match t {
    TyAdt(_, _) -> true
    _ -> false
  }

fn is_nongeneric_adt(cx: Cx, t: Ty) -> Bool =
  match t {
    TyAdt(aid, _) -> len(adt_of(cx.adts, aid).tparams) == 0
    _ -> false
  }

test "ctor values and witnesses" {
  var cx = seed_prelude(test_cx())
  # Some as fn(Int) -> Option[Int]
  let (cx1, t1, _) = check_ctor_value(cx, OPTION_ID, 0, [TyInt], opt_ty(TyInt), EPure, 0, 4)
  assert len(cx1.diags) == 0
  assert t1 == TyFn([TyInt], opt_ty(TyInt), EPure)
  # arity mismatch reports with the ctor render
  let (cx2, t2, _) = check_ctor_value(cx, OPTION_ID, 0, [TyInt, TyInt], TyUnit, EPure, 0, 4)
  assert str.contains(cx2.diags[0].msg, "`Some` takes 1 field(s)")
  # witness: Int has a prelude Ord impl, Bool does not
  let (cx3, ok3) = resolve_witness(cx, ORD_ID, TyInt, 0, 4, "`sort`")
  assert ok3 == Some(WConcrete(ORD_ID, TyInt))
  let (cx4, ok4) = resolve_witness(cx, ORD_ID, TyBool, 0, 4, "`sort`")
  assert ok4 == None
  assert cx4.diags[0].msg == "no impl of `Ord` for `Bool`"
  # Ord over a non-ADT gets the ordering-specific hint (the Kotlin implHint order)
  assert cx4.diags[0].hint == "only Int, Float, String and types with an `impl Ord` can be ordered"
}

# ---- the recursive expression checker (pass 5 core) ----

## Check one expression against an optional expected type (the Kotlin
## checkExpr/inferExpr pair). Returns (state, type, typed node).
pub fn check_expr(cx: Cx, e: Expr, expected: Option[Ty]) -> (Cx, Ty, TExpr) !io =
  match e {
    EInt(v, lo, hi) -> (cx, TyInt, XInt(v, lo, hi))
    EFloat(v, lo, hi) -> (cx, TyFloat, XFloat(v, lo, hi))
    EBool(v, lo, hi) -> (cx, TyBool, XBool(v, lo, hi))
    EUnit(lo, hi) -> (cx, TyUnit, XUnit(lo, hi))
    EStr(parts, lo, hi) -> {
      var cx1 = cx
      var tparts: List[TStrPart] = []
      for pt in parts {
        match pt {
          SPText(v) -> { tparts = tparts ++ [TSPText(v)] }
          SPInterp(x) -> {
            let (cx2, t, tx) = check_expr(cx1, x, no_expected())
            cx1 = cx2
            if not is_showable(cx1, t) && not is_errorish(t) {
              cx1 = cerr_h(cx1, "cannot interpolate a value of type " ++ ty_show(cx1.adts, t),
                e_lo(x), e_hi(x), show_hint(cx1, t))
            }
            tparts = tparts ++ [TSPInterp(tx)]
          }
        }
      }
      (cx1, TyString, XStr(tparts, lo, hi))
    }
    EVar(name, lo, hi) -> check_var(cx, name, expected, lo, hi)
    EUnary(op, operand, lo, hi) -> {
      let (cx1, t, tx) = check_expr(cx, operand, no_expected())
      check_unary(cx1, op, t, tx, e_lo(operand), e_hi(operand), lo, hi)
    }
    EBinary(op, left, right, olo, ohi, lo, hi) -> {
      let (cx1, lt, lx) = check_expr(cx, left, no_expected())
      # == seeds the right side with the left side's type
      let eq_like = op == OpEq || op == OpNeq
      let rexp: Option[Ty] = if eq_like && is_concrete(cx1, lt) { Some(lt) } else { None }
      let (cx2, rt, rx) = check_expr(cx1, right, rexp)
      check_binary_typed(cx2, op, lt, rt, lx, rx,
        e_lo(left), e_hi(left), e_lo(right), e_hi(right), olo, ohi, lo, hi)
    }
    EIf(cond, thn, els, lo, hi) -> {
      let (cx1, ct, cndx) = check_expr(cx, cond, no_expected())
      var cx2 = cx1
      if ct != TyBool && not is_errorish(ct) {
        cx2 = cerr(cx2, "if condition must be Bool, got " ++ ty_show(cx2.adts, ct),
          e_lo(cond), e_hi(cond))
      }
      let (cx3, tt, thnx) = check_expr(cx2, thn, expected)
      match els {
        None -> {
          # no else: statement position only, branch must be Unit
          var cx4 = cx3
          if tt != TyUnit && not is_errorish(tt) {
            cx4 = cerr_h(cx4, "an if without else is a statement, so its branch must be Unit (got " ++
                ty_show(cx4.adts, tt) ++ ")", e_lo(thn), e_hi(thn),
              "add an else branch to produce a value")
          }
          (cx4, TyUnit, XIf(cndx, thnx, None, lo, hi, TyUnit))
        }
        Some(eb) -> {
          let (cx4, et, ex) = check_expr(cx3, eb, expected)
          let (cx5, t) = unify_branches(cx4, tt, et, lo, hi, "the if branches")
          (cx5, t, XIf(cndx, thnx, Some(ex), lo, hi, t))
        }
      }
    }
    EListLit(elems, lo, hi) -> {
      let expected_elem: Option[Ty] = match expected {
        Some(TyList(el)) -> if is_concrete(cx, el) { Some(el) } else { None }
        _ -> None
      }
      if len(elems) == 0 {
        match expected_elem {
          Some(el) -> return (cx, TyList(el), XListLit([], lo, hi, TyList(el)))
          None -> return (cerr_h(cx, "cannot infer the element type of an empty list", lo, hi,
            "add a type annotation: let xs: List[Int] = []"), TyError, XError(lo, hi))
        }
      }
      var elem_t = match expected_elem {
        Some(el) -> el
        None -> TyNever
      }
      # inference-needing elements (bare None, nested []) go last; the typed
      # nodes must come back in source order
      var order: List[Int] = []
      var i = 0
      for x in elems {
        if not needs_expected(cx, x) { order = order ++ [i] }
        i = i + 1
      }
      i = 0
      for x in elems {
        if needs_expected(cx, x) { order = order ++ [i] }
        i = i + 1
      }
      var cx1 = cx
      var slots: List[Option[TExpr]] = []
      for _j in 0 ..len(elems) { slots = slots ++ [no_texpr()] }
      for idx in order {
        let x = elems[idx]
        let el_exp: Option[Ty] =
          if elem_t != TyNever && is_concrete(cx1, elem_t) { Some(elem_t) } else { None }
        let (cx2, t, tx) = check_expr(cx1, x, el_exp)
        cx1 = cx2
        let (cx3, unified) = unify_branches(cx1, elem_t, t, e_lo(x), e_hi(x), "the list elements")
        cx1 = cx3
        elem_t = unified
        slots = list.take(slots, idx) ++ [Some(tx)] ++ list.drop(slots, idx + 1)
      }
      var txs: List[TExpr] = []
      for s in slots {
        match s {
          Some(tx) -> { txs = txs ++ [tx] }
          None -> { txs = txs ++ [XError(lo, hi)] }
        }
      }
      (cx1, TyList(elem_t), XListLit(txs, lo, hi, TyList(elem_t)))
    }
    ETupleLit(elems, lo, hi) -> {
      let exps: Option[List[Ty]] = match expected {
        Some(TyTuple(ets)) -> Some(ets)
        _ -> None
      }
      var cx1 = cx
      var tys: List[Ty] = []
      var txs: List[TExpr] = []
      var i = 0
      for x in elems {
        let el_exp: Option[Ty] = match exps {
          Some(ets) ->
            match get(ets, i) {
              Some(et) -> if is_concrete(cx1, et) { Some(et) } else { None }
              None -> None
            }
          None -> None
        }
        let (cx2, t, tx) = check_expr(cx1, x, el_exp)
        cx1 = cx2
        if t == TyUnit {
          cx1 = cerr(cx1, "tuple elements cannot be Unit", e_lo(x), e_hi(x))
          tys = tys ++ [TyError]
        } else {
          tys = tys ++ [t]
        }
        txs = txs ++ [tx]
        i = i + 1
      }
      (cx1, TyTuple(tys), XTupleLit(txs, lo, hi, TyTuple(tys)))
    }
    EPropagate(operand, lo, hi) -> {
      let (cx1, ot, ox) = check_expr(cx, operand, no_expected())
      check_propagate_typed(cx1, ot, ox, lo, hi)
    }
    EUnwrap(operand, lo, hi) -> {
      let (cx1, ot, ox) = check_expr(cx, operand, no_expected())
      let msg = unwrap_msg(cx1, operand, lo, hi)
      check_unwrap_typed(cx1, ot, ox, msg, lo, hi)
    }
    EIndex(target, index, lo, hi) -> {
      let (cx1, tt, tx) = check_expr(cx, target, no_expected())
      let (cx2, wanted) = index_wanted(cx1, tt, lo, hi)
      match wanted {
        None -> {
          let (cx3, _, ix) = check_expr(cx2, index, no_expected())
          (cx3, TyError, XError(lo, hi))
        }
        Some(w) -> {
          let (want_idx, result, on_map) = w
          let (cx3, it, ix) = check_expr(cx2, index, Some(want_idx))
          var cx4 = cx3
          if it != want_idx && not is_errorish(it) {
            if on_map {
              cx4 = cerr(cx4, "this Map has keys of type " ++ ty_show(cx4.adts, want_idx) ++
                  ", got " ++ ty_show(cx4.adts, it), e_lo(index), e_hi(index))
            } else {
              cx4 = cerr(cx4, "a List index must be Int, got " ++ ty_show(cx4.adts, it),
                e_lo(index), e_hi(index))
            }
            (cx4, TyError, XError(lo, hi))
          } else {
            (cx4, result, XIndex(tx, ix, on_map, lo, hi, result))
          }
        }
      }
    }
    EReturn(v, lo, hi) -> {
      let (cx1, target) = return_target(cx, lo, hi)
      match target {
        None -> {
          match v {
            Some(x) -> {
              let (cx2, _, _) = check_expr(cx1, x, no_expected())
              (cx2, TyError, XError(lo, hi))
            }
            None -> (cx1, TyError, XError(lo, hi))
          }
        }
        Some(t) -> {
          let (cx2, vt, vx) = match v {
            Some(x) -> {
              let (cxa, xt, xx) = check_expr(cx1, x, Some(t))
              (cxa, xt, Some(xx))
            }
            None -> (cx1, TyUnit, no_texpr())
          }
          var cx3 = cx2
          if not assignable(cx3, vt, t) {
            let (slo, shi) = match v {
              Some(x) -> (e_lo(x), e_hi(x))
              None -> (lo, hi)
            }
            cx3 = cerr(cx3, "`return` type mismatch: this function returns " ++
                ty_show(cx3.adts, t) ++ ", got " ++ ty_show(cx3.adts, vt), slo, shi)
          }
          (cx3, TyNever, XReturn(vx, lo, hi))
        }
      }
    }
    EBreak(lo, hi) -> {
      let (cx1, ok) = check_loop_jump(cx, "break", lo, hi)
      if ok { (cx1, TyNever, XBreak(lo, hi)) } else { (cx1, TyError, XError(lo, hi)) }
    }
    EContinue(lo, hi) -> {
      let (cx1, ok) = check_loop_jump(cx, "continue", lo, hi)
      if ok { (cx1, TyNever, XContinue(lo, hi)) } else { (cx1, TyError, XError(lo, hi)) }
    }
    EBlock(stmts, tail, lo, hi) -> check_block(cx, stmts, tail, expected, lo, hi)
    EComptime(body, lo, hi) -> {
      let (cx1, frame) = enter_isolated(cx)
      let (cx2, t, bx) = check_expr(cx1, body, expected)
      let cx3 = leave_isolated(cx2, frame, "comptime blocks", e_lo(body), e_hi(body))
      if not is_const_serializable(cx3, t, set.empty()) && not is_errorish(t) {
        (cerr_h(cx3, "a comptime result must be constant-serializable, got " ++
            ty_show(cx3.adts, t), lo, hi,
          "Int/Float/Bool/String and List/tuple/record/ADT values of them (spec §7.2)"),
          TyError, XError(lo, hi))
      } else {
        (cx3, t, XComptime(bx, lo, hi, t))
      }
    }
    EUnsafePure(body, lo, hi) -> check_unsafe_pure(cx, body, expected, lo, hi)
    ECall(callee, args, clo, chi, lo, hi) ->
      check_call(cx, callee, args, expected, None, no_sig(), clo, chi, lo, hi)
    ECtor(cname, cargs, spread, has_parens, cclo, cchi, lo, hi) ->
      check_ctor_call(cx, cname, cargs, spread, has_parens, expected, cclo, cchi, lo, hi)
    ELambda(params, body, lo, hi) -> check_lambda(cx, params, body, expected, lo, hi)
    EApply(target, args, lo, hi) -> check_apply(cx, target, args, lo, hi)
    EMethod(target, name, args, nlo, nhi, lo, hi) ->
      check_method_call(cx, target, name, args, expected, nlo, nhi, lo, hi)
    EFieldAcc(target, fname, flo, fhi, lo, hi) ->
      match static_field_target(cx, target) {
        # Class.FIELD reads a public static field (spec §9.1) — the receiver is a
        # java class name (a nullary ctor spelling), not an evaluable expression
        Some(fq) -> check_java_static_field(cx, fq, fname, flo, fhi, lo, hi)
        None -> {
          let (cx1, tt, tx) = check_expr(cx, target, no_expected())
          check_field_access_typed(cx1, tt, tx, fname, flo, fhi, lo, hi)
        }
      }
    EMatch(scrut, arms, lo, hi) -> check_match(cx, scrut, arms, expected, lo, hi)
  }

fn no_expected() -> Option[Ty] = None

fn no_texpr() -> Option[TExpr] = None

fn no_sig() -> Option[Sig] = None

## The panic message for `expr!` (the Kotlin unwrapMsg): names the producing
## call and the site, since codegen has neither source text nor line numbers.
fn unwrap_msg(cx: Cx, operand: Expr, lo: Int, hi: Int) -> String = {
  var msg = "unwrapped None"
  let desc: Option[String] = match operand {
    EMethod(recv, mname, _, _, _, _, _) ->
      match recv {
        ECtor(rname, _, _, _, _, _, _, _) -> Some(rname ++ "." ++ mname ++ "()")
        EVar(rname, _, _) -> Some(rname ++ "." ++ mname ++ "()")
        _ -> Some(mname ++ "()")
      }
    ECall(callee, _, _, _, _, _) -> Some(callee ++ "()")
    _ -> None
  }
  match desc {
    Some(d) -> { msg = msg ++ " from " ++ d }
    None -> ()
  }
  match cx.src_path {
    Some(p) -> { msg = msg ++ " at " ++ p ++ ":" ++ to_string(line_of(cx, lo)) }
    None -> ()
  }
  msg
}

## 1-based line number of a UTF-16 offset in the current source (set by the
## driver; the Kotlin SourceFile.lineOf).
fn line_of(cx: Cx, off: Int) -> Int = {
  var line = 1
  for s in cx.line_starts {
    if s <= off && s > 0 { line = line + 1 }
  }
  line
}

# ---- name resolution with capture bookkeeping ----

fn no_int() -> Option[Int] = None

fn no_wit() -> Option[WitRef] = None

fn no_tref() -> Option[TypeRef] = None

fn no_ty2() -> Option[Ty] = None

fn no_msigs(n: Int) -> List[Option[Sig]] = {
  var out: List[Option[Sig]] = []
  for _i in 0 ..n { out = out ++ [no_sig()] }
  out
}

fn is_tyvar(t: Ty) -> Bool =
  match t {
    TyVar(_, _) -> true
    _ -> false
  }

fn is_tuple_ty(t: Ty) -> Bool =
  match t {
    TyTuple(_) -> true
    _ -> false
  }

fn is_list_ty(t: Ty) -> Bool =
  match t {
    TyList(_) -> true
    _ -> false
  }

fn is_java_node(x: TExpr) -> Bool =
  match x {
    XJava(_, _, _, _) -> true
    _ -> false
  }

## Find a name in the scope stack with lambda-capture bookkeeping (the Kotlin
## resolveLocal): a hit below a lambda boundary is captured by value into every
## crossing lambda; `var` bindings refuse to cross, and assignment never does.
pub fn resolve_local(
  cx: Cx,
  name: String,
  lo: Int,
  hi: Int,
  for_assign: Bool
) -> (Cx, Option[Int]) = {
  var i = len(cx.scopes) - 1
  while i >= 0 {
    match map.get(cx.scopes[i], name) {
      Some(id) -> {
        let sym = sym_of(cx, id)
        var cx1 = cx
        var stack: List[LambdaCx] = []
        for lc in cx1.lambda_stack {
          if i < lc.boundary {
            if for_assign {
              cx1 = cerr_h(cx1, "cannot assign to `" ++ name ++ "` from inside a lambda", lo, hi,
                "lambdas capture by value; use the result of the lambda instead")
              stack = stack ++ [lc]
            } else if sym.mutable {
              cx1 = cerr_h(cx1, "lambdas cannot capture `var` bindings (capture is by value)",
                lo, hi, "bind it to a let before the lambda, or pass it as a parameter")
              stack = stack ++ [lc]
            } else {
              var caps = lc.captures
              var have = false
              for c in caps {
                if c == id { have = true }
              }
              if not have { caps = caps ++ [id] }
              stack = stack ++ [LambdaCx { ..lc, captures: caps }]
            }
          } else {
            stack = stack ++ [lc]
          }
        }
        cx1 = Cx { ..cx1, lambda_stack: stack }
        return (cx1, Some(id))
      }
      None -> ()
    }
    i = i - 1
  }
  (cx, None)
}

## The hint for a name that used to exist: where it moved (v0.5.0 flattened
## names, populated by the std loader), else did-you-mean.
pub fn moved_or_suggest(cx: Cx, name: String, pool: List[String]) -> Option[String] =
  match map.get(cx.moved, name) {
    Some(w) -> Some("`" ++ name ++ "` was removed in v0.5.0; " ++ w)
    None -> suggest.hint(name, pool)
  }

## A variable read: a local (with capture bookkeeping), else a top-level fn or
## builtin used as a value, else undefined.
fn check_var(cx: Cx, name: String, expected: Option[Ty], lo: Int, hi: Int) -> (Cx, Ty, TExpr) = {
  let (cx1, found) = resolve_local(cx, name, lo, hi, false)
  match found {
    Some(id) -> {
      let sym = sym_of(cx1, id)
      (cx1, sym.ty, XLocal(id, name, lo, hi, sym.ty))
    }
    None -> {
      match lookup_fn_sig(cx1, name) {
        Some(s) -> check_fn_value(cx1, name, s, expected, lo, hi)
        None ->
          (cerr_o(cx1, "undefined variable: " ++ name, lo, hi,
            moved_or_suggest(cx1, name, local_names(cx1) ++ fn_pool(cx1))),
            TyError, XError(lo, hi))
      }
    }
  }
}

# ---- unsafe_pure ----

## unsafe_pure { body } (docs/pure-ffi-design.md §3.2): the body checks as
## usual — locals stay in scope — but its effects are captured in isolation.
## Concrete io is masked to Pure; an effect variable is rejected; a body that
## did no io at all flags the stamp as redundant.
fn check_unsafe_pure(cx: Cx, body: Expr, expected: Option[Ty], lo: Int, hi: Int) -> (Cx, Ty, TExpr) !io = {
  let saved_used = cx.used_effects
  let saved_wit = cx.eff_witness
  let empty_w: Map[Eff, (Int, Int, String)] = map.empty()
  let (cx1, t, bx) = check_expr(Cx { ..cx, used_effects: [], eff_witness: empty_w }, body, expected)
  let inner = cx1.used_effects
  var cx2 = Cx { ..cx1, used_effects: saved_used, eff_witness: saved_wit }
  var poly: Option[Eff] = None
  for u in inner {
    match u {
      EffVar(_, _) -> if poly == None { poly = Some(u) }
      EUnion(_) -> if poly == None { poly = Some(u) }
      _ -> ()
    }
  }
  match poly {
    Some(p) -> {
      cx2 = cerr_h(cx2, "unsafe_pure cannot mask the effect variable !" ++ eff_show(p) ++
          " — it only vouches that a concrete io effect is absent", lo, hi,
        "the block calls an effect-polymorphic function (e.g. a higher-order `map`/`fold`); " ++
          "rewrite it as pure Dawn recursion over first-order pure primitives (docs/pure-ffi-design.md §3.3)")
    }
    None -> {
      var has_io = false
      for u in inner {
        if u == EIo { has_io = true }
      }
      if not has_io && not is_errorish(t) {
        cx2 = cerr_h(cx2, "redundant unsafe_pure: the block is already pure", lo, hi,
          "drop `unsafe_pure { … }` and keep the inner expression — the stamp is only for vouching " ++
            "a Java interop call the effect checker would otherwise flag !io")
      }
    }
  }
  # masked: the body's io is deliberately not folded back into the saved record
  (cx2, t, XUnsafePure(bx, lo, hi, t))
}

# ---- lambdas and application ----

fn check_lambda(
  cx: Cx,
  params: List[LambdaParam],
  body: Expr,
  expected: Option[Ty],
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  var cx1 = cx
  var have_exp = false
  var eps: List[Ty] = []
  var eret = TyUnit
  var eeff = EPure
  match expected {
    Some(TyFn(ps, r, ef)) -> {
      have_exp = true
      eps = ps
      eret = r
      eeff = ef
    }
    _ -> ()
  }
  if have_exp && len(eps) != len(params) {
    cx1 = cerr(cx1, "this lambda takes " ++ to_string(len(params)) ++ " parameter(s), but " ++
        ty_show(cx1.adts, TyFn(eps, eret, eeff)) ++ " is expected", lo, hi)
  }
  var ptys: List[Ty] = []
  var i = 0
  for p in params {
    var t = TyError
    var have = false
    match p.ann {
      Some(ref) -> {
        let (cxa, tt) = resolve_type(cx1, ref)
        cx1 = cxa
        t = tt
        have = true
      }
      None -> ()
    }
    if not have && have_exp {
      # take the parameter type from the expected fn type; an enclosing
      # function's type parameter (a TyVar) is a legitimate opaque type here
      match get(eps, i) {
        Some(et) ->
          if is_concrete(cx1, et) || is_tyvar(et) {
            t = et
            have = true
          }
        None -> ()
      }
    }
    if not have {
      cx1 = cerr_h(cx1, "cannot infer the type of `" ++ p.name ++ "`", p.lo, p.hi,
        "annotate it: fn(" ++ p.name ++ ": Int) => ...")
      t = TyError
    }
    if t == TyUnit {
      cx1 = cerr(cx1, "lambda parameters cannot be Unit", p.lo, p.hi)
      t = TyError
    }
    ptys = ptys ++ [t]
    i = i + 1
  }
  # the lambda's effects are its own — they happen when it is called
  let saved_used = cx1.used_effects
  let saved_wit = cx1.eff_witness
  let empty_w: Map[Eff, (Int, Int, String)] = map.empty()
  let exp_ret: Option[Ty] =
    if have_exp && is_concrete(cx1, eret) { Some(eret) } else { None }
  let ctx = LambdaCx { boundary: len(cx1.scopes), expected_ret: exp_ret, captures: [] }
  cx1 = Cx {
    ..cx1,
    used_effects: [],
    eff_witness: empty_w,
    lambda_stack: cx1.lambda_stack ++ [ctx]
  }
  cx1 = push_scope(cx1)
  var psyms: List[Int] = []
  var pnames: List[String] = []
  var j = 0
  for p in params {
    let (cxa, sid) = declare(cx1, p.name, ptys[j], false, p.lo, p.hi)
    cx1 = cxa
    psyms = psyms ++ [sid]
    pnames = pnames ++ [p.name]
    j = j + 1
  }
  let (cx2, bt, bx) = check_expr(cx1, body, exp_ret)
  var cx3 = pop_scope(cx2)
  let popped = cx3.lambda_stack[len(cx3.lambda_stack) - 1]
  cx3 = Cx { ..cx3, lambda_stack: list.take(cx3.lambda_stack, len(cx3.lambda_stack) - 1) }
  let lam_eff = eff_union(cx3.used_effects)
  cx3 = Cx { ..cx3, used_effects: saved_used, eff_witness: saved_wit }
  let t = TyFn(ptys, bt, lam_eff)
  (cx3, t, XLambda(psyms, pnames, bx, popped.captures, lo, hi, t))
}

fn check_apply(cx: Cx, target: Expr, args: List[Expr], lo: Int, hi: Int) -> (Cx, Ty, TExpr) !io = {
  # piping into an unannotated lambda: the arguments determine its parameter types
  var lambda_unannotated = false
  match target {
    ELambda(ps, _, _, _) -> {
      for p in ps {
        match p.ann {
          None -> { lambda_unannotated = true }
          Some(_) -> ()
        }
      }
    }
    _ -> ()
  }
  var cx1 = cx
  var pre: Option[List[Ty]] = None
  var pre_txs: List[TExpr] = []
  var ft = TyError
  var fx: TExpr = XError(lo, hi)
  if lambda_unannotated {
    var ats: List[Ty] = []
    for a in args {
      let (cxa, at, ax) = check_expr(cx1, a, no_expected())
      cx1 = cxa
      ats = ats ++ [at]
      pre_txs = pre_txs ++ [ax]
    }
    pre = Some(ats)
    let (cxb, ftt, fxx) = check_expr(cx1, target, Some(TyFn(ats, TyNever, EIo)))
    cx1 = cxb
    ft = ftt
    fx = fxx
  } else {
    let (cxb, ftt, fxx) = check_expr(cx1, target, no_expected())
    cx1 = cxb
    ft = ftt
    fx = fxx
  }
  let pre_none = pre == None
  if is_errorish(ft) {
    if pre_none {
      for a in args {
        let (cxa, _, _) = check_expr(cx1, a, no_expected())
        cx1 = cxa
      }
    }
    return (cx1, TyError, XError(lo, hi))
  }
  var is_fn = false
  var fps: List[Ty] = []
  var fret = TyError
  var feff = EPure
  match ft {
    TyFn(ps, r, ef) -> {
      is_fn = true
      fps = ps
      fret = r
      feff = ef
    }
    _ -> ()
  }
  if not is_fn {
    if pre_none {
      for a in args {
        let (cxa, _, _) = check_expr(cx1, a, no_expected())
        cx1 = cxa
      }
    }
    return (cerr(cx1, "cannot call a value of type " ++ ty_show(cx1.adts, ft),
      e_lo(target), e_hi(target)), TyError, XError(lo, hi))
  }
  if len(args) != len(fps) {
    if pre_none {
      for a in args {
        let (cxa, _, _) = check_expr(cx1, a, no_expected())
        cx1 = cxa
      }
    }
    cx1 = cerr_h(cx1, "this function takes " ++ to_string(len(fps)) ++ " argument(s), got " ++
        to_string(len(args)), lo, hi, "type: " ++ ty_show(cx1.adts, ft))
    return (cx1, fret, XError(lo, hi))
  }
  var txs: List[TExpr] = []
  match pre {
    None -> {
      var i = 0
      for a in args {
        let pt = fps[i]
        let (cxa, at, ax) = check_expr(cx1, a, Some(pt))
        cx1 = cxa
        if not assignable(cx1, at, pt) {
          cx1 = cerr(cx1, "argument type mismatch: expected " ++ ty_show(cx1.adts, pt) ++
              ", got " ++ ty_show(cx1.adts, at), e_lo(a), e_hi(a))
        }
        txs = txs ++ [ax]
        i = i + 1
      }
    }
    Some(ats) -> {
      var i = 0
      for at in ats {
        if not assignable(cx1, at, fps[i]) {
          cx1 = cerr(cx1, "argument type mismatch: expected " ++ ty_show(cx1.adts, fps[i]) ++
              ", got " ++ ty_show(cx1.adts, at), e_lo(args[i]), e_hi(args[i]))
        }
        i = i + 1
      }
      txs = pre_txs
    }
  }
  cx1 = record_effect(cx1, feff, e_lo(target), e_hi(target), "the applied function")
  (cx1, fret, XApply(fx, txs, lo, hi, fret))
}

# ---- blocks and statements ----

fn check_block(
  cx: Cx,
  stmts: List[Stmt],
  tail: Option[Expr],
  expected: Option[Ty],
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  var cx1 = push_scope(cx)
  var tstmts: List[TStmt] = []
  for s in stmts {
    let (cxa, ts) = check_stmt(cx1, s)
    cx1 = cxa
    tstmts = tstmts ++ [ts]
  }
  var t = TyUnit
  var ttail: Option[TExpr] = None
  var tail_java = false
  match tail {
    Some(x) -> {
      let (cxa, xt, xx) = check_expr(cx1, x, expected)
      cx1 = cxa
      t = xt
      ttail = Some(xx)
      tail_java = is_java_node(xx)
    }
    None -> ()
  }
  cx1 = pop_scope(cx1)
  # a Java call in tail position of a Unit block is a discard, like in
  # statement position (spec §9) — codegen pops the leftover value
  let rt = if expected == Some(TyUnit) && t != TyUnit && tail_java { TyUnit } else { t }
  (cx1, rt, XBlock(tstmts, ttail, lo, hi, rt))
}

fn check_stmt(cx: Cx, s: Stmt) -> (Cx, TStmt) !io =
  match s {
    SLet(name, mutable, ann, init, lo, hi) -> {
      var cx1 = cx
      let ann_t: Option[Ty] = match ann {
        Some(ref) -> {
          let (cxa, t) = resolve_type(cx1, ref)
          cx1 = cxa
          Some(t)
        }
        None -> None
      }
      let (cxb, it, ix) = check_expr(cx1, init, ann_t)
      cx1 = cxb
      var t = match ann_t {
        Some(a) -> a
        None -> it
      }
      match ann_t {
        Some(a) ->
          if not assignable(cx1, it, a) {
            cx1 = cerr(cx1, "annotated type is " ++ ty_show(cx1.adts, a) ++
                " but the initializer is " ++ ty_show(cx1.adts, it), e_lo(init), e_hi(init))
            t = a
          }
        None -> ()
      }
      if t == TyNever {
        cx1 = cerr(cx1, "cannot bind Never (this expression does not return)", e_lo(init), e_hi(init))
        t = TyError
      }
      let (cxc, sid) = declare(cx1, name, t, mutable, lo, hi)
      # `_` binds nothing: codegen discards the value (sym None)
      let bind: Option[Int] = if name == "_" { None } else { Some(sid) }
      (cxc, TSLet(bind, name, ix, lo, hi))
    }
    SLocalFn(name, params, ret, effs, body, nlo, nhi, lo, hi) ->
      check_local_fn(cx, name, params, ret, effs, body, nlo, nhi, lo, hi)
    SLetPat(pat, mutable, init, lo, hi) -> {
      var cx1 = cx
      let (cxa, it0, ix) = check_expr(cx1, init, no_expected())
      cx1 = cxa
      var it = it0
      if it == TyNever {
        cx1 = cerr(cx1, "cannot bind Never (this expression does not return)", e_lo(init), e_hi(init))
        it = TyError
      }
      match refutable_part(cx1, pat) {
        Some(sp) -> {
          let (plo, phi) = sp
          cx1 = cerr_h(cx1, "this pattern does not always match, so it cannot be used in a let",
            plo, phi, "use match to handle the other cases")
        }
        None -> ()
      }
      let (cxb, tp) = check_pattern(cx1, pat, it, mutable)
      (cxb, TSLetPat(tp, ix, lo, hi))
    }
    SAssign(name, value, nlo, nhi, lo, hi) -> {
      var cx1 = cx
      let (cxa, found) = resolve_local(cx1, name, nlo, nhi, true)
      cx1 = cxa
      match found {
        None -> {
          cx1 = cerr_o(cx1, "undefined variable: " ++ name, nlo, nhi,
            moved_or_suggest(cx1, name, local_names(cx1) ++ fn_pool(cx1)))
          let (cxb, _, vx) = check_expr(cx1, value, no_expected())
          (cxb, TSExpr(vx, lo, hi))
        }
        Some(sid) -> {
          let sym = sym_of(cx1, sid)
          if not sym.mutable {
            cx1 = cerr_h(cx1, "`" ++ name ++ "` is a let binding and cannot be assigned", nlo, nhi,
              "declare it as var " ++ name ++ " = ... if it needs to change")
          }
          let (cxb, vt, vx) = check_expr(cx1, value, Some(sym.ty))
          cx1 = cxb
          if not assignable(cx1, vt, sym.ty) {
            cx1 = cerr(cx1, "`" ++ name ++ "` is " ++ ty_show(cx1.adts, sym.ty) ++
                ", cannot assign " ++ ty_show(cx1.adts, vt), e_lo(value), e_hi(value))
          }
          (cx1, TSAssign(sid, name, vx, lo, hi))
        }
      }
    }
    SExpr(e, lo, hi) -> {
      let (cx1, t, tx) = check_expr(cx, e, no_expected())
      var cx2 = cx1
      # Java results may be dropped freely — Java APIs return `this` and
      # status codes that Dawn code rarely wants (spec §9)
      if t != TyUnit && not is_errorish(t) && not is_java_node(tx) {
        cx2 = cerr_h(cx2, "this " ++ ty_show(cx2.adts, t) ++ " value is discarded", lo, hi,
          "write let _ = ... to discard it, or move it to the block's tail/return position")
      }
      (cx2, TSExpr(tx, lo, hi))
    }
    SAssert(cond, src, lo, hi) -> {
      var cx1 = cx
      if not cx1.in_test {
        cx1 = cerr_h(cx1, "`assert` is only allowed inside test blocks", lo, hi,
          "use panic(...) for runtime invariants in regular code")
      }
      let (cxa, ct, cnx) = check_expr(cx1, cond, no_expected())
      cx1 = cxa
      if ct != TyBool && not is_errorish(ct) {
        cx1 = cerr(cx1, "assert expects Bool, got " ++ ty_show(cx1.adts, ct), e_lo(cond), e_hi(cond))
      }
      (cx1, TSAssert(cnx, src, lo, hi))
    }
    SWhile(cond, body, lo, hi) -> {
      var cx1 = cx
      let (cxa, ct, cnx) = check_expr(cx1, cond, no_expected())
      cx1 = cxa
      if ct != TyBool && not is_errorish(ct) {
        cx1 = cerr(cx1, "while condition must be Bool, got " ++ ty_show(cx1.adts, ct),
          e_lo(cond), e_hi(cond))
      }
      let d = len(cx1.loop_stack)
      cx1 = Cx { ..cx1, loop_stack: cx1.loop_stack ++ [len(cx1.lambda_stack)] }
      let (cxb, bt, bx) = check_expr(cx1, body, Some(TyUnit))
      cx1 = cxb
      let hj = set.has(cx1.loop_jumps, d)
      cx1 = Cx {
        ..cx1,
        loop_stack: list.take(cx1.loop_stack, len(cx1.loop_stack) - 1),
        loop_jumps: set.remove(cx1.loop_jumps, d)
      }
      if bt != TyUnit && not is_errorish(bt) {
        cx1 = cerr_h(cx1, "the loop body's value is discarded (" ++ ty_show(cx1.adts, bt) ++ ")",
          e_lo(body), e_hi(body),
          "the last statement of a loop body must not be a non-Unit expression")
      }
      (cx1, TSWhile(cnx, bx, hj, lo, hi))
    }
    SFor(name, from, to_opt, body, lo, hi) -> {
      var cx1 = cx
      let (cxa, ft, fx) = check_expr(cx1, from, no_expected())
      cx1 = cxa
      var loop_t = TyError
      var tx_to: Option[TExpr] = None
      match to_opt {
        None -> {
          loop_t = match ft {
            TyList(el) -> el
            _ -> {
              if not is_errorish(ft) {
                cx1 = cerr(cx1, "for..in iterates a List or an integer range a..b, got " ++
                    ty_show(cx1.adts, ft), e_lo(from), e_hi(from))
              }
              TyError
            }
          }
        }
        Some(te) -> {
          let (cxb, tt2, tx2) = check_expr(cx1, te, no_expected())
          cx1 = cxb
          if (ft != TyInt && not is_errorish(ft)) || (tt2 != TyInt && not is_errorish(tt2)) {
            cx1 = cerr(cx1, "range bounds a..b must be Int (got " ++ ty_show(cx1.adts, ft) ++
                ".." ++ ty_show(cx1.adts, tt2) ++ ")", lo, hi)
          }
          loop_t = TyInt
          tx_to = Some(tx2)
        }
      }
      cx1 = push_scope(cx1)
      let (cxc, sid) = declare(cx1, name, loop_t, false, lo, hi)
      cx1 = cxc
      let d = len(cx1.loop_stack)
      cx1 = Cx { ..cx1, loop_stack: cx1.loop_stack ++ [len(cx1.lambda_stack)] }
      let (cxd, bt, bx) = check_expr(cx1, body, Some(TyUnit))
      cx1 = cxd
      let hj = set.has(cx1.loop_jumps, d)
      cx1 = Cx {
        ..cx1,
        loop_stack: list.take(cx1.loop_stack, len(cx1.loop_stack) - 1),
        loop_jumps: set.remove(cx1.loop_jumps, d)
      }
      if bt != TyUnit && not is_errorish(bt) {
        cx1 = cerr(cx1, "the loop body's value is discarded (" ++ ty_show(cx1.adts, bt) ++ ")",
          e_lo(body), e_hi(body))
      }
      cx1 = pop_scope(cx1)
      (cx1, TSFor(sid, name, fx, tx_to, bx, hj, lo, hi))
    }
  }

## fn name(params) -> T [!io] = body, statement form (the Kotlin checkLocalFn).
## The name is declared before the body is checked, so the body can call it;
## the self-capture is then dropped — codegen calls the impl method directly.
fn check_local_fn(
  cx: Cx,
  name: String,
  params: List[LambdaParam],
  ret_ref: TypeRef,
  effs: List[String],
  body: Expr,
  nlo: Int,
  nhi: Int,
  lo: Int,
  hi: Int
) -> (Cx, TStmt) !io = {
  var cx1 = cx
  var ptys: List[Ty] = []
  for p in params {
    var t = match p.ann {
      Some(ref) -> {
        let (cxa, tt) = resolve_type(cx1, ref)
        cx1 = cxa
        tt
      }
      # the parser requires annotations on local fn parameters
      None -> TyError
    }
    if t == TyUnit {
      cx1 = cerr(cx1, "function parameters cannot be Unit", p.lo, p.hi)
      t = TyError
    }
    ptys = ptys ++ [t]
  }
  let (cxb, ret) = resolve_type(cx1, ret_ref)
  cx1 = cxb
  var eff = EPure
  if len(effs) == 0 {
    eff = EPure
  } else if len(effs) == 1 && effs[0] == "io" {
    eff = EIo
  } else {
    cx1 = cerr_h(cx1, "local functions cannot declare effect variables", nlo, nhi,
      "a local function is `!io` or pure; lift it to the top level for effect polymorphism")
    eff = EIo
  }
  let ft = TyFn(ptys, ret, eff)
  let (cxc, sid) = declare(cx1, name, ft, false, nlo, nhi)
  cx1 = cxc
  let (cxd, actual, lam) = check_lambda(cx1, params, body, Some(ft), lo, hi)
  cx1 = cxd
  match actual {
    TyFn(_, ar, ae) -> {
      if not assignable(cx1, ar, ret) {
        cx1 = cerr(cx1, "the body of `" ++ name ++ "` has type " ++ ty_show(cx1.adts, ar) ++
            " but the declared return type is " ++ ty_show(cx1.adts, ret), e_lo(body), e_hi(body))
      }
      if ae == EIo && eff == EPure {
        cx1 = cerr_h(cx1, "the body of `" ++ name ++ "` performs io", nlo, nhi,
          "declare it: fn " ++ name ++ "(...) -> " ++ ty_show(cx1.adts, ret) ++ " !io = ...")
      }
    }
    _ -> ()
  }
  match lam {
    XLambda(psyms, pnames, bx, caps, ..) -> {
      var caps2: List[Int] = []
      for c in caps {
        if c != sid { caps2 = caps2 ++ [c] }
      }
      (cx1, TSLocalFn(sid, name, psyms, pnames, bx, caps2, lo, hi))
    }
    _ -> (cx1, TSExpr(XError(lo, hi), lo, hi))
  }
}

# ---- calls ----

fn is_lambda_or_var(e: Expr) -> Bool =
  match e {
    ELambda(_, _, _, _) -> true
    EVar(_, _, _) -> true
    _ -> false
  }

## Check argument i; a UFCS receiver (always args[0]) was already checked by
## check_method_call and its result is passed through.
fn check_arg_at(
  cx: Cx,
  a: Expr,
  i: Int,
  pre0: Option[(Ty, TExpr)],
  exp: Option[Ty]
) -> (Cx, Ty, TExpr) !io =
  if i == 0 {
    match pre0 {
      Some(p) -> {
        let (pt, px) = p
        (cx, pt, px)
      }
      None -> check_expr(cx, a, exp)
    }
  } else {
    check_expr(cx, a, exp)
  }

## Check every argument with no expected type (error paths: the subtrees still
## get visited so their own diagnostics surface).
fn check_args_plain(cx: Cx, args: List[Expr], pre0: Option[(Ty, TExpr)]) -> (Cx, List[TExpr]) !io = {
  var cx1 = cx
  var txs: List[TExpr] = []
  var i = 0
  for a in args {
    let (cxa, _, ax) = check_arg_at(cx1, a, i, pre0, no_expected())
    cx1 = cxa
    txs = txs ++ [ax]
    i = i + 1
  }
  (cx1, txs)
}

## A named call f(args) (the Kotlin checkCall): a local fn value, else a
## top-level / std / builtin signature with two-round argument inference,
## trait witnesses and effect instantiation. `resolved_sig` bypasses locals
## (module-qualified calls); `pre0` is a pre-typed UFCS receiver at args[0].
fn check_call(
  cx: Cx,
  callee: String,
  args: List[Expr],
  expected: Option[Ty],
  pre0: Option[(Ty, TExpr)],
  resolved_sig: Option[Sig],
  clo: Int,
  chi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  var cx1 = cx
  var local: Option[Int] = None
  match resolved_sig {
    Some(_) -> ()
    None -> {
      let (cxa, found) = resolve_local(cx1, callee, clo, chi, false)
      cx1 = cxa
      local = found
    }
  }
  match local {
    Some(sid) -> {
      let sym = sym_of(cx1, sid)
      let lt = sym.ty
      if is_errorish(lt) {
        let (cxa, _) = check_args_plain(cx1, args, pre0)
        return (cxa, TyError, XError(lo, hi))
      }
      var is_fn = false
      var lps: List[Ty] = []
      var lret = TyError
      var leff = EPure
      match lt {
        TyFn(ps, r, ef) -> {
          is_fn = true
          lps = ps
          lret = r
          leff = ef
        }
        _ -> ()
      }
      if not is_fn {
        let (cxa, _) = check_args_plain(cx1, args, pre0)
        return (cerr(cxa, "`" ++ callee ++ "` is not a function (it is " ++
            ty_show(cxa.adts, lt) ++ ")", clo, chi), TyError, XError(lo, hi))
      }
      if len(args) != len(lps) {
        let (cxa, _) = check_args_plain(cx1, args, pre0)
        return (cerr_h(cxa, "`" ++ callee ++ "` takes " ++ to_string(len(lps)) ++
            " argument(s), got " ++ to_string(len(args)), lo, hi,
          "type: " ++ ty_show(cxa.adts, lt)), lret, XError(lo, hi))
      }
      var txs: List[TExpr] = []
      var i = 0
      for a in args {
        let pt = lps[i]
        let (cxa, at, ax) = check_arg_at(cx1, a, i, pre0, Some(pt))
        cx1 = cxa
        if not assignable(cx1, at, pt) {
          cx1 = cerr(cx1, "argument type mismatch: expected " ++ ty_show(cx1.adts, pt) ++
              ", got " ++ ty_show(cx1.adts, at), e_lo(a), e_hi(a))
        }
        txs = txs ++ [ax]
        i = i + 1
      }
      cx1 = record_effect(cx1, leff, clo, chi, callee)
      return (cx1, lret, XCallDyn(sid, callee, txs, lo, hi, lret))
    }
    None -> ()
  }
  let sig = match resolved_sig {
    Some(s0) -> Some(s0)
    None -> lookup_fn_sig(cx1, callee)
  }
  let s = match sig {
    Some(s2) -> s2
    None -> {
      # still check the arguments so their subtrees get types/symbols
      let (cxa, _) = check_args_plain(cx1, args, pre0)
      return (cerr_o(cxa, "undefined function: " ++ callee, clo, chi,
        moved_or_suggest(cxa, callee, fn_pool(cxa))),
        TyError, XError(lo, hi))
    }
  }
  if len(args) != len(s.param_tys) {
    let (cxa, _) = check_args_plain(cx1, args, pre0)
    let cxb = cerr_h(cxa, "`" ++ callee ++ "` takes " ++ to_string(len(s.param_tys)) ++
        " argument(s), got " ++ to_string(len(args)), lo, hi,
      "signature: " ++ sig_render(cxa.adts, cxa.traits, s))
    let rt = if len(s.tparams) == 0 { s.ret } else { TyError }
    return (cxb, rt, XError(lo, hi))
  }
  var m: Map[Int, Ty] = map.empty()
  var em: Map[Int, Eff] = map.empty()
  # seed inference from the expected result type (helps nested cases like Some(None))
  match expected {
    Some(et) ->
      if len(s.tparams) > 0 && is_concrete(cx1, et) {
        let (m2, em2, _) = unify_into(cx1, s.ret, et, m, em)
        m = m2
        em = em2
      }
    None -> ()
  }
  # two rounds: self-sufficient arguments first (they bind type variables),
  # then inference-needing ones (bare None, []) with what was learned
  var at_slots: List[Option[Ty]] = []
  var tx_slots: List[Option[TExpr]] = []
  for _k in 0 ..len(args) {
    at_slots = at_slots ++ [no_expected()]
    tx_slots = tx_slots ++ [no_texpr()]
  }
  for round in 0 ..2 {
    var i = 0
    for a in args {
      let done = match at_slots[i] {
        Some(_) -> true
        None -> false
      }
      let skip = round == 0 && needs_expected(cx1, a)
      if not done && not skip {
        let substd = subst(s.param_tys[i], m, em)
        # lambdas only need their parameter types, and function values unify
        # piecewise — a partially concrete expected type still helps
        let exp2: Option[Ty] =
          if is_concrete(cx1, substd) || is_lambda_or_var(a) { Some(substd) } else { None }
        let (cxa, at, ax) = check_arg_at(cx1, a, i, pre0, exp2)
        cx1 = cxa
        at_slots = list.take(at_slots, i) ++ [Some(at)] ++ list.drop(at_slots, i + 1)
        tx_slots = list.take(tx_slots, i) ++ [Some(ax)] ++ list.drop(tx_slots, i + 1)
        let (m3, em3, ok) = unify_into(cx1, s.param_tys[i], at, m, em)
        m = m3
        em = em3
        if not ok {
          cx1 = cerr_h(cx1, "argument type mismatch: expected " ++
              ty_show(cx1.adts, subst(s.param_tys[i], m, em)) ++ ", got " ++
              ty_show(cx1.adts, at), e_lo(a), e_hi(a),
            "signature: " ++ sig_render(cx1.adts, cx1.traits, s))
        }
      }
      i = i + 1
    }
  }
  # return-position inference: let x: Option[Int] = ...
  var unbound_any = false
  for tp in s.tparams {
    match tp {
      TyVar(_, vid) -> if not map.has(m, vid) { unbound_any = true }
      _ -> ()
    }
  }
  if unbound_any {
    match expected {
      Some(et) -> {
        let (m4, em4, _) = unify_into(cx1, s.ret, et, m, em)
        m = m4
        em = em4
      }
      None -> ()
    }
  }
  var unbound: List[String] = []
  for tp in s.tparams {
    match tp {
      TyVar(n, vid) -> if not map.has(m, vid) { unbound = unbound ++ [n] }
      _ -> ()
    }
  }
  if len(unbound) > 0 {
    return (cerr_h(cx1, "cannot infer type parameter(s) " ++ join(unbound, ", ") ++
        " for `" ++ callee ++ "`", lo, hi, "add a type annotation at the use site"),
      TyError, XError(lo, hi))
  }
  # trait bounds: each (type parameter, bound) pair needs a dictionary
  var wits: List[WitRef] = []
  var any_constraint = false
  for bs in s.constraints {
    if len(bs) > 0 { any_constraint = true }
  }
  if any_constraint {
    var all_ok = true
    var ws: List[WitRef] = []
    var i2 = 0
    for tp in s.tparams {
      for tr_id in bounds_of(s, i2) {
        let (cxa, w) = resolve_witness(cx1, tr_id, subst(tp, m, em), clo, chi,
          "`" ++ callee ++ "`")
        cx1 = cxa
        match w {
          Some(wr) -> { ws = ws ++ [wr] }
          None -> { all_ok = false }
        }
      }
      i2 = i2 + 1
    }
    if all_ok { wits = ws }
  }
  if s.is_builtin && s.name == "to_string" {
    let t0 = subst(s.param_tys[0], m, em)
    if not is_showable(cx1, t0) && not is_errorish(t0) {
      cx1 = cerr_h(cx1, "cannot print a value of type " ++ ty_show(cx1.adts, t0),
        e_lo(args[0]), e_hi(args[0]), show_hint(cx1, t0))
    }
  }
  if s.is_builtin && s.name == "cast" {
    # T is bound here (an unbound type param already errored above). It must be
    # a reference type: CHECKCAST cannot target a primitive (docs/cast-interop.md §三)
    let target = subst(s.ret, m, em)
    if target == TyInt || target == TyFloat || target == TyBool {
      cx1 = cerr_h(cx1, "`cast` target must be a reference type, not " ++
          ty_show(cx1.adts, target), lo, hi,
        "cast reclaims an erased Java Object via CHECKCAST; primitive targets aren't supported")
    }
  }
  # instantiate the callee's effect: an unbound effect variable means pure
  let callee_eff = match s.eff {
    EffVar(_, eid) ->
      match map.get(em, eid) {
        Some(ef) -> ef
        None -> EPure
      }
    _ -> s.eff
  }
  cx1 = record_effect(cx1, callee_eff, clo, chi, callee)
  let ret = subst(s.ret, m, em)
  # a generic call is where a concrete Map/Set key type is first formed from
  # inference (spec §2.2) — check the instantiated result by type
  if len(s.tparams) > 0 { cx1 = check_key_types_in(cx1, ret, lo, hi) }
  var txs2: List[TExpr] = []
  for sl in tx_slots {
    match sl {
      Some(ax) -> { txs2 = txs2 ++ [ax] }
      None -> { txs2 = txs2 ++ [XError(lo, hi)] }
    }
  }
  let node = if s.is_builtin {
    XCallBuiltin(callee, txs2, wits, lo, hi, ret)
  } else {
    XCallFn(s.owner, callee, txs2, wits, s.trait_id, lo, hi, ret)
  }
  (cx1, ret, node)
}

## Ctor(args) / Record { fields } / bare Name (the Kotlin checkCtorCall): also
## the landing site for SCREAMING_SNAKE constant references.
fn check_ctor_call(
  cx: Cx,
  cname: String,
  cargs: List[CtorArg],
  spread: Option[Expr],
  has_parens: Bool,
  expected: Option[Ty],
  cclo: Int,
  cchi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  var cx1 = cx
  let has_spread = match spread {
    Some(_) -> true
    None -> false
  }
  let key = map.get(cx1.ctors_by_name, cname)
  match key {
    None -> {
      # a bare SCREAMING_SNAKE name may be a constant reference; inside a
      # const initializer only earlier constants are visible (spec §3.2)
      let visible = match cx1.const_cutoff {
        Some(cut) -> set.has(cut, cname)
        None -> true
      }
      var cd: Option[Ty] = None
      if visible { cd = map.get(cx1.consts, cname) }
      match cd {
        Some(ct) -> {
          if has_parens || len(cargs) > 0 || has_spread {
            return (cerr(cx1, "`" ++ cname ++ "` is a constant, not a constructor", cclo, cchi),
              TyError, XError(lo, hi))
          }
          return (cx1, ct, XConstRef(cname, lo, hi, ct))
        }
        None -> ()
      }
      match spread {
        Some(sp) -> {
          let (cxa, _, _) = check_expr(cx1, sp, no_expected())
          cx1 = cxa
        }
        None -> ()
      }
      for a in cargs {
        let (cxa, _, _) = check_expr(cx1, a.e, no_expected())
        cx1 = cxa
      }
      let hint: Option[String] = if map.has(cx1.adts_by_name, cname) {
        let aid0 = map.get(cx1.adts_by_name, cname).expect("has")
        let ad0 = adt_of(cx1.adts, aid0)
        var cnames: List[String] = []
        for c in ad0.ctors { cnames = cnames ++ [c.name] }
        Some("`" ++ cname ++ "` is a type; build a value with one of its constructors: " ++
            join(cnames, ", "))
      } else if set.has(cx1.all_const_names, cname) {
        Some("const `" ++ cname ++
            "` is declared later in the file; constants are evaluated top to bottom")
      } else {
        suggest.hint(cname, map.keys(cx1.ctors_by_name) ++ map.keys(cx1.consts))
      }
      return (cerr_o(cx1, "undefined constructor: " ++ cname, cclo, cchi, hint),
        TyError, XError(lo, hi))
    }
    Some(_) -> ()
  }
  let (aid, cslot) = key.expect("ctor")
  let ad = adt_of(cx1.adts, aid)
  let ci = ad.ctors[cslot]
  let n = len(ci.fields)
  let self_ty = adt_self_ty(ad)
  var exp_is_fn = false
  var exp_fn_ps: List[Ty] = []
  var exp_fn_ret = TyUnit
  var exp_fn_eff = EPure
  match expected {
    Some(TyFn(ps2, r2, ef2)) -> {
      exp_is_fn = true
      exp_fn_ps = ps2
      exp_fn_ret = r2
      exp_fn_eff = ef2
    }
    _ -> ()
  }
  if not has_parens && n > 0 {
    # a bare constructor with fields, in a function-typed position, is a function value
    if not ad.is_record && exp_is_fn {
      return check_ctor_value(cx1, aid, cslot, exp_fn_ps, exp_fn_ret, exp_fn_eff, lo, hi)
    }
    let msg = if ad.is_record {
      "record `" ++ ci.name ++ "` must be built with braces: " ++ ci.name ++ " { ... }"
    } else {
      "constructor `" ++ ci.name ++ "` has " ++ to_string(n) ++
        " field(s) and cannot be used bare"
    }
    return (cerr_h(cx1, msg, lo, hi, "constructor: " ++ ctor_render(cx1.adts, ci)),
      TyError, XError(lo, hi))
  }
  # a bare nullary constructor where a function is expected: a value, not a function
  if not has_parens && n == 0 && exp_is_fn {
    return (cerr_h(cx1, "`" ++ ci.name ++ "` is a value, not a function (it takes no fields)",
      lo, hi, "use it directly; only constructors with fields can be passed as functions"),
      TyError, XError(lo, hi))
  }
  var m: Map[Int, Ty] = map.empty()
  var em: Map[Int, Eff] = map.empty()
  # seed inference from the expected result type (helps nested cases like Some(None))
  match expected {
    Some(et) ->
      if len(ad.tparams) > 0 && is_concrete(cx1, et) {
        let (m2, em2, _) = unify_into(cx1, self_ty, et, m, em)
        m = m2
        em = em2
      }
    None -> ()
  }
  var spread_tx: Option[TExpr] = None
  match spread {
    Some(sp) -> {
      if not ad.is_record {
        cx1 = cerr(cx1, "`..base` functional update only works on records", e_lo(sp), e_hi(sp))
      }
      let sexp: Option[Ty] = if is_concrete(cx1, self_ty) { Some(self_ty) } else { None }
      let (cxa, bt, sx) = check_expr(cx1, sp, sexp)
      cx1 = cxa
      let (m3, em3, ok) = unify_into(cx1, self_ty, bt, m, em)
      m = m3
      em = em3
      if not ok {
        cx1 = cerr(cx1, "`..base` must be a " ++ ad.name ++ ", got " ++ ty_show(cx1.adts, bt),
          e_lo(sp), e_hi(sp))
      }
      spread_tx = Some(sx)
    }
    None -> ()
  }
  # resolve the argument → field mapping (positional prefix, then named)
  var slots: List[Option[Int]] = []
  for _k in 0 ..n { slots = slots ++ [no_int()] }
  var idx_of: List[Int] = []
  for _k in 0 ..len(cargs) { idx_of = idx_of ++ [-1] }
  var atx: List[Option[TExpr]] = []
  for _k in 0 ..len(cargs) { atx = atx ++ [no_texpr()] }
  var saw_named = false
  var args_broken = false
  var i = 0
  for a in cargs {
    var idx = -1
    var skip = false
    match a.name {
      Some(an) -> {
        saw_named = true
        var found = -1
        var fi = 0
        for f in ci.fields {
          if found < 0 && f.name == an { found = fi }
          fi = fi + 1
        }
        if found < 0 {
          var fnames: List[String] = []
          for f in ci.fields { fnames = fnames ++ [f.name] }
          let h = match suggest.hint(an, fnames) {
            Some(hh) -> hh
            None -> "constructor: " ++ ctor_render(cx1.adts, ci)
          }
          cx1 = cerr_h(cx1, "`" ++ ci.name ++ "` has no field `" ++ an ++ "`", a.lo, a.hi, h)
          args_broken = true
          let (cxa, _, ax) = check_expr(cx1, a.e, no_expected())
          cx1 = cxa
          atx = list.take(atx, i) ++ [Some(ax)] ++ list.drop(atx, i + 1)
          skip = true
        } else {
          idx = found
        }
      }
      None -> {
        if saw_named {
          cx1 = cerr(cx1, "positional arguments cannot follow named arguments", a.lo, a.hi)
          args_broken = true
          let (cxa, _, ax) = check_expr(cx1, a.e, no_expected())
          cx1 = cxa
          atx = list.take(atx, i) ++ [Some(ax)] ++ list.drop(atx, i + 1)
          skip = true
        } else {
          idx = i
          if idx >= n {
            # counted below
            let (cxa, _, ax) = check_expr(cx1, a.e, no_expected())
            cx1 = cxa
            atx = list.take(atx, i) ++ [Some(ax)] ++ list.drop(atx, i + 1)
            skip = true
          }
        }
      }
    }
    if not skip {
      let taken = match slots[idx] {
        Some(_) -> true
        None -> false
      }
      if taken {
        cx1 = cerr(cx1, "field `" ++ ci.fields[idx].name ++ "` is given twice", a.lo, a.hi)
        args_broken = true
        let (cxa, _, ax) = check_expr(cx1, a.e, no_expected())
        cx1 = cxa
        atx = list.take(atx, i) ++ [Some(ax)] ++ list.drop(atx, i + 1)
      } else {
        slots = list.take(slots, idx) ++ [Some(i)] ++ list.drop(slots, idx + 1)
        idx_of = list.take(idx_of, i) ++ [idx] ++ list.drop(idx_of, i + 1)
      }
    }
    i = i + 1
  }
  # two rounds of checking (see check_call)
  for round in 0 ..2 {
    var j = 0
    for a in cargs {
      let idx = idx_of[j]
      let already = match atx[j] {
        Some(_) -> true
        None -> false
      }
      if idx >= 0 && not already {
        if not (round == 0 && needs_expected(cx1, a.e)) {
          let declared = ci.fields[idx].ty
          let sub = subst(declared, m, em)
          let exp2: Option[Ty] = if is_concrete(cx1, sub) { Some(sub) } else { None }
          let (cxa, at, ax) = check_expr(cx1, a.e, exp2)
          cx1 = cxa
          atx = list.take(atx, j) ++ [Some(ax)] ++ list.drop(atx, j + 1)
          let (m3, em3, ok) = unify_into(cx1, declared, at, m, em)
          m = m3
          em = em3
          if not ok {
            cx1 = cerr_h(cx1, "field `" ++ ci.fields[idx].name ++ "` of `" ++ ci.name ++
                "` is " ++ ty_show(cx1.adts, subst(declared, m, em)) ++ ", got " ++
                ty_show(cx1.adts, at), e_lo(a.e), e_hi(a.e),
              "constructor: " ++ ctor_render(cx1.adts, ci))
          }
        }
      }
      j = j + 1
    }
  }
  if not args_broken {
    var missing: List[String] = []
    var fi2 = 0
    for f in ci.fields {
      let filled = match slots[fi2] {
        Some(_) -> true
        None -> false
      }
      if not filled { missing = missing ++ [f.name] }
      fi2 = fi2 + 1
    }
    if len(cargs) > n {
      cx1 = cerr_h(cx1, "`" ++ ci.name ++ "` takes " ++ to_string(n) ++ " field(s), got " ++
          to_string(len(cargs)), lo, hi, "constructor: " ++ ctor_render(cx1.adts, ci))
    } else if len(missing) > 0 && not has_spread {
      cx1 = cerr_h(cx1, "missing field(s) in `" ++ ci.name ++ "`: " ++ join(missing, ", "),
        lo, hi, "constructor: " ++ ctor_render(cx1.adts, ci))
    }
  }
  # instantiate the type arguments; fall back to the expected type (bare None etc.)
  var unbound_any = false
  for tp in ad.tparams {
    match tp {
      TyVar(_, vid) -> if not map.has(m, vid) { unbound_any = true }
      _ -> ()
    }
  }
  if unbound_any {
    match expected {
      Some(et) -> {
        let (m4, em4, _) = unify_into(cx1, self_ty, et, m, em)
        m = m4
        em = em4
      }
      None -> ()
    }
  }
  var unbound: List[String] = []
  for tp in ad.tparams {
    match tp {
      TyVar(nm, vid) -> if not map.has(m, vid) { unbound = unbound ++ [nm] }
      _ -> ()
    }
  }
  if len(unbound) > 0 {
    return (cerr_h(cx1, "cannot infer type parameter(s) " ++ join(unbound, ", ") ++
        " for `" ++ ci.name ++ "`", lo, hi,
      "add a type annotation, e.g. let x: " ++ ad.name ++ "[...] = " ++ ci.name),
      TyError, XError(lo, hi))
  }
  var written: List[TExpr] = []
  for sl in atx {
    match sl {
      Some(ax) -> { written = written ++ [ax] }
      None -> { written = written ++ [XError(lo, hi)] }
    }
  }
  let rt = subst(self_ty, m, em)
  (cx1, rt, XCtor(aid, cslot, written, slots, spread_tx, lo, hi, rt))
}

# ---- Java interop calls (spec §9) ----

fn is_java_ty(t: Ty) -> Bool =
  match t {
    TyJava(_, _) -> true
    _ -> false
  }

fn is_prim_name(p: String) -> Bool =
  p == "long" || p == "int" || p == "short" || p == "byte" || p == "double" ||
  p == "float" || p == "boolean" || p == "char" || p == "void"

fn sam_of_nonprim(p: String) -> Option[JMethod] !io =
  if is_prim_name(p) { None } else { sam_of(p) }

fn sam_param_ty(p: String) -> Option[Ty] !io =
  if p == "long" || p == "int" || p == "short" || p == "byte" {
    Some(TyInt)
  } else if p == "double" || p == "float" {
    Some(TyFloat)
  } else if p == "boolean" {
    Some(TyBool)
  } else if p == "char" {
    None
  } else if p == "java.lang.String" {
    Some(TyString)
  } else {
    Some(TyJava(p, class_info(p).display))
  }

## SAM signature → the Dawn function shape a converted argument must have
## (spec §9.4). Callback parameters arrive unwrapped; None when the SAM is not
## convertible (char).
fn sam_fn_ty(sm: JMethod) -> Option[(List[Ty], Ty)] !io = {
  var ps: List[Ty] = []
  for p in sm.param_cls {
    match sam_param_ty(p) {
      Some(t) -> { ps = ps ++ [t] }
      None -> return None
    }
  }
  let r = sm.ret_cls
  let ret: Option[Ty] = if r == "void" {
    Some(TyUnit)
  } else if r == "long" || r == "int" || r == "short" || r == "byte" {
    Some(TyInt)
  } else if r == "double" || r == "float" {
    Some(TyFloat)
  } else if r == "boolean" {
    Some(TyBool)
  } else if r == "char" {
    None
  } else if r == "java.lang.String" {
    Some(TyString)
  } else {
    Some(TyJava(r, class_info(r).display))
  }
  match ret {
    Some(rt) -> Some((ps, rt))
    None -> None
  }
}

## May a Dawn return land where the SAM asks for j? (the boxed rep must be assignable)
fn sam_ret_compatible(r: Ty, j: String) -> Bool !io =
  if j == "void" {
    r == TyUnit || r == TyNever
  } else if j == "long" || j == "int" || j == "short" || j == "byte" {
    r == TyInt
  } else if j == "double" || j == "float" {
    r == TyFloat
  } else if j == "boolean" {
    r == TyBool
  } else if j == "char" {
    false
  } else {
    match r {
      TyString -> is_assignable(j, "java.lang.String")
      TyInt -> is_assignable(j, "java.lang.Long")
      TyFloat -> is_assignable(j, "java.lang.Double")
      TyBool -> is_assignable(j, "java.lang.Boolean")
      TyJava(fq, _) -> is_assignable(j, fq)
      TyNever -> true
      _ -> false
    }
  }

## Function-shaped arguments that need the target SAM to be typed are deferred:
## scored by arity now, checked once the winning overload is known.
fn sam_deferred(cx: Cx, a: Expr) -> Bool =
  match a {
    ELambda(ps, _, _, _) -> {
      for p in ps {
        match p.ann {
          None -> return true
          Some(_) -> ()
        }
      }
      false
    }
    ECtor(cn, cargs2, sp, hp, _, _, _, _) -> {
      if hp || len(cargs2) > 0 { return false }
      match sp {
        Some(_) -> return false
        None -> ()
      }
      match map.get(cx.ctors_by_name, cn) {
        Some(k) -> {
          let (aid, cslot) = k
          len(adt_of(cx.adts, aid).ctors[cslot].fields) > 0
        }
        None -> false
      }
    }
    _ -> false
  }

fn deferred_arity(cx: Cx, a: Expr) -> Int =
  match a {
    ELambda(ps, _, _, _) -> len(ps)
    ECtor(cn, _, _, _, _, _, _, _) ->
      match map.get(cx.ctors_by_name, cn) {
        Some(k) -> {
          let (aid, cslot) = k
          len(adt_of(cx.adts, aid).ctors[cslot].fields)
        }
        None -> 0
      }
    _ -> 0
  }

## How well one Java parameter class accepts an argument (spec §9.3); None = no fit.
fn param_score(cx: Cx, p: String, at: Option[Ty], arity: Int) -> Option[Int] !io =
  match at {
    # deferred lambda / bare constructor: match a convertible SAM by arity
    None ->
      match sam_of_nonprim(p) {
        Some(sm) ->
          match sam_fn_ty(sm) {
            Some(ft) -> {
              let (sps, _) = ft
              if len(sps) == arity { Some(2) } else { None }
            }
            None -> None
          }
        None -> None
      }
    Some(t) ->
      match t {
        TyInt -> if p == "long" { Some(2) } else if p == "int" { Some(1) } else { None }
        TyFloat -> if p == "double" { Some(2) } else if p == "float" { Some(1) } else { None }
        TyBool -> if p == "boolean" { Some(2) } else { None }
        TyString ->
          if p == "java.lang.String" {
            Some(2)
          } else if is_assignable(p, "java.lang.String") {
            Some(1)
          } else {
            None
          }
        # Bytes is a raw byte[] at runtime, so it passes to Java byte[] params directly
        TyBytes ->
          if p == "[B" {
            Some(2)
          } else if not is_prim_name(p) && is_assignable(p, "[B") {
            Some(1)
          } else {
            None
          }
        TyJava(fq, _) ->
          if p == fq {
            Some(2)
          } else if is_assignable(p, fq) {
            Some(1)
          } else if fq == "java.lang.Object" && not is_prim_name(p) {
            # opaque value (erased generic → Object, spec §9.5) down-cast to a
            # specific reference param with a runtime CHECKCAST
            Some(1)
          } else {
            None
          }
        TyFn(fps, fret, _) ->
          match sam_of_nonprim(p) {
            Some(sm) ->
              match sam_fn_ty(sm) {
                Some(ft) -> {
                  let (sps, _) = ft
                  if fps == sps && sam_ret_compatible(fret, sm.ret_cls) { Some(2) } else { None }
                }
                None -> None
              }
            None -> None
          }
        # a Dawn List bridges to the three collection interfaces only (spec §9.6)
        TyList(_) ->
          if p == "java.util.List" {
            Some(2)
          } else if p == "java.util.Collection" || p == "java.lang.Iterable" {
            Some(1)
          } else {
            None
          }
        _ -> None
      }
  }

## Reflection returns methods in an unspecified, process-varying order; sort
## by rendering so resolution and candidate lists are deterministic.
fn sort_methods(ms: List[JMethod]) -> List[JMethod] = {
  var out: List[JMethod] = []
  for m2 in ms {
    var i = 0
    var placed = false
    var next: List[JMethod] = []
    for x in out {
      if not placed && m2.desc < x.desc {
        next = next ++ [m2]
        placed = true
      }
      next = next ++ [x]
    }
    if not placed { next = next ++ [m2] }
    out = next
  }
  out
}

fn sort_ctors(cs: List[JCtor]) -> List[JCtor] = {
  var out: List[JCtor] = []
  for c in cs {
    var placed = false
    var next: List[JCtor] = []
    for x in out {
      if not placed && c.desc < x.desc {
        next = next ++ [c]
        placed = true
      }
      next = next ++ [x]
    }
    if not placed { next = next ++ [c] }
    out = next
  }
  out
}

## The i-th parameter as the argument at i sees it: inside a packed variadic
## part that is the array's component type, not the array.
fn param_at(params: List[String], packs: Bool, i: Int) -> String !io =
  if packs && i >= len(params) - 1 {
    component_of(params[len(params) - 1]).expect("varargs component")
  } else {
    params[i]
  }

fn score_with(
  cx: Cx,
  params: List[String],
  packs: Bool,
  ats: List[Option[Ty]],
  arities: List[Int]
) -> Option[Int] !io = {
  if packs {
    if len(ats) < len(params) - 1 { return None }
  } else if len(params) != len(ats) {
    return None
  }
  var total = 0
  var i = 0
  while i < len(ats) {
    match param_score(cx, param_at(params, packs, i), ats[i], arities[i]) {
      Some(sc) -> { total = total + sc }
      None -> return None
    }
    i = i + 1
  }
  Some(total)
}

## Two-phase resolution (spec §9.3, after JLS): phase 1 tries every candidate
## without varargs packing; only if that fails does phase 2 pack. The phase,
## not the score, decides first — packing scores grow with arity.
fn fit_score(
  cx: Cx,
  params: List[String],
  is_varargs: Bool,
  ats: List[Option[Ty]],
  arities: List[Int]
) -> Option[(Int, Int)] !io = {
  match score_with(cx, params, false, ats, arities) {
    Some(sc) -> return Some((1, sc))
    None -> ()
  }
  if is_varargs {
    match score_with(cx, params, true, ats, arities) {
      Some(sc) -> return Some((0, sc))
      None -> ()
    }
  }
  None
}

## Error paths: type the deferred arguments so their subtrees get visited.
fn check_deferred(cx: Cx, args: List[Expr], ats: List[Option[Ty]]) -> Cx !io = {
  var cx1 = cx
  var i = 0
  for a in args {
    let deferred = match ats[i] {
      Some(_) -> false
      None -> true
    }
    if deferred {
      let (cxa, _, _) = check_expr(cx1, a, no_expected())
      cx1 = cxa
    }
    i = i + 1
  }
  cx1
}

## The winner is known: type deferred arguments against their SAM's shape and
## validate List-bridged positions (spec §9.4, §9.6). Positions in a packed
## variadic part resolve to the component type.
fn finalize_sams(
  cx: Cx,
  params: List[String],
  packs: Bool,
  args: List[Expr],
  ats: List[Option[Ty]],
  atx: List[Option[TExpr]]
) -> (Cx, List[Option[TExpr]], List[(Int, String, String, List[String], String)], List[Int]) !io = {
  var cx1 = cx
  var atx2 = atx
  var convs: List[(Int, String, String, List[String], String)] = []
  var bridges: List[Int] = []
  var i = 0
  for a in args {
    let p = param_at(params, packs, i)
    match ats[i] {
      None -> {
        let sm = sam_of_nonprim(p).expect("sam scored")
        let ft = sam_fn_ty(sm).expect("sam shape scored")
        let (sps, sret) = ft
        let (cxa, t, ax) = check_expr(cx1, a, Some(TyFn(sps, sret, EIo)))
        cx1 = cxa
        atx2 = list.take(atx2, i) ++ [Some(ax)] ++ list.drop(atx2, i + 1)
        var fits = false
        match t {
          TyFn(tps, tret, _) ->
            if tps == sps && sam_ret_compatible(tret, sm.ret_cls) { fits = true }
          _ -> ()
        }
        if fits { convs = convs ++ [(i, p, sm.name, sm.param_cls, sm.ret_cls)] }
        if not fits && not is_errorish(t) {
          cx1 = cerr_h(cx1, "this function does not fit `" ++ class_info(p).simple ++ "`",
            e_lo(a), e_hi(a),
            "expected shape: " ++ ty_show(cx1.adts, TyFn(sps, sret, EIo)) ++
              "\n  single abstract method: " ++ sm.desc)
        }
      }
      Some(t) ->
        match t {
          TyFn(_, _, _) ->
            match sam_of_nonprim(p) {
              Some(sm2) -> { convs = convs ++ [(i, p, sm2.name, sm2.param_cls, sm2.ret_cls)] }
              None -> ()
            }
          TyList(el) -> {
            # zero-copy bridge: elements cross as their boxed reps, so only
            # scalars, String and Java references may cross (spec §9.6)
            let bridgeable = el == TyInt || el == TyFloat || el == TyBool ||
              el == TyString || is_java_ty(el)
            if bridgeable { bridges = bridges ++ [i] }
            if not bridgeable {
              cx1 = cerr_h(cx1, "cannot bridge " ++ ty_show(cx1.adts, t) ++ " to `" ++
                  class_info(p).simple ++ "`: element type " ++ ty_show(cx1.adts, el) ++
                  " does not cross", e_lo(a), e_hi(a),
                "bridgeable elements: Int, Float, Bool, String, and Java classes; " ++
                  "nested containers, ADTs, tuples and functions stay on the Dawn side (spec §9.6)")
            }
          }
          _ -> ()
        }
    }
    i = i + 1
  }
  (cx1, atx2, convs, bridges)
}

## Java return types → Dawn (spec §9.2): references land wrapped in Option.
fn map_java_return(cx: Cx, rc: String, nlo: Int, nhi: Int) -> (Cx, Ty) !io =
  if rc == "void" {
    (cx, TyUnit)
  } else if rc == "long" || rc == "int" || rc == "short" || rc == "byte" {
    (cx, TyInt)
  } else if rc == "double" || rc == "float" {
    (cx, TyFloat)
  } else if rc == "boolean" {
    (cx, TyBool)
  } else if rc == "char" {
    (cerr_h(cx, "`char` returns are not supported in v0.1", nlo, nhi,
      "there is no char type; wrap the call in the standard library instead"), TyError)
  } else if rc == "java.lang.String" {
    (cx, opt_ty(TyString))
  } else if rc == "[B" {
    # a Java byte[] return is a first-class Bytes (spec §9.5)
    (cx, opt_ty(TyBytes))
  } else {
    # not-imported classes and arrays are still usable as opaque values
    (cx, opt_ty(TyJava(rc, class_info(rc).display)))
  }

## Class.m(a) / value.m(a) / Class.new(a) — the Kotlin checkJavaCall.
fn check_java_call(
  cx: Cx,
  cls: JClass,
  target_tx: Option[TExpr],
  is_static: Bool,
  name: String,
  args: List[Expr],
  nlo: Int,
  nhi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  var cx1 = record_effect(cx, EIo, nlo, nhi, cls.simple ++ "." ++ name)
  var ats: List[Option[Ty]] = []
  var atx: List[Option[TExpr]] = []
  for a in args {
    if sam_deferred(cx1, a) {
      ats = ats ++ [no_expected()]
      atx = atx ++ [no_texpr()]
    } else {
      let (cxa, t, ax) = check_expr(cx1, a, no_expected())
      cx1 = cxa
      ats = ats ++ [Some(t)]
      atx = atx ++ [Some(ax)]
    }
  }
  var arities: List[Int] = []
  for a in args { arities = arities ++ [deferred_arity(cx1, a)] }
  var any_err = false
  for t0 in ats {
    match t0 {
      Some(t) -> if is_errorish(t) { any_err = true }
      None -> ()
    }
  }
  if any_err {
    cx1 = check_deferred(cx1, args, ats)
    return (cx1, TyError, XError(lo, hi))
  }
  var shown: List[String] = []
  var si = 0
  for t0 in ats {
    match t0 {
      Some(t) -> { shown = shown ++ [ty_show(cx1.adts, t)] }
      None -> { shown = shown ++ ["fn/" ++ to_string(arities[si])] }
    }
    si = si + 1
  }
  let show_args = join(shown, ", ")
  if name == "new" {
    if not is_static {
      return (cerr(cx1, "`.new` is called on the class, not on an instance", nlo, nhi),
        TyError, XError(lo, hi))
    }
    let cands = sort_ctors(ctors_of(cls.fqcn))
    var bph = -1
    var bsc = -1
    var best: List[JCtor] = []
    for c in cands {
      match fit_score(cx1, c.param_cls, c.is_varargs, ats, arities) {
        Some(f) -> {
          let (ph, sc) = f
          if ph > bph || (ph == bph && sc > bsc) {
            bph = ph
            bsc = sc
            best = [c]
          } else if ph == bph && sc == bsc {
            best = best ++ [c]
          }
        }
        None -> ()
      }
    }
    if len(best) == 0 {
      cx1 = check_deferred(cx1, args, ats)
      var descs: List[String] = []
      for c in cands { descs = descs ++ ["  " ++ c.desc] }
      return (cerr_h(cx1, "no constructor of `" ++ cls.fqcn ++ "` matches (" ++ show_args ++ ")",
        lo, hi, "candidates:\n" ++ join(descs, "\n")), TyError, XError(lo, hi))
    }
    if len(best) > 1 {
      cx1 = check_deferred(cx1, args, ats)
      var bdescs: List[String] = []
      for c in best { bdescs = bdescs ++ ["  " ++ c.desc] }
      return (cerr_h(cx1, "ambiguous constructor call on `" ++ cls.fqcn ++ "`", lo, hi,
        "candidates:\n" ++ join(bdescs, "\n")), TyError, XError(lo, hi))
    }
    let c = best[0]
    let packs = bph == 0
    let (cxa, atx2, convs, bridges) = finalize_sams(cx1, c.param_cls, packs, args, ats, atx)
    cx1 = cxa
    var fin: List[TExpr] = []
    for sl in atx2 {
      match sl {
        Some(ax) -> { fin = fin ++ [ax] }
        None -> { fin = fin ++ [XError(lo, hi)] }
      }
    }
    let vp: Option[Int] = if packs { Some(len(c.param_cls) - 1) } else { None }
    let call = TJavaCall {
      fqcn: cls.fqcn,
      decl_cls: cls.fqcn,
      method: "new",
      param_cls: c.param_cls,
      ret_cls: cls.fqcn,
      is_static: true,
      is_ctor: true,
      is_field: false,
      target: None,
      args: fin,
      varargs_pack: vp,
      sam_convs: convs,
      list_bridges: bridges,
      nlo: nlo,
      nhi: nhi
    }
    # .new returns T — a constructor never returns null; a constructed
    # java.lang.String is an ordinary Dawn String
    let rt = if cls.fqcn == "java.lang.String" { TyString } else { TyJava(cls.fqcn, cls.display) }
    return (cx1, rt, XJava(call, lo, hi, rt))
  }
  var matching: List[JMethod] = []
  for m0 in methods_of(cls.fqcn) {
    if m0.name == name && m0.is_static == is_static { matching = matching ++ [m0] }
  }
  var same_name: List[JMethod] = []
  var seen_sigs: List[String] = []
  for m2 in sort_methods(matching) {
    let sig_key = join(m2.param_cls, ",")
    var dup = false
    for s0 in seen_sigs {
      if s0 == sig_key { dup = true }
    }
    if not dup {
      seen_sigs = seen_sigs ++ [sig_key]
      same_name = same_name ++ [m2]
    }
  }
  if len(same_name) == 0 {
    cx1 = check_deferred(cx1, args, ats)
    let shape = if is_static {
      "Class.method(...) for statics"
    } else {
      "value.method(...) for instance methods"
    }
    let stat = if is_static { "static " } else { "" }
    return (cerr_h(cx1, "`" ++ cls.fqcn ++ "` has no " ++ stat ++ "method `" ++ name ++ "`",
      nlo, nhi, "Java calls are " ++ shape ++ "; fields are not supported in v0.1"),
      TyError, XError(lo, hi))
  }
  var bph = -1
  var bsc = -1
  var best: List[JMethod] = []
  for m2 in same_name {
    match fit_score(cx1, m2.param_cls, m2.is_varargs, ats, arities) {
      Some(f) -> {
        let (ph, sc) = f
        if ph > bph || (ph == bph && sc > bsc) {
          bph = ph
          bsc = sc
          best = [m2]
        } else if ph == bph && sc == bsc {
          best = best ++ [m2]
        }
      }
      None -> ()
    }
  }
  if len(best) == 0 {
    cx1 = check_deferred(cx1, args, ats)
    var descs: List[String] = []
    for m2 in same_name { descs = descs ++ ["  " ++ m2.desc] }
    return (cerr_h(cx1, "no overload of `" ++ cls.simple ++ "." ++ name ++ "` matches (" ++
        show_args ++ ")", lo, hi, "candidates:\n" ++ join(descs, "\n")),
      TyError, XError(lo, hi))
  }
  if len(best) > 1 {
    cx1 = check_deferred(cx1, args, ats)
    var bdescs: List[String] = []
    for m2 in best { bdescs = bdescs ++ ["  " ++ m2.desc] }
    return (cerr_h(cx1, "ambiguous call to `" ++ cls.simple ++ "." ++ name ++ "`", lo, hi,
      "candidates:\n" ++ join(bdescs, "\n")), TyError, XError(lo, hi))
  }
  let m3 = best[0]
  let packs = bph == 0
  let (cxb, atx3, convs, bridges) = finalize_sams(cx1, m3.param_cls, packs, args, ats, atx)
  cx1 = cxb
  var fin: List[TExpr] = []
  for sl in atx3 {
    match sl {
      Some(ax) -> { fin = fin ++ [ax] }
      None -> { fin = fin ++ [XError(lo, hi)] }
    }
  }
  let (cxc, rt) = map_java_return(cx1, m3.ret_cls, nlo, nhi)
  cx1 = cxc
  let vp: Option[Int] = if packs { Some(len(m3.param_cls) - 1) } else { None }
  let call = TJavaCall {
    fqcn: cls.fqcn,
    decl_cls: m3.decl_cls,
    method: name,
    param_cls: m3.param_cls,
    ret_cls: m3.ret_cls,
    is_static: is_static,
    is_ctor: false,
    is_field: false,
    target: target_tx,
    args: fin,
    varargs_pack: vp,
    sam_convs: convs,
    list_bridges: bridges,
    nlo: nlo,
    nhi: nhi
  }
  (cx1, rt, XJava(call, lo, hi, rt))
}

## Is `target` a bare java class name (a nullary ctor spelling that resolves to a
## `use java` class and shadows nothing)? Returns its fqcn — the receiver of a
## `Class.FIELD` static field read. Mirrors the static-call guard in check_method_call.
fn static_field_target(cx: Cx, target: Expr) -> Option[String] =
  match target {
    ECtor(cn, cargs, sp, hp, _, _, _, _) ->
      if not hp && len(cargs) == 0 && sp == None &&
      not map.has(cx.ctors_by_name, cn) && not map.has(cx.consts, cn) {
        map.get(cx.java_classes, cn)
      } else {
        None
      }
    _ -> None
  }

## Class.FIELD — a read-only public static field (spec §9.1). The value maps by
## §9.2 exactly like a method return (references wrap in Option, small ints/floats
## widen); the read is !io like every Java interop.
fn check_java_static_field(
  cx: Cx,
  fq: String,
  fname: String,
  flo: Int,
  fhi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  var found: Option[JField] = None
  for f in static_fields_of(fq) {
    match found {
      None -> if f.name == fname { found = Some(f) }
      Some(_) -> ()
    }
  }
  match found {
    None -> (cerr_h(cx, "`" ++ fq ++ "` has no static field `" ++ fname ++ "`", flo, fhi,
      "only public static fields are readable; instance fields and methods are not"),
      TyError, XError(lo, hi))
    Some(f) -> {
      let cx1 = record_effect(cx, EIo, flo, fhi, fq ++ "." ++ fname)
      let (cx2, ty) = map_java_return(cx1, f.type_cls, flo, fhi)
      let empty_params: List[String] = []
      let empty_args: List[TExpr] = []
      let no_convs: List[(Int, String, String, List[String], String)] = []
      let no_bridges: List[Int] = []
      let call = TJavaCall {
        fqcn: fq,
        decl_cls: f.decl_cls,
        method: fname,
        param_cls: empty_params,
        ret_cls: f.type_cls,
        is_static: true,
        is_ctor: false,
        is_field: true,
        target: None,
        args: empty_args,
        varargs_pack: None,
        sam_convs: no_convs,
        list_bridges: no_bridges,
        nlo: flo,
        nhi: fhi
      }
      (cx2, ty, XJava(call, lo, hi, ty))
    }
  }
}

# ---- method calls (x.f(a)) ----

## alias.fn(args): a call to a pub function of an imported module (spec §10.3).
fn check_module_call(
  cx: Cx,
  al: String,
  name: String,
  args: List[Expr],
  expected: Option[Ty],
  nlo: Int,
  nhi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  var cx1 = cx
  match map.get(cx1.module_fn_sigs, (al, name)) {
    # reuse the ordinary call machinery with the resolved (imported) signature
    Some(s) -> check_call(cx1, name, args, expected, None, Some(s), nlo, nhi, lo, hi)
    None -> {
      for a in args {
        let (cxa, _, _) = check_expr(cx1, a, no_expected())
        cx1 = cxa
      }
      let mod_path = match map.get(cx1.module_aliases, al) {
        Some(p) -> p
        None -> al
      }
      match map.get(cx1.module_exports, al) {
        Some(ex) -> {
          var in_all = false
          for n2 in ex.all_names {
            if n2 == name { in_all = true }
          }
          if in_all {
            return (cerr_h(cx1, "`" ++ name ++ "` is private to module `" ++ ex.mod_path ++ "`",
              nlo, nhi, "add `pub` to its declaration in " ++ ex.mod_path),
              TyError, XError(lo, hi))
          }
          if map.has(ex.types_by_name, name) || map.has(ex.consts, name) {
            return (cerr(cx1, "`" ++ name ++ "` is not a function; import it with `use " ++
                ex.mod_path ++ ".{" ++ name ++ "}`", nlo, nhi), TyError, XError(lo, hi))
          }
          (cerr_o(cx1, "module `" ++ ex.mod_path ++ "` has no exported function `" ++ name ++ "`",
            nlo, nhi, suggest.hint(name, map.keys(ex.fns))), TyError, XError(lo, hi))
        }
        None ->
          (cerr(cx1, "module `" ++ mod_path ++ "` has no exported function `" ++ name ++ "`",
            nlo, nhi), TyError, XError(lo, hi))
      }
    }
  }
}

## x.f(a): module-qualified (alias.f), Java static (Class.m), Java instance
## (value.m), a fn-typed record field, or UFCS f(x, a) — the Kotlin checkMethodCall.
fn check_method_call(
  cx: Cx,
  target: Expr,
  name: String,
  args: List[Expr],
  expected: Option[Ty],
  nlo: Int,
  nhi: Int,
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  var cx1 = cx
  # module-qualified call: alias.fn(args), where alias is a whole-module import
  match target {
    EVar(rname, _, _) ->
      if lookup(cx1, rname) == None && map.has(cx1.module_aliases, rname) {
        return check_module_call(cx1, rname, name, args, expected, nlo, nhi, lo, hi)
      }
    _ -> ()
  }
  # static namespace / constructor: System.exit(1), StringBuilder.new()
  match target {
    ECtor(cn, cargs2, sp2, hp2, _, _, _, _) ->
      if not hp2 && len(cargs2) == 0 && sp2 == None &&
      not map.has(cx1.ctors_by_name, cn) && not map.has(cx1.consts, cn) {
        match map.get(cx1.java_classes, cn) {
          Some(fq) ->
            return check_java_call(cx1, class_info(fq), None, true, name, args, nlo, nhi, lo, hi)
          None -> ()
        }
      }
    _ -> ()
  }
  let (cx2, tt, tx) = check_expr(cx1, target, no_expected())
  cx1 = cx2
  match tt {
    TyJava(fq, _) ->
      return check_java_call(cx1, class_info(fq), Some(tx), false, name, args, nlo, nhi, lo, hi)
    _ -> ()
  }
  if is_errorish(tt) {
    for a in args {
      let (cxa, _, _) = check_expr(cx1, a, no_expected())
      cx1 = cxa
    }
    return (cx1, TyError, XError(lo, hi))
  }
  # a record field holding a function: r.f(a) calls the field value. When a
  # function `f` is ALSO in scope the call is ambiguous and errors out (spec §2.4)
  match tt {
    TyAdt(aid, targs) -> {
      let ad = adt_of(cx1.adts, aid)
      if ad.is_record {
        let ci = ad.ctors[0]
        var fidx = -1
        var k = 0
        for f in ci.fields {
          if fidx < 0 && f.name == name { fidx = k }
          k = k + 1
        }
        if fidx >= 0 {
          var im: Map[Int, Ty] = map.empty()
          var ti = 0
          for tp in ad.tparams {
            match tp {
              TyVar(_, vid) ->
                match get(targs, ti) {
                  Some(ta) -> { im = map.insert(im, vid, ta) }
                  None -> ()
                }
              _ -> ()
            }
            ti = ti + 1
          }
          let em0: Map[Int, Eff] = map.empty()
          let ftype = subst(ci.fields[fidx].ty, im, em0)
          match ftype {
            TyFn(fps, fret, feff) -> {
              let fn_in_scope = lookup(cx1, name) != None ||
                lookup_fn_sig(cx1, name) != None
              if fn_in_scope {
                for a in args {
                  let (cxa, _, _) = check_expr(cx1, a, no_expected())
                  cx1 = cxa
                }
                return (cerr_h(cx1, "`" ++ name ++
                    "` is both a function in scope and a fn-typed field of `" ++ ad.name ++
                    "` — ambiguous call", nlo, nhi,
                  "for the field, bind it first: `let g = <recv>." ++ name ++ "` then `g(...)`; " ++
                    "for the function, call it directly: `" ++ name ++ "(<recv>, ...)`"),
                  TyError, XError(lo, hi))
              }
              let fx = XField(tx, fidx, e_lo(target), nhi, ftype)
              if len(args) != len(fps) {
                for a in args {
                  let (cxa, _, _) = check_expr(cx1, a, no_expected())
                  cx1 = cxa
                }
                cx1 = cerr_h(cx1, "`" ++ name ++ "` takes " ++ to_string(len(fps)) ++
                    " argument(s), got " ++ to_string(len(args)), lo, hi,
                  "field type: " ++ ty_show(cx1.adts, ftype))
                return (cx1, fret, XError(lo, hi))
              }
              var txs: List[TExpr] = []
              var ai = 0
              for a in args {
                let pt = fps[ai]
                let (cxa, at, ax) = check_expr(cx1, a, Some(pt))
                cx1 = cxa
                if not assignable(cx1, at, pt) {
                  cx1 = cerr(cx1, "argument type mismatch: expected " ++ ty_show(cx1.adts, pt) ++
                      ", got " ++ ty_show(cx1.adts, at), e_lo(a), e_hi(a))
                }
                txs = txs ++ [ax]
                ai = ai + 1
              }
              cx1 = record_effect(cx1, feff, nlo, nhi, name)
              return (cx1, fret, XApply(fx, txs, lo, hi, fret))
            }
            _ -> ()
          }
        }
      }
    }
    _ -> ()
  }
  # UFCS: x.f(a) is f(x, a) (spec §4.3); the receiver is already checked
  check_call(cx1, name, [target] ++ args, expected, Some((tt, tx)), no_sig(), nlo, nhi, lo, hi)
}

# ---- match ----

fn wilds_of(n: Int) -> List[SPat] = {
  var out: List[SPat] = []
  for _i in 0 ..n { out = out ++ [SWild] }
  out
}

## Lower a checked pattern for the exhaustiveness algorithm; broken patterns
## already became wildcards during checking (their errors are reported).
fn to_spat(p: TPat) -> SPat =
  match p {
    TPWild -> SWild
    TPBind(_, _) -> SWild
    TPLit(v) -> SLit(v)
    TPTuple(elems) -> {
      var subs: List[SPat] = []
      for s in elems { subs = subs ++ [to_spat(s)] }
      STuple(subs)
    }
    TPList(pre, has_rest, _, post) -> {
      var pres: List[SPat] = []
      for s in pre { pres = pres ++ [to_spat(s)] }
      var posts: List[SPat] = []
      for s in post { posts = posts ++ [to_spat(s)] }
      SList(pres, has_rest, posts)
    }
    TPCtor(aid, ci, fps) -> {
      var subs: List[SPat] = []
      for fp in fps {
        match fp {
          Some(s) -> { subs = subs ++ [to_spat(s)] }
          None -> { subs = subs ++ [SWild] }
        }
      }
      SCtor(aid, ci, subs)
    }
  }

fn check_match(
  cx: Cx,
  scrut: Expr,
  arms: List[MatchArm],
  expected: Option[Ty],
  lo: Int,
  hi: Int
) -> (Cx, Ty, TExpr) !io = {
  let (cx0, st, sx) = check_expr(cx, scrut, no_expected())
  var cx1 = cx0
  let scrut_ok = st == TyInt || st == TyFloat || st == TyString || st == TyBool ||
    is_adt(st) || is_tuple_ty(st) || is_list_ty(st)
  if not scrut_ok && not is_errorish(st) {
    cx1 = cerr(cx1, "match supports Int/Float/String/Bool, tuples, lists and user-defined types, got " ++
        ty_show(cx1.adts, st), e_lo(scrut), e_hi(scrut))
  }
  var result = TyNever
  # concrete-typed arms first so an inference-only arm body (bare `None`, `[]`)
  # can borrow the result type from its siblings as its expected — the empty-list
  # two-pass (§EListLit) applied to arm bodies. Typed arms are reassembled in
  # source order for exhaustiveness + codegen.
  var order: List[Int] = []
  var oi = 0
  for arm in arms {
    if not needs_expected(cx1, arm.body) { order = order ++ [oi] }
    oi = oi + 1
  }
  oi = 0
  for arm in arms {
    if needs_expected(cx1, arm.body) { order = order ++ [oi] }
    oi = oi + 1
  }
  var slots: List[Option[TArm]] = []
  for _s in 0 ..len(arms) {
    let empty: Option[TArm] = None
    slots = slots ++ [empty]
  }
  for idx in order {
    let arm = arms[idx]
    cx1 = push_scope(cx1)
    if len(arm.pats) > 1 {
      # or-patterns must not bind: each alternative would need identical bindings
      for p in arm.pats {
        if binds_anything(p) {
          cx1 = cerr(cx1, "or-pattern alternatives cannot introduce bindings", pat_lo(p), pat_hi(p))
        }
      }
    }
    var tpats: List[TPat] = []
    for p in arm.pats {
      let (cxa, tp) = check_pattern(cx1, p, st, false)
      cx1 = cxa
      tpats = tpats ++ [tp]
    }
    var tguard: Option[TExpr] = None
    match arm.guard {
      Some(g) -> {
        let (cxa, gt, gx) = check_expr(cx1, g, no_expected())
        cx1 = cxa
        if gt != TyBool && not is_errorish(gt) {
          cx1 = cerr(cx1, "guard must be Bool, got " ++ ty_show(cx1.adts, gt), e_lo(g), e_hi(g))
        }
        tguard = Some(gx)
      }
      None -> ()
    }
    # prefer the match's own expected; else the result inferred from concrete arms
    let arm_exp: Option[Ty] = match expected {
      Some(e) -> Some(e)
      None -> if result != TyNever && is_concrete(cx1, result) { Some(result) } else { None }
    }
    let (cxb, bt, bx) = check_expr(cx1, arm.body, arm_exp)
    cx1 = cxb
    let (cxc, unified) = unify_branches(cx1, result, bt, e_lo(arm.body), e_hi(arm.body),
      "the match arms")
    cx1 = cxc
    result = unified
    cx1 = pop_scope(cx1)
    slots = list.take(slots, idx) ++
      [Some(TArm { pats: tpats, guard: tguard, body: bx })] ++ list.drop(slots, idx + 1)
  }
  var tarms: List[TArm] = []
  for s in slots {
    match s {
      Some(t) -> { tarms = tarms ++ [t] }
      None -> ()
    }
  }
  # exhaustiveness (guarded arms can fail their guard, so they don't count)
  if scrut_ok {
    var rows: List[List[SPat]] = []
    var ai = 0
    for arm in arms {
      let unguarded = match arm.guard {
        Some(_) -> false
        None -> true
      }
      if unguarded {
        let ta = tarms[ai]
        for tp in ta.pats { rows = rows ++ [[to_spat(tp)]] }
      }
      ai = ai + 1
    }
    let tys = [st]
    if useful(cx1.adts, rows, [SWild], tys) {
      let missing = match st {
        TyAdt(aid, _) -> {
          let ad = adt_of(cx1.adts, aid)
          var names: List[String] = []
          var ci2 = 0
          for c in ad.ctors {
            if useful(cx1.adts, rows, [SCtor(aid, ci2, wilds_of(len(c.fields)))], tys) {
              names = names ++ [c.name]
            }
            ci2 = ci2 + 1
          }
          join(names, ", ")
        }
        TyBool -> {
          var names: List[String] = []
          if useful(cx1.adts, rows, [SLit(LBool(true))], tys) { names = names ++ ["true"] }
          if useful(cx1.adts, rows, [SLit(LBool(false))], tys) { names = names ++ ["false"] }
          join(names, ", ")
        }
        TyList(_) -> join(missing_list_patterns(cx1.adts, rows, st), ", ")
        _ -> "_ (" ++ ty_show(cx1.adts, st) ++ " has too many values to enumerate)"
      }
      let hint = if is_adt(st) {
        "add arms for the missing constructors, or a catch-all _"
      } else {
        "add an unguarded catch-all arm (a binding or _)"
      }
      cx1 = cerr_h(cx1, "non-exhaustive match, missing: " ++ missing, lo, hi, hint)
    }
  }
  (cx1, result, XMatch(sx, tarms, lo, hi, result))
}

# ---- expression checker tests ----

test "check_expr: literals, locals and undefined variables" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  let (cx0, _) = declare(cx, "x", TyInt, false, 0, 1)
  let (cx1, t, node) = check_expr(cx0, EVar("x", 2, 3), no_expected())
  assert t == TyInt
  assert len(cx1.diags) == 0
  match node {
    XLocal(_, n, ..) -> { assert n == "x" }
    _ -> { assert false }
  }
  let (cx2, t2, _) = check_expr(cx0, EVar("nope", 2, 6), no_expected())
  assert t2 == TyError
  assert cx2.diags[0].msg == "undefined variable: nope"
}

test "blocks scope lets, type tails and flag discards" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  # { let a = 1  a + 2 } : Int
  let blk = EBlock([SLet("a", false, None, EInt(1, 6, 7), 2, 7)],
    Some(EBinary(OpAdd, EVar("a", 10, 11), EInt(2, 14, 15), 12, 13, 10, 15)), 0, 16)
  let (cx1, t, _) = check_expr(cx, blk, no_expected())
  assert t == TyInt
  assert len(cx1.diags) == 0
  # a non-Unit statement value is discarded
  let blk2 = EBlock([SExpr(EInt(1, 2, 3), 2, 3)], None, 0, 5)
  let (cx2, t2, _) = check_expr(cx, blk2, no_expected())
  assert t2 == TyUnit
  assert str.contains(cx2.diags[0].msg, "value is discarded")
  # the let is scoped to the block
  let (cx3, _, _) = check_expr(cx1, EVar("a", 20, 21), no_expected())
  assert str.contains(cx3.diags[len(cx3.diags) - 1].msg, "undefined variable: a")
}

test "lambdas infer parameters from expected types and track captures" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  let (cxk, _) = declare(cx, "k", TyInt, false, 0, 1)
  # fn(x) => x + k against fn(Int) -> Int captures k
  let lam = ELambda([LambdaParam { name: "x", ann: None, lo: 3, hi: 4 }],
    EBinary(OpAdd, EVar("x", 9, 10), EVar("k", 13, 14), 11, 12, 9, 14), 0, 14)
  let (cx1, t, node) = check_expr(cxk, lam, Some(TyFn([TyInt], TyInt, EPure)))
  assert t == TyFn([TyInt], TyInt, EPure)
  assert len(cx1.diags) == 0
  match node {
    XLambda(_, _, _, caps, ..) -> { assert len(caps) == 1 }
    _ -> { assert false }
  }
  # without context the parameter cannot be inferred
  let (cx2, _, _) = check_expr(cxk, lam, no_expected())
  assert str.contains(cx2.diags[0].msg, "cannot infer the type of `x`")
  # a var cannot be captured
  let (cxv, _) = declare(cxk, "v", TyInt, true, 0, 1)
  let lam2 = ELambda([LambdaParam { name: "y", ann: None, lo: 3, hi: 4 }],
    EVar("v", 9, 10), 0, 10)
  let (cx3, _, _) = check_expr(cxv, lam2, Some(TyFn([TyInt], TyInt, EPure)))
  assert str.contains(cx3.diags[0].msg, "lambdas cannot capture `var` bindings")
}

test "apply: piping arguments into an unannotated lambda" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  let lam = ELambda([LambdaParam { name: "x", ann: None, lo: 1, hi: 2 }], EVar("x", 7, 8), 0, 8)
  let ap = EApply(lam, [EInt(1, 10, 11)], 0, 12)
  let (cx1, t, _) = check_expr(cx, ap, no_expected())
  assert t == TyInt
  assert len(cx1.diags) == 0
  # calling a non-function
  let (cxa, _) = declare(cx, "n", TyInt, false, 0, 1)
  let ap2 = EApply(EVar("n", 0, 1), [], 0, 3)
  let (cx2, _, _) = check_expr(cxa, ap2, no_expected())
  assert str.contains(cx2.diags[0].msg, "cannot call a value of type Int")
}

test "calls: builtins, dynamic targets, arity and undefined" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  # len([1]) : Int
  let call = ECall("len", [EListLit([EInt(1, 5, 6)], 4, 7)], 0, 3, 0, 8)
  let (cx1, t, _) = check_expr(cx, call, no_expected())
  assert t == TyInt
  assert len(cx1.diags) == 0
  # a local fn value is a dynamic call target
  let (cxa, _) = declare(cx, "f", TyFn([TyInt], TyBool, EPure), false, 0, 1)
  let (cx2, t2, node2) = check_expr(cxa, ECall("f", [EInt(1, 2, 3)], 0, 1, 0, 4), no_expected())
  assert t2 == TyBool
  match node2 {
    XCallDyn(_, n, ..) -> { assert n == "f" }
    _ -> { assert false }
  }
  # arity mismatch reports the signature
  let bad = ECall("len", [], 0, 3, 0, 5)
  let (cx3, _, _) = check_expr(cx, bad, no_expected())
  assert str.contains(cx3.diags[0].msg, "`len` takes 1 argument(s), got 0")
  # undefined
  let (cx4, _, _) = check_expr(cx, ECall("nope", [], 0, 4, 0, 6), no_expected())
  assert cx4.diags[0].msg == "undefined function: nope"
}

test "ctor calls infer type arguments; constants land as refs" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  # Some(1) : Option[Int]
  let e = ECtor("Some", [CtorArg { name: None, e: EInt(1, 5, 6), lo: 5, hi: 6 }],
    None, true, 0, 4, 0, 7)
  let (cx1, t, _) = check_expr(cx, e, no_expected())
  assert t == opt_ty(TyInt)
  assert len(cx1.diags) == 0
  # bare None cannot infer without context, lands with one
  let e2 = ECtor("None", [], None, false, 0, 4, 0, 4)
  let (cx2, _, _) = check_expr(cx, e2, no_expected())
  assert str.contains(cx2.diags[0].msg, "cannot infer type parameter(s) T for `None`")
  let (cx3, t3, _) = check_expr(cx, e2, Some(opt_ty(TyString)))
  assert t3 == opt_ty(TyString)
  assert len(cx3.diags) == 0
  # a SCREAMING const reference
  cx = Cx { ..cx, consts: map.insert(cx.consts, "LIMIT", TyInt) }
  let (cx4, t4, node4) = check_expr(cx, ECtor("LIMIT", [], None, false, 0, 5, 0, 5), no_expected())
  assert t4 == TyInt
  match node4 {
    XConstRef(n, ..) -> { assert n == "LIMIT" }
    _ -> { assert false }
  }
}

test "match checks arms, unifies results and demands exhaustiveness" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  let (cxo, _) = declare(cx, "o", opt_ty(TyInt), false, 0, 1)
  let arm = MatchArm {
    pats: [PCtor("Some", [PatArg { name: None, pat: PBind("v", 10, 11) }],
      false, true, 5, 9, 5, 12)],
    guard: None,
    body: EVar("v", 16, 17),
    lo: 5,
    hi: 17
  }
  let m1 = EMatch(EVar("o", 0, 1), [arm], 0, 18)
  let (cx1, t, _) = check_expr(cxo, m1, no_expected())
  assert t == TyInt
  assert cx1.diags[0].msg == "non-exhaustive match, missing: None"
  # a wildcard arm completes it
  let arm2 = MatchArm { pats: [PWild(20, 21)], guard: None, body: EInt(0, 25, 26), lo: 20, hi: 26 }
  let m2 = EMatch(EVar("o", 0, 1), [arm, arm2], 0, 27)
  let (cx2, t2, _) = check_expr(cxo, m2, no_expected())
  assert t2 == TyInt
  assert len(cx2.diags) == 0
  # a guarded arm does not count toward exhaustiveness
  let arm3 = MatchArm {
    pats: [PWild(20, 21)],
    guard: Some(EBool(true, 22, 26)),
    body: EInt(0, 30, 31),
    lo: 20,
    hi: 31
  }
  let m3 = EMatch(EVar("o", 0, 1), [arm, arm3], 0, 32)
  let (cx3, _, _) = check_expr(cxo, m3, no_expected())
  assert str.contains(cx3.diags[0].msg, "non-exhaustive match")
}

test "statements: assignment rules and loop jump tracking" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  # { var i = 0  while true { i = i + 1  break } } — has_jumps lands on the while
  let wbody = EBlock([
    SAssign("i", EBinary(OpAdd, EVar("i", 30, 31), EInt(1, 34, 35), 32, 33, 30, 35),
      26, 27, 26, 35),
    SExpr(EBreak(38, 43), 38, 43)
  ], None, 24, 45)
  let blk = EBlock([
    SLet("i", true, None, EInt(0, 10, 11), 2, 11),
    SWhile(EBool(true, 18, 22), wbody, 12, 45)
  ], None, 0, 47)
  let (cx1, t, node) = check_expr(cx, blk, no_expected())
  assert t == TyUnit
  assert len(cx1.diags) == 0
  match node {
    XBlock(stmts, ..) ->
      match stmts[1] {
        TSWhile(_, _, hj, _, _) -> { assert hj }
        _ -> { assert false }
      }
    _ -> { assert false }
  }
  # assigning to a let is rejected
  let blk2 = EBlock([
    SLet("a", false, None, EInt(0, 10, 11), 2, 11),
    SAssign("a", EInt(1, 16, 17), 12, 13, 12, 17)
  ], None, 0, 19)
  let (cx2, _, _) = check_expr(cx, blk2, no_expected())
  assert str.contains(cx2.diags[0].msg, "`a` is a let binding and cannot be assigned")
  # break outside a loop
  let (cx3, _, _) = check_expr(cx, EBreak(0, 5), no_expected())
  assert str.contains(cx3.diags[0].msg, "`break` can only be used inside a loop body")
}

test "unsafe_pure masks io and flags redundancy" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  # a pure body makes the stamp a no-op
  let e = EUnsafePure(EInt(1, 12, 13), 0, 14)
  let (cx1, t, _) = check_expr(cx, e, no_expected())
  assert t == TyInt
  assert str.contains(cx1.diags[0].msg, "redundant unsafe_pure")
  # a Java-call body (io) is masked: no diags, no recorded effect
  cx = Cx { ..cx, java_classes: map.insert(cx.java_classes, "Long", "java.lang.Long") }
  let recv = ECtor("Long", [], None, false, 12, 16, 12, 16)
  let jc = EMethod(recv, "toHexString", [EInt(5, 29, 30)], 17, 28, 12, 31)
  let p = EUnsafePure(jc, 0, 33)
  let (cx2, t2, _) = check_expr(cx, p, no_expected())
  assert t2 == opt_ty(TyString)
  assert len(cx2.diags) == 0
  assert len(cx2.used_effects) == 0
}

test "java calls resolve overloads, wrap references and reject unknowns" {
  var cx = seed_prelude(test_cx())
  cx = Cx { ..cx, java_classes: map.insert(cx.java_classes, "Math", "java.lang.Math") }
  cx = Cx { ..cx, java_classes: map.insert(cx.java_classes, "Long", "java.lang.Long") }
  cx = push_scope(cx)
  # Math.abs(1): the long overload beats int; primitive return is Int
  let recv = ECtor("Math", [], None, false, 0, 4, 0, 4)
  let call = EMethod(recv, "abs", [EInt(1, 9, 10)], 5, 8, 0, 11)
  let (cx1, t, node) = check_expr(cx, call, no_expected())
  assert t == TyInt
  assert len(cx1.diags) == 0
  match node {
    XJava(jc, ..) -> {
      assert jc.fqcn == "java.lang.Math"
      assert jc.param_cls == ["long"]
      assert jc.is_static
    }
    _ -> { assert false }
  }
  # a String return lands as Option[String]
  let recv2 = ECtor("Long", [], None, false, 0, 4, 0, 4)
  let call2 = EMethod(recv2, "toHexString", [EInt(5, 17, 18)], 5, 16, 0, 19)
  let (cx2, t2, _) = check_expr(cx, call2, no_expected())
  assert t2 == opt_ty(TyString)
  assert len(cx2.diags) == 0
  # unknown method names every candidate shape
  let call3 = EMethod(recv, "nosuch", [], 5, 11, 0, 13)
  let (cx3, _, _) = check_expr(cx, call3, no_expected())
  assert str.contains(cx3.diags[0].msg, "`java.lang.Math` has no static method `nosuch`")
}

test "static field access reads Class.FIELD, maps types, rejects unknowns" {
  var cx = seed_prelude(test_cx())
  cx = Cx { ..cx, java_classes: map.insert(cx.java_classes, "Math", "java.lang.Math") }
  cx = Cx { ..cx, java_classes: map.insert(cx.java_classes, "Integer", "java.lang.Integer") }
  cx = push_scope(cx)
  # Math.PI is a double -> Float; the node is a field read
  let recv = ECtor("Math", [], None, false, 0, 4, 0, 4)
  let f1 = EFieldAcc(recv, "PI", 5, 7, 0, 7)
  let (cx1, t1, node) = check_expr(cx, f1, no_expected())
  assert t1 == TyFloat
  assert len(cx1.diags) == 0
  match node {
    XJava(jc, ..) -> {
      assert jc.is_field
      assert jc.method == "PI"
      assert jc.fqcn == "java.lang.Math"
    }
    _ -> { assert false }
  }
  # Integer.MAX_VALUE is an int -> Int
  let recv2 = ECtor("Integer", [], None, false, 0, 7, 0, 7)
  let f2 = EFieldAcc(recv2, "MAX_VALUE", 8, 17, 0, 17)
  let (cx2, t2, _) = check_expr(cx, f2, no_expected())
  assert t2 == TyInt
  # a bogus field name is a clear error
  let f3 = EFieldAcc(recv, "NOPE", 5, 9, 0, 9)
  let (cx3, _, _) = check_expr(cx, f3, no_expected())
  assert str.contains(cx3.diags[0].msg, "has no static field `NOPE`")
}

test "ufcs rewrites x.f(a) into f(x, a) with the receiver pre-typed" {
  var cx = seed_prelude(test_cx())
  cx = push_scope(cx)
  let (cxa, _) = declare(cx, "xs", TyList(TyInt), false, 0, 2)
  let u = EMethod(EVar("xs", 0, 2), "len", [], 3, 6, 0, 8)
  let (cx1, t, node) = check_expr(cxa, u, no_expected())
  assert t == TyInt
  assert len(cx1.diags) == 0
  match node {
    XCallBuiltin(n, args2, ..) -> {
      assert n == "len"
      assert len(args2) == 1
    }
    _ -> { assert false }
  }
}

# ---- pass 5 driver: function bodies, const initializers, tests ----

## Mint dictionary symbols for a signature's trait bounds (the Kotlin
## bindDicts): typed as the tvar itself, marked with (trait, tvar).
fn bind_dicts(cx: Cx, s: Sig, nlo: Int, nhi: Int) -> Cx = {
  let empty_d: Map[(Int, Int), Int] = map.empty()
  var any = false
  for bs in s.constraints {
    if len(bs) > 0 { any = true }
  }
  if not any { return Cx { ..cx, dict_syms: empty_d } }
  var cx1 = Cx { ..cx, dict_syms: empty_d }
  var i = 0
  for tp in s.tparams {
    for tr_id in bounds_of(s, i) {
      match tp {
        TyVar(tn, vid) -> {
          let tr = trait_of(cx1.traits, tr_id)
          let (cx2, sid) = fresh(cx1)
          let sym = Sym {
            name: tr.name ++ "$" ++ tn,
            ty: tp,
            mutable: false,
            dlo: nlo,
            dhi: nhi,
            dict_of: Some((tr_id, vid))
          }
          cx1 = Cx {
            ..cx2,
            syms: map.insert(cx2.syms, sid, sym),
            dict_syms: map.insert(cx2.dict_syms, (vid, tr_id), sid)
          }
        }
        _ -> ()
      }
    }
    i = i + 1
  }
  cx1
}

## The signature's dictionary symbols in bound order (codegen appends them
## behind the declared parameters in exactly this order).
fn dict_sym_list(cx: Cx, s: Sig) -> List[Int] = {
  var out: List[Int] = []
  var i = 0
  for tp in s.tparams {
    for tr_id in bounds_of(s, i) {
      match tp {
        TyVar(_, vid) ->
          match map.get(cx.dict_syms, (vid, tr_id)) {
            Some(sid) -> { out = out ++ [sid] }
            None -> ()
          }
        _ -> ()
      }
    }
    i = i + 1
  }
  out
}

## The shared prologue of checkFn and friends: bind the signature frame and
## dictionaries, fresh effect record, one root scope.
fn enter_fn(cx: Cx, s: Sig, ev: Map[String, Eff], nlo: Int, nhi: Int) -> Cx = {
  var tp: Map[String, Ty] = map.empty()
  for tv in s.tparams {
    match tv {
      TyVar(tn, _) -> { tp = map.insert(tp, tn, tv) }
      _ -> ()
    }
  }
  var cx1 = Cx { ..cx, current_tparams: tp, current_eff_vars: ev, current_sig: Some(s) }
  cx1 = bind_dicts(cx1, s, nlo, nhi)
  let empty_w: Map[Eff, (Int, Int, String)] = map.empty()
  cx1 = Cx {
    ..cx1,
    used_effects: [],
    eff_witness: empty_w,
    lambda_stack: [],
    loop_stack: [],
    scopes: []
  }
  push_scope(cx1)
}

## The signature is the promise: every used effect must be subsumed by the
## declared one. `where2` finishes the hint ("the end of the signature" /
## "the trait method").
fn verify_effects(
  cx: Cx,
  kind: String,
  name: String,
  declared: Eff,
  where2: String,
  nlo: Int,
  nhi: Int
) -> Cx = {
  var cx1 = cx
  for used in cx.used_effects {
    if not eff_subsumes(declared, used) {
      let (wlo, whi, wname) = match map.get(cx.eff_witness, used) {
        Some(w) -> w
        None -> (nlo, nhi, "?")
      }
      cx1 = cerr_h(cx1, kind ++ " `" ++ name ++ "` is not declared !" ++ eff_show(used) ++
          " but calls `" ++ wname ++ "` (!" ++ eff_show(used) ++ ")", wlo, whi,
        "add !" ++ eff_show(used) ++ " to " ++ where2 ++ ", or remove the call")
    }
  }
  cx1
}

## Check one annotated function body against its signature (the Kotlin checkFn).
pub fn check_fn(cx: Cx, d: FnDecl, s: Sig, ev: Map[String, Eff]) -> (Cx, TFun) !io = {
  var cx1 = enter_fn(cx, s, ev, d.nlo, d.nhi)
  var psyms: List[Int] = []
  var i = 0
  for p in d.params {
    let (cxa, sid) = declare(cx1, p.name, s.param_tys[i], false, p.lo, p.hi)
    cx1 = cxa
    psyms = psyms ++ [sid]
    i = i + 1
  }
  let (cx2, bt, bx) = check_expr(cx1, d.body, Some(s.ret))
  cx1 = cx2
  if not assignable(cx1, bt, s.ret) {
    cx1 = cerr(cx1, "function `" ++ d.name ++ "` declares return type " ++
        ty_show(cx1.adts, s.ret) ++ " but its body is " ++ ty_show(cx1.adts, bt),
      e_lo(d.body), e_hi(d.body))
  }
  cx1 = verify_effects(cx1, "function", d.name, s.eff, "the end of the signature", d.nlo, d.nhi)
  let dsyms = dict_sym_list(cx1, s)
  cx1 = pop_scope(cx1)
  (cx1, TFun {
    name: d.name,
    sig: s,
    param_syms: psyms,
    dict_syms: dsyms,
    body: bx,
    is_test: false,
    impl_of: None,
    default_of: None
  })
}

## Check the body of a signature-inferred function and seal its signature:
## ret = the body's type, eff = the body's effects (or the declared one, which
## is then enforced as usual). The Kotlin checkFnInferred.
pub fn check_fn_inferred(cx: Cx, d: FnDecl, s: Sig, ev: Map[String, Eff]) -> (Cx, Sig, TFun) !io = {
  var cx1 = enter_fn(cx, s, ev, d.nlo, d.nhi)
  var psyms: List[Int] = []
  var i = 0
  for p in d.params {
    let (cxa, sid) = declare(cx1, p.name, s.param_tys[i], false, p.lo, p.hi)
    cx1 = cxa
    psyms = psyms ++ [sid]
    i = i + 1
  }
  let (cx2, bt, bx) = check_expr(cx1, d.body, no_expected())
  cx1 = cx2
  var final_eff = EPure
  if len(d.effs) == 0 {
    final_eff = eff_union(cx1.used_effects)
  } else {
    # the registration pass resolved the declared effect
    cx1 = verify_effects(cx1, "function", d.name, s.eff, "the end of the signature", d.nlo, d.nhi)
    final_eff = s.eff
  }
  let sealed = Sig { ..s, ret: bt, eff: final_eff, inferring: false }
  let dsyms = dict_sym_list(cx1, s)
  var cx3 = pop_scope(cx1)
  if map.get(cx3.fns, d.name) == Some(s) {
    cx3 = Cx { ..cx3, fns: map.insert(cx3.fns, d.name, sealed) }
  }
  (cx3, sealed,
    TFun {
      name: d.name,
      sig: sealed,
      param_syms: psyms,
      dict_syms: dsyms,
      body: bx,
      is_test: false,
      impl_of: None,
      default_of: None
    })
}

## Check a trait's default method body against its own signature (T stays
## rigid). The Kotlin checkTraitDefault.
pub fn check_trait_default(cx: Cx, m2: TraitMethod, s: Sig, body: Expr) -> (Cx, TFun) !io = {
  let empty_ev: Map[String, Eff] = map.empty()
  var cx1 = enter_fn(cx, s, empty_ev, m2.nlo, m2.nhi)
  var psyms: List[Int] = []
  var i = 0
  for p in m2.params {
    let (cxa, sid) = declare(cx1, p.name, s.param_tys[i], false, p.lo, p.hi)
    cx1 = cxa
    psyms = psyms ++ [sid]
    i = i + 1
  }
  let (cx2, bt, bx) = check_expr(cx1, body, Some(s.ret))
  cx1 = cx2
  if not assignable(cx1, bt, s.ret) {
    cx1 = cerr(cx1, "method `" ++ m2.name ++ "` declares return type " ++
        ty_show(cx1.adts, s.ret) ++ " but its default body is " ++ ty_show(cx1.adts, bt),
      e_lo(body), e_hi(body))
  }
  cx1 = verify_effects(cx1, "method", m2.name, s.eff, "the trait method", m2.nlo, m2.nhi)
  let dsyms = dict_sym_list(cx1, s)
  cx1 = pop_scope(cx1)
  (cx1, TFun {
    name: m2.name,
    sig: s,
    param_syms: psyms,
    dict_syms: dsyms,
    body: bx,
    is_test: false,
    impl_of: None,
    default_of: None
  })
}

fn test_sig(name: String) -> Sig =
  Sig {
    name: name,
    param_tys: [],
    param_names: [],
    ret: TyUnit,
    eff: EIo,
    is_builtin: false,
    tparams: [],
    constraints: [],
    owner: None,
    trait_id: None,
    inferring: false
  }

## Check one test block: fresh frame, assert allowed, io implicit (spec §3.4).
pub fn check_test(cx: Cx, name: String, body: Expr) -> (Cx, TFun) !io = {
  let empty_tp: Map[String, Ty] = map.empty()
  let empty_ev: Map[String, Eff] = map.empty()
  let empty_d: Map[(Int, Int), Int] = map.empty()
  let empty_w: Map[Eff, (Int, Int, String)] = map.empty()
  var cx1 = Cx {
    ..cx,
    current_tparams: empty_tp,
    current_eff_vars: empty_ev,
    current_sig: None,
    dict_syms: empty_d,
    used_effects: [],
    eff_witness: empty_w,
    lambda_stack: [],
    loop_stack: [],
    scopes: [],
    in_test: true
  }
  cx1 = push_scope(cx1)
  let (cx2, bt, bx) = check_expr(cx1, body, Some(TyUnit))
  cx1 = cx2
  if not assignable(cx1, bt, TyUnit) {
    cx1 = cerr_h(cx1, "a test block's trailing value is discarded (" ++
        ty_show(cx1.adts, bt) ++ ")", e_lo(body), e_hi(body),
      "assert on it instead of leaving it as the last expression")
  }
  cx1 = pop_scope(cx1)
  cx1 = Cx { ..cx1, in_test: false }
  (cx1, TFun {
    name: name,
    sig: test_sig(name),
    param_syms: [],
    dict_syms: [],
    body: bx,
    is_test: true,
    impl_of: None,
    default_of: None
  })
}

## The initializer must be pure, comptime-evaluable, and match the declared
## type; only earlier constants are visible (the Kotlin checkConstInit).
pub fn check_const_init(
  cx: Cx,
  d: ConstView,
  declared: Ty,
  visible: Set[String]
) -> (Cx, TConst) !io = {
  let empty_tp: Map[String, Ty] = map.empty()
  let empty_ev: Map[String, Eff] = map.empty()
  var cx1 = Cx {
    ..cx,
    current_tparams: empty_tp,
    current_eff_vars: empty_ev,
    const_cutoff: Some(visible)
  }
  let (cx2, frame) = enter_isolated(cx1)
  let (cx3, bt, bx) = check_expr(cx2, d.init, Some(declared))
  cx1 = leave_isolated(cx3, frame, "const initializers", e_lo(d.init), e_hi(d.init))
  if not assignable(cx1, bt, declared) {
    cx1 = cerr(cx1, "`" ++ d.name ++ "` declares type " ++ ty_show(cx1.adts, declared) ++
        " but its initializer is " ++ ty_show(cx1.adts, bt), e_lo(d.init), e_hi(d.init))
  }
  cx1 = Cx { ..cx1, const_cutoff: None }
  (cx1, TConst { name: d.name, ty: declared, init: bx, lo: d.lo, hi: d.hi })
}

fn no_tfun() -> Option[TFun] = None

## The whole checking pipeline for one module (the Kotlin Checker.check()):
## passes 0–4 register declarations, pass 5 checks bodies — inferred functions
## first in call-dependency order, then consts, annotated fns, impl methods,
## trait defaults, tests.
pub fn check_module(cx: Cx, m: Module, env: Map[String, ModExports]) -> (Cx, TModule) !io = {
  var cx1 = seed_prelude(cx)
  cx1 = pass_java_uses(cx1, m)
  cx1 = pass_imports(cx1, m, env)
  let (cxa, shells) = pass_type_shells(cx1, m)
  cx1 = cxa
  cx1 = pass_ctor_fields(cx1, m, shells)
  cx1 = pass_resolve_aliases(cx1)
  cx1 = pass_derive_show(cx1, m, shells)
  cx1 = pass_register_traits(cx1, m)
  let (cxb, impl_sigs) = pass_register_impls(cx1, m, shells)
  cx1 = cxb
  let (cxc, sigs, evs) = pass_fn_signatures(cx1, m)
  cx1 = cxc
  let (cxd, const_tys) = pass_const_decls(cx1, m)
  cx1 = cxd
  cx1 = pass_main_check(cx1, m, sigs)
  # 5. inferred functions first, in call-dependency order — every callee's
  # signature is final before any caller is checked; a cycle must annotate
  let fnds = module_fns(m)
  var sealed = sigs
  var tfuns: List[Option[TFun]] = []
  for _k in 0 ..len(fnds) { tfuns = tfuns ++ [no_tfun()] }
  var pending: List[Int] = []
  var i = 0
  for d in fnds {
    if sigs[i].inferring { pending = pending ++ [i] }
    i = i + 1
  }
  if len(pending) > 0 {
    var pending_names: Set[String] = set.empty()
    for idx in pending { pending_names = set.insert(pending_names, fnds[idx].name) }
    var deps: Map[String, List[String]] = map.empty()
    for idx in pending {
      let d = fnds[idx]
      let refs: Set[String] = name_refs(d.body, set.empty())
      var dlist: List[String] = []
      for r in set.to_list(refs) {
        if set.has(pending_names, r) { dlist = dlist ++ [r] }
      }
      deps = map.insert(deps, d.name, dlist)
    }
    var done: Set[String] = set.empty()
    var progress = true
    while progress {
      progress = false
      var remaining: List[Int] = []
      for idx in pending {
        let d = fnds[idx]
        let dlist = map.get(deps, d.name).expect("dep")
        var ready = true
        for r in dlist {
          if not set.has(done, r) { ready = false }
        }
        if ready {
          let (cxe, ssig, tf) = check_fn_inferred(cx1, d, sealed[idx], evs[idx])
          cx1 = cxe
          sealed = list.take(sealed, idx) ++ [ssig] ++ list.drop(sealed, idx + 1)
          tfuns = list.take(tfuns, idx) ++ [Some(tf)] ++ list.drop(tfuns, idx + 1)
          done = set.insert(done, d.name)
          progress = true
        } else {
          remaining = remaining ++ [idx]
        }
      }
      pending = remaining
    }
    # what remains is a dependency cycle
    for idx in pending {
      let d = fnds[idx]
      cx1 = cerr_h(cx1, "cannot infer the return type of `" ++ d.name ++
          "`: it is recursive (directly or mutually)", d.nlo, d.nhi,
        "declare it: fn " ++ d.name ++ "(...) -> T = ...")
    }
  }
  # 5.5. constant initializers, in declaration order (a const sees only
  # earlier consts; that order is also the evaluation order)
  var tconsts: List[TConst] = []
  var visible: Set[String] = set.empty()
  var ci = 0
  for d in module_consts(m) {
    match const_tys[ci] {
      Some(declared) -> {
        let (cxe, tc) = check_const_init(cx1, d, declared, visible)
        cx1 = cxe
        tconsts = tconsts ++ [tc]
      }
      None -> ()
    }
    visible = set.insert(visible, d.name)
    ci = ci + 1
  }
  # annotated function bodies
  i = 0
  for d in fnds {
    if not sigs[i].inferring {
      let (cxe, tf) = check_fn(cx1, d, sealed[i], evs[i])
      cx1 = cxe
      tfuns = list.take(tfuns, i) ++ [Some(tf)] ++ list.drop(tfuns, i + 1)
    }
    i = i + 1
  }
  # 5.75. impl method bodies and trait default bodies (full signatures, so
  # they check like ordinary annotated functions)
  var ii = 0
  var impl_tfuns: List[TFun] = []
  for imd in module_impls(m) {
    let msigs = impl_sigs[ii]
    # recover (trait id, subject) for codegen's mangled impl-method names;
    # both lookups re-run what registration already validated, diags discarded
    let imp_key: Option[(Int, Ty)] = match map.get(cx1.traits_by_name, imd.trait_name) {
      Some(t) -> {
        let (_, subj) = resolve_type(cx1, imd.subject)
        if subj == TyError { None } else { Some((t, subj)) }
      }
      None -> None
    }
    var mi = 0
    for me in imd.methods {
      match msigs[mi] {
        Some(ms) -> {
          let empty_ev: Map[String, Eff] = map.empty()
          let (cxe, tf) = check_fn(cx1, me, ms, empty_ev)
          cx1 = cxe
          impl_tfuns = impl_tfuns ++ [TFun { ..tf, impl_of: imp_key }]
        }
        None -> ()
      }
      mi = mi + 1
    }
    ii = ii + 1
  }
  var default_tfuns: List[TFun] = []
  for td in module_traits(m) {
    let tid = map.get(cx1.traits_by_name, td.name)
    match tid {
      Some(t) -> {
        let tr = trait_of(cx1.traits, t)
        for me in td.methods {
          match me.body {
            Some(b) -> {
              var msig: Option[Sig] = None
              for entry in tr.methods {
                let (mname, ms2) = entry
                if mname == me.name { msig = Some(ms2.sig) }
              }
              match msig {
                Some(s2) -> {
                  let (cxe, tf) = check_trait_default(cx1, me, s2, b)
                  cx1 = cxe
                  default_tfuns = default_tfuns ++ [TFun { ..tf, default_of: Some(t) }]
                }
                None -> ()
              }
            }
            None -> ()
          }
        }
      }
      None -> ()
    }
  }
  var ttests: List[TFun] = []
  for t in module_tests(m) {
    let (cxe, tf) = check_test(cx1, t.name, t.body)
    cx1 = cxe
    ttests = ttests ++ [tf]
  }
  var fns_out: List[TFun] = []
  for sl in tfuns {
    match sl {
      Some(tf) -> { fns_out = fns_out ++ [tf] }
      None -> ()
    }
  }
  fns_out = fns_out ++ impl_tfuns ++ default_tfuns
  (cx1, TModule { fns: fns_out, consts: tconsts, tests: ttests, syms: cx1.syms })
}

test "check_module: a whole module checks end to end" {
  let src = "fn add(a: Int, b: Int) -> Int = a + b\n" ++
    "fn twice(x: Int) = add(x, x)\n" ++
    "const K: Int = 41\n" ++
    "pub fn main() -> Unit !io = ()\n" ++
    "test \"k\" {\n  assert twice(K) == 82\n}\n"
  let (m, pdiags) = parser.parse_module(src)
  assert len(pdiags) == 0
  let env: Map[String, ModExports] = map.empty()
  let (cx1, tm) = check_module(test_cx(), m, env)
  assert len(cx1.diags) == 0
  # the inferred signature sealed to Int, pure
  let tw = map.get(cx1.fns, "twice").expect("twice")
  assert tw.ret == TyInt
  assert tw.eff == EPure
  assert not tw.inferring
  assert len(tm.fns) == 3
  assert len(tm.consts) == 1
  assert len(tm.tests) == 1
}

test "check_module: a bare None arm infers from a concrete sibling arm" {
  # `entry` is unannotated and the `[]` arm has no expected type of its own; it
  # must borrow Option[Int] from the concrete `Some` arm (match sibling inference)
  let src =
    "pub fn first(xs: List[Int]) -> Bool = {\n" ++
    "  let entry = match xs {\n" ++
    "    [x, ..] -> Some(x)\n" ++
    "    [] -> None\n" ++
    "  }\n" ++
    "  match entry { Some(v) -> true  None -> false }\n" ++
    "}\n"
  let (m, pdiags) = parser.parse_module(src)
  assert len(pdiags) == 0
  let env: Map[String, ModExports] = map.empty()
  let (cx1, _) = check_module(test_cx(), m, env)
  assert len(cx1.diags) == 0
}

test "check_module: an inference cycle must annotate" {
  let src = "fn a2(x: Int) = b2(x)\nfn b2(x: Int) = a2(x)\n"
  let (m, pdiags) = parser.parse_module(src)
  assert len(pdiags) == 0
  let env: Map[String, ModExports] = map.empty()
  let (cx1, _) = check_module(test_cx(), m, env)
  assert len(cx1.diags) == 2
  assert str.contains(cx1.diags[0].msg, "cannot infer the return type of `a2`")
  assert str.contains(cx1.diags[0].msg, "recursive")
}

test "check_module: impl methods and trait defaults check as bodies" {
  let src = "pub type Coin = { v: Int }\n" ++
    "trait Waxy[T] {\n  fn wax(x: T) -> Int\n  fn buff(x: T) -> Int = wax(x) + 1\n}\n" ++
    "impl Waxy[Coin] {\n  fn wax(x: Coin) -> Int = x.v * 2\n}\n"
  let (m, pdiags) = parser.parse_module(src)
  assert len(pdiags) == 0
  let env: Map[String, ModExports] = map.empty()
  let (cx1, tm) = check_module(test_cx(), m, env)
  assert len(cx1.diags) == 0
  # 2 bodies land: the impl's wax and the trait default buff
  assert len(tm.fns) == 2
  # an effectful body under a pure signature reports
  let bad = "fn f() -> Int = g()\nfn g() -> Int !io = 1\n"
  let (m2, _) = parser.parse_module(bad)
  let (cx2, _) = check_module(test_cx(), m2, env)
  assert len(cx2.diags) == 1
  assert cx2.diags[0].msg == "function `f` is not declared !io but calls `g` (!io)"
}

## The pub surface of a checked module for importers (the Kotlin exportsOf).
## The whole ADT/trait tables ride along — extra entries graft harmlessly.
pub fn exports_of(cx: Cx, m: Module, mod_path: String, class_name: String) -> ModExports = {
  var fns2: Map[String, Sig] = map.empty()
  var types2: Map[String, Int] = map.empty()
  var aliases2: Map[String, AliasE] = map.empty()
  var ares2: Map[String, Ty] = map.empty()
  var ctors2: Map[String, (Int, Int)] = map.empty()
  var consts2: Map[String, Ty] = map.empty()
  var traits2: Map[String, Int] = map.empty()
  var all: List[String] = []
  for d in module_fns(m) {
    all = all ++ [d.name]
    if d.is_pub {
      match map.get(cx.fns, d.name) {
        Some(s) -> { fns2 = map.insert(fns2, d.name, s) }
        None -> ()
      }
    }
  }
  for d in module_types(m) {
    all = all ++ [d.name]
    if d.is_pub {
      match map.get(cx.adts_by_name, d.name) {
        Some(aid) -> {
          types2 = map.insert(types2, d.name, aid)
          # a pub type brings its constructors (spec §10.3)
          var ci = 0
          for c in adt_of(cx.adts, aid).ctors {
            ctors2 = map.insert(ctors2, c.name, (aid, ci))
            ci = ci + 1
          }
        }
        None -> ()
      }
      match map.get(cx.aliases, d.name) {
        Some(al) -> {
          aliases2 = map.insert(aliases2, d.name, al)
          match map.get(cx.alias_resolved, d.name) {
            Some(t) -> { ares2 = map.insert(ares2, d.name, t) }
            None -> ()
          }
        }
        None -> ()
      }
    }
  }
  for d in module_consts(m) {
    all = all ++ [d.name]
    if d.is_pub {
      match map.get(cx.consts, d.name) {
        Some(t) -> { consts2 = map.insert(consts2, d.name, t) }
        None -> ()
      }
    }
  }
  for d in module_traits(m) {
    all = all ++ [d.name]
    for me in d.methods { all = all ++ [me.name] }
    if d.is_pub {
      match map.get(cx.traits_by_name, d.name) {
        Some(tid) -> {
          traits2 = map.insert(traits2, d.name, tid)
          # a pub trait's methods are importable like pub fns
          for entry in trait_of(cx.traits, tid).methods {
            let (mname, ms) = entry
            fns2 = map.insert(fns2, mname, ms.sig)
          }
        }
        None -> ()
      }
    }
  }
  ModExports {
    mod_path: mod_path,
    class_name: class_name,
    fns: fns2,
    types_by_name: types2,
    aliases: aliases2,
    alias_resolved: ares2,
    ctors: ctors2,
    consts: consts2,
    all_names: all,
    src_path: cx.src_path,
    traits_by_name: traits2,
    impls: cx.local_impls,
    adt_infos: cx.adts,
    trait_infos: cx.traits
  }
}

test "exports_of exposes the pub surface, and imports consume it" {
  let src = "pub type Pt = { x: Int, y: Int }\n" ++
    "pub fn mk(x: Int, y: Int) -> Pt = Pt { x: x, y: y }\n" ++
    "fn hidden() -> Int = 1\n" ++
    "pub const ORIGIN_X: Int = 0\n"
  let (m, pdiags) = parser.parse_module(src)
  assert len(pdiags) == 0
  let env0: Map[String, ModExports] = map.empty()
  let (cx1, _) = check_module(cx_new(Some("geom"), None), m, env0)
  assert len(cx1.diags) == 0
  let exp = exports_of(cx1, m, "geom", "geom")
  assert map.has(exp.fns, "mk")
  assert not map.has(exp.fns, "hidden")
  assert map.has(exp.types_by_name, "Pt")
  assert map.has(exp.ctors, "Pt")
  assert map.has(exp.consts, "ORIGIN_X")
  # a second module imports it, whole-module and selectively
  let src2 = "use geom\n" ++
    "pub fn go() -> Int = geom.mk(1, 2).x\n"
  let (m2, pdiags2) = parser.parse_module(src2)
  assert len(pdiags2) == 0
  let env = map.from([("geom", exp)])
  let (cx2, _) = check_module(cx_new(Some("use_site"), None), m2, env)
  assert len(cx2.diags) == 0
  # a private name reports as private
  let src3 = "use geom\n" ++
    "pub fn go() -> Int = geom.hidden()\n"
  let (m3, _) = parser.parse_module(src3)
  let (cx3, _) = check_module(cx_new(Some("use_site"), None), m3, env)
  assert cx3.diags[0].msg == "`hidden` is private to module `geom`"
}
