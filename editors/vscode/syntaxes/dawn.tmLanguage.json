{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Dawn",
  "scopeName": "source.dawn",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#effects" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.dawn", "match": "#.*$" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dawn",
          "match": "\\b(if|else|match|for|in|while)\\b"
        },
        {
          "name": "keyword.declaration.dawn",
          "match": "\\b(fn|let|var|type|const|use|java|pub|comptime|test|assert)\\b"
        },
        {
          "name": "keyword.operator.logical.dawn",
          "match": "\\bnot\\b"
        },
        {
          "name": "constant.language.dawn",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "effects": {
      "patterns": [
        { "name": "storage.modifier.effect.dawn", "match": "!\\s*[a-z][a-z0-9_]*" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.dawn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.dawn", "match": "\\\\(n|t|\\\\|\"|\\{|u\\{[0-9A-Fa-f]+\\})" },
        {
          "name": "meta.embedded.interpolation.dawn",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.dawn" } },
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.dawn" } },
          "patterns": [{ "include": "$self" }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.dawn", "match": "\\b0x[0-9A-Fa-f_]+\\b" },
        { "name": "constant.numeric.binary.dawn", "match": "\\b0b[01_]+\\b" },
        { "name": "constant.numeric.float.dawn", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.integer.dawn", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "entity.name.type.dawn", "match": "\\b[A-Z][A-Za-z0-9]*\\b" }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-z][a-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.dawn" },
            "2": { "name": "entity.name.function.dawn" }
          }
        },
        { "name": "entity.name.function.call.dawn", "match": "\\b[a-z][a-z0-9_]*(?=\\()" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.pipe.dawn", "match": "\\|>" },
        { "name": "keyword.operator.dawn", "match": "(\\+\\+|==|!=|<=|>=|&&|\\|\\||->|=>|\\.\\.|[+\\-*/%<>=?])" }
      ]
    }
  }
}
