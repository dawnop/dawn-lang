fn judge(n: Int) -> String =
  match n {
    0 | 1 -> "tiny"
    x if x < 0 -> "negative"
    100 -> "century"
    _ -> "normal"
  }

fn color(name: String) -> String =
  match name {
    "red" -> "#f00"
    "blue" -> "#00f"
    other -> "unknown: " ++ other
  }

pub fn main() -> Unit !io = {
  println(judge(0))
  println(judge(-5))
  println(judge(100))
  println(judge(42))
  println(color("red"))
  println(color("cyan"))
}
