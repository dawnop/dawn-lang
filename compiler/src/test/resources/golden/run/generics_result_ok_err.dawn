fn div(a: Int, b: Int) -> Result[Int, String] =
  if b == 0 { Err("division by zero") } else { Ok(a / b) }

fn show(r: Result[Int, String]) -> String =
  match r {
    Ok(v) -> "ok $v"
    Err(m) -> "err: $m"
  }

pub fn main() -> Unit !io = {
  println(show(div(10, 3)))
  println(show(div(1, 0)))
}
