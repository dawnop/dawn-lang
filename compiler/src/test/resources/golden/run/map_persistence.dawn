# Map/Set semantics on the persistent HAMT (spec §2.2): insertion-order
# iteration, update keeps position, persistence, order-independent equality.

use std/map
use std/set

pub fn main() -> Unit !io = {
  var m: Map[String, Int] = map.empty()
  m = map.insert(m, "b", 2)
  m = map.insert(m, "a", 1)
  m = map.insert(m, "c", 3)
  m = map.insert(m, "b", 20)         # updating b keeps its original position

  println(to_string(map.size(m)))
  println(to_string(m["a"]))
  println(to_string(m["b"]))
  println(to_string(map.keys(m)))    # insertion order, b still first
  println(to_string(map.values(m)))
  println(to_string(map.has(m, "z")))

  let m2 = map.remove(m, "a")
  println(to_string(map.keys(m2)))
  println(to_string(map.keys(m)))    # original unchanged: the map is persistent

  # equal keys/values in any insertion order compare equal
  var p: Map[String, Int] = map.empty()
  p = map.insert(p, "c", 3)
  p = map.insert(p, "b", 20)
  p = map.insert(p, "a", 1)
  println(to_string(m == p))

  # Set: duplicate ignored, insertion order preserved
  var s: Set[Int] = set.empty()
  s = set.insert(s, 3)
  s = set.insert(s, 1)
  s = set.insert(s, 3)
  println(to_string(set.size(s)))
  println(to_string(set.to_list(s)))
  println(to_string(set.has(s, 1)))
}
