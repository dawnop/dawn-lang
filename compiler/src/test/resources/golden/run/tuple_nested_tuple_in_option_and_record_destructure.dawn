type Pair = { fst: Int, snd: String }

fn find(k: Int) -> Option[(Int, String)] =
  if k == 1 { Some((10, "ten")) } else { None }

pub fn main() -> Unit !io = {
  match find(1) {
    Some((n, s)) -> println("$n=$s")
    None -> println("missing")
  }
  let Pair { fst, snd } = Pair { fst: 5, snd: "five" }
  println("$fst $snd")
}
