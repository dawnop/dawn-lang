# A `.` may start the next line (spec §1.7) — the vertical method-chain style
# Java builder APIs want. Same continuation privilege |> already has.

use java "java.lang.StringBuilder"

pub fn main() -> Unit !io = {
  let s = StringBuilder.new()
    .append("a")!
    .append("b")!
    .append("c")!
    .toString()!
  println(s)

  # mixes with fields and indexing on Dawn values too
  let xs = [10, 20, 30]
  let n = xs
    .get(1)!
  println(to_string(n))
}
