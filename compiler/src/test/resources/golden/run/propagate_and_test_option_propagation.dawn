fn both_first(a: List[Int], b: List[Int]) -> Option[Int] = {
  let x = get(a, 0)?
  let y = get(b, 0)?
  Some(x + y)
}

fn show(o: Option[Int]) -> String =
  match o {
    Some(v) -> "$v"
    None -> "none"
  }

pub fn main() -> Unit !io = {
  println(show(both_first([1], [2])))
  println(show(both_first([1], [])))
}
