use java "java.lang.System"

pub fn main() -> Unit !io = {
  match System.getProperty("java.version") {
    Some(v) -> println("has version: ${len(chars(v)) > 0}")
    None -> println("none")
  }
  match System.getProperty("definitely.not.set.dawn") {
    Some(_) -> println("set?!")
    None -> println("unset")
  }
}
