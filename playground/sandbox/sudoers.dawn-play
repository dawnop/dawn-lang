# /etc/sudoers.d/dawn-play  (install: visudo -c -f this file, then copy, chmod 440)
#
# Let the dawn-play service user invoke ONLY the sandbox wrapper, without a
# password and without inheriting any other privilege. The wrapper itself pins
# every systemd sandbox property, so this grant cannot be widened by argument.
#
# The trailing "" after the path means: no fixed arguments required, any args
# allowed — the wrapper validates its own workdir argument.
dawn-play ALL=(root) NOPASSWD: /opt/dawn/playground/sandbox/run-sandboxed.sh ""
