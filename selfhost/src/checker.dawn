  DType, TypeDeclR, CtorDecl, FieldDecl, DTrait, TraitMethod, Param, Expr,
  Decl, DImpl, FnDecl, EBool, DFn, EVar, DConst, EInt,
  BinOp, UnOp, OpAdd, OpSub, OpMul, OpDiv, OpMod, OpConcat, OpEq, OpNeq, OpLt,
  OpLe, OpGt, OpGe, OpAnd, OpOr, OpBand, OpBor, OpBxor, OpShl, OpShr, OpUshr,
  OpNeg, OpNot, OpBnot,
  Pattern, PLit, PBind, PWild, PCtor, PTuple, PList, PatArg, MatchArm, CtorArg,
  SPText, SPInterp, EFloat, EStr, pat_lo, pat_hi, e_lo, e_hi,
  ECall, EMethod, EApply, ELambda, EBlock, EIf, EMatch, ECtor, EFieldAcc,
  EListLit, ETupleLit, EBinary, EUnary, EPropagate, EUnwrap, EIndex, EReturn,
  EComptime, EUnsafePure, Stmt, SLet, SLetPat, SLocalFn, SAssign, SExpr,
  SAssert, SWhile, SFor, LambdaParam, ConstView
}
