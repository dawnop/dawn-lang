# trait/impl declarations and constrained type parameters
pub trait Ord[T] {
  fn cmp(a: T, b: T) -> Int
  fn max_of(a: T, b: T) -> T = if cmp(a, b) >= 0 { a } else { b }
}

type Point = { x: Int, y: Int }

impl Ord[Point] {
  fn cmp(a: Point, b: Point) -> Int =
    if a.x != b.x { a.x - b.x } else { a.y - b.y }
}

fn sort2[T: Ord + Show](xs: List[T]) -> List[T] = xs

type Task = { name: String, priority: Int } derive Show, Ord
